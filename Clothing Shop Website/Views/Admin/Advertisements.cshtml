@model List<Clothing_Shop_Website.Models.Advertisement>
@{
    ViewData["Title"] = "Quảng cáo";
    Layout = null;
    string PosLabel(string p) => p switch { "banner" => "Banner", "popup" => "Popup", "sidebar" => "Sidebar", _ => p };
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>NEVA Admin — Quảng cáo</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Josefin+Sans:wght@200;300;400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/neva-base.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-staff.css" asp-append-version="true"/>
</head>
<body>
<div class="toast" id="toast"></div>
<nav class="admin-nav">
    <span class="admin-nav-logo">NEVA</span><span class="admin-nav-sep">|</span><span class="admin-nav-badge">Admin</span>
</nav>
<div class="admin-wrap">
    <aside class="admin-sidebar">
        <div class="sb-section">
            <div class="sb-lbl">Quản lý</div>
            <a asp-controller="Admin" asp-action="Dashboard" class="sitem"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
            <a asp-controller="Admin" asp-action="Products" class="sitem"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Sản phẩm</a>
            <a asp-controller="Admin" asp-action="Staff" class="sitem"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Nhân viên</a>
            <a asp-controller="Admin" asp-action="Advertisements" class="sitem active"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Quảng cáo</a>
        </div>
        <div class="sb-section" style="margin-top:12px">
            <a asp-controller="Account" asp-action="Logout" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Đăng xuất</a>
        </div>
    </aside>
    <main class="admin-main">

        @if (TempData["Success"] != null)
        {
            <div style="padding:10px 16px;background:rgba(90,154,90,.1);border:1px solid rgba(90,154,90,.3);color:#7aba7a;font-size:11px;margin-bottom:16px">✦ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="padding:10px 16px;background:rgba(180,80,80,.12);border:1px solid rgba(212,122,116,.35);color:#d4a8a4;font-size:11px;margin-bottom:16px">@TempData["Error"]</div>
        }

        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px">
            <div>
                <div class="page-title">Quảng cáo</div>
                <div class="page-sub">Quản lý <strong style="color:var(--gold)">@Model.Count</strong> quảng cáo · Hiển thị trên giao diện khách hàng</div>
            </div>
            <button type="button" class="btn-add" onclick="document.getElementById('addAdMo').style.display='flex';requestAnimationFrame(()=>document.getElementById('addAdMo').classList.add('open'))">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Thêm quảng cáo
            </button>
        </div>

        @if (Model.Count == 0)
        {
            <div style="text-align:center;padding:60px;border:1px dashed var(--border);color:rgba(250,248,242,.25)">
                <svg viewBox="0 0 24 24" style="width:40px;height:40px;fill:none;stroke:currentColor;stroke-width:1;margin:0 auto 12px;display:block"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <div style="font-size:13px;margin-bottom:6px">Chưa có quảng cáo nào</div>
                <div style="font-size:10px;letter-spacing:1.5px">Bấm "Thêm quảng cáo" để bắt đầu</div>
            </div>
        }
        else
        {
            <div class="ads-grid">
                @foreach (var ad in Model)
                {
                    <div class="ad-card">
                        <div class="ad-img-wrap">
                            @if (!string.IsNullOrEmpty(ad.ImageUrl))
                            {
                                <img src="@ad.ImageUrl" alt="@ad.Title" onerror="this.parentElement.innerHTML='<div class=ad-img-placeholder><svg viewBox=\'0 0 24 24\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><polyline points=\'21 15 16 10 5 21\'/></svg><span style=\'font-size:10px;letter-spacing:1px\'>Ảnh lỗi</span></div>'">
                            }
                            else
                            {
                                <div class="ad-img-placeholder">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                    <span style="font-size:10px;letter-spacing:1px">Chưa có ảnh</span>
                                </div>
                            }
                        </div>
                        <div class="ad-body">
                            <div class="ad-title" title="@ad.Title">@ad.Title</div>
                            <div class="ad-meta">
                                <span class="ad-pos-badge">@PosLabel(ad.Position)</span>
                                <span class="ad-active-badge @(ad.IsActive ? "on" : "off")">@(ad.IsActive ? "Đang hiện" : "Ẩn")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(ad.LinkUrl))
                            {
                                <div style="font-size:9px;letter-spacing:1px;color:rgba(250,248,242,.3);margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="@ad.LinkUrl">
                                    🔗 @ad.LinkUrl
                                </div>
                            }
                            <div style="font-size:9px;color:rgba(250,248,242,.25);margin-bottom:10px;letter-spacing:.5px">
                                Tạo: @ad.CreatedDate.ToString("dd/MM/yyyy")
                            </div>
                            <div class="ad-actions">
                                <form method="post" asp-controller="Admin" asp-action="ToggleAdActive" style="flex:1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="adId" value="@ad.AdID" />
                                    <button type="submit" class="ad-btn" style="width:100%">
                                        @(ad.IsActive ? "Ẩn đi" : "Hiện lên")
                                    </button>
                                </form>
                                <form method="post" asp-controller="Admin" asp-action="DeleteAdvertisement" style="flex:1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="adId" value="@ad.AdID" />
                                    <button type="submit" class="ad-btn del" style="width:100%"
                                        onclick="return confirm('Xóa quảng cáo &quot;@Html.Raw(ad.Title.Replace("\"",""))&quot;?')">
                                        Xóa
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </main>
</div>

<!-- ═══ MODAL THÊM QUẢNG CÁO ═══ -->
<div id="addAdMo" class="modal-overlay" style="display:none;backdrop-filter:blur(8px)">
    <div class="modal-box" style="max-width:560px">
        <div class="modal-hdr">
            THÊM QUẢNG CÁO
            <button class="modal-x" onclick="document.getElementById('addAdMo').classList.remove('open');setTimeout(()=>document.getElementById('addAdMo').style.display='none',300)">×</button>
        </div>
        <form method="post" asp-controller="Admin" asp-action="AddAdvertisement" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="modal-grid">
                <label>Tiêu đề</label>
                <input type="text" name="title" class="modal-inp" required placeholder="VD: Sale hè 50% giảm" maxlength="200" />

                <label>Vị trí</label>
                <select name="position" class="modal-inp">
                    <option value="banner">Banner (đầu trang)</option>
                    <option value="popup">Popup (khi mở trang)</option>
                    <option value="sidebar">Sidebar (bên cạnh)</option>
                </select>

                <label>Link URL</label>
                <input type="url" name="linkUrl" class="modal-inp" placeholder="https://... (tùy chọn)" />

                <label>Ảnh quảng cáo</label>
                <div>
                    <div class="dropzone" id="adDropzone">
                        <input type="file" name="imageFile" id="adImageFile" accept="image/*" hidden />
                        <span>Kéo thả hoặc bấm để chọn ảnh</span>
                    </div>
                    <div id="adImgPreview" style="margin-top:8px;display:none">
                        <img id="adPreviewImg" style="max-width:100%;max-height:120px;object-fit:contain;border:1px solid var(--border)" />
                    </div>
                </div>
            </div>

            <!-- Ghi chú hiển thị -->
            <div style="padding:0 18px 14px;font-size:10px;color:rgba(250,248,242,.35);letter-spacing:1px;line-height:1.8">
                <strong style="color:rgba(201,168,76,.6)">Ghi chú vị trí:</strong><br>
                · <strong>Banner</strong> — Thanh banner ngang trên đầu trang chủ<br>
                · <strong>Popup</strong> — Hộp thoại hiện khi khách hàng mở trang lần đầu<br>
                · <strong>Sidebar</strong> — Cột quảng cáo bên cạnh danh sách sản phẩm
            </div>

            <div class="modal-actions">
                <button type="button" class="act-btn"
                    onclick="document.getElementById('addAdMo').classList.remove('open');setTimeout(()=>document.getElementById('addAdMo').style.display='none',300)">Hủy</button>
                <button type="submit" class="act-btn" style="border-color:var(--gold);color:var(--gold)">Thêm quảng cáo</button>
            </div>
        </form>
    </div>
</div>

<script src="~/js/neva-base.js" asp-append-version="true"></script>
<script>
// Dropzone + preview ảnh
(function(){
    const dz = document.getElementById('adDropzone');
    const fi = document.getElementById('adImageFile');
    const prev = document.getElementById('adImgPreview');
    const img = document.getElementById('adPreviewImg');
    if (!dz || !fi) return;
    dz.addEventListener('click', () => fi.click());
    dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dz-over'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('dz-over'));
    dz.addEventListener('drop', e => {
        e.preventDefault();
        dz.classList.remove('dz-over');
        const f = e.dataTransfer.files?.[0];
        if (f) { fi.files = e.dataTransfer.files; showPreview(f); }
    });
    fi.addEventListener('change', () => {
        if (fi.files?.[0]) showPreview(fi.files[0]);
    });
    function showPreview(file) {
        dz.querySelector('span').textContent = file.name;
        const reader = new FileReader();
        reader.onload = e => { img.src = e.target.result; prev.style.display = 'block'; };
        reader.readAsDataURL(file);
    }
})();
</script>
</body>
</html>
