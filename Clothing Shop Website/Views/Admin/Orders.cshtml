   items:[{img:'https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?w=100&q=80',name:'Áo blouse lụa cổ V x2',meta:'Kem · M',price:'1.960.000đ'},{img:'https://images.unsplash.com/photo-1506629082955-511b1aa562c8?w=100&q=80',name:'Quần wide-leg linen x1',meta:'Đen · S',price:'1.350.000đ'},{img:'https://images.unsplash.com/photo-1502716119720-b23a93e5fe1b?w=100&q=80',name:'Đầm cocktail x1',meta:'Đen · S',price:'1.890.000đ'}],
