@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEVA Admin — Đơn hàng</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--gold:#c9a84c;--gold2:#e8c96a;--black:#050402;--dark:#0c0a07;--dark2:#14100a;--white:#faf8f2;--border:rgba(201,168,76,0.18);--font-d:'Playfair Display',serif;--font-b:'Josefin Sans',sans-serif;--font-a:'EB Garamond',serif;--nav-h:52px;--side-w:220px}
body{font-family:var(--font-b);background:var(--black);color:var(--white);min-height:100vh;display:flex;flex-direction:column}
a{text-decoration:none;color:inherit}
img{display:block;width:100%;height:100%;object-fit:cover}
nav{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 44px;height:var(--nav-h);background:rgba(5,4,2,.97);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;flex-shrink:0}
.nav-logo{font-family:var(--font-d);font-size:18px;letter-spacing:8px;justify-self:start;display:flex;align-items:center;gap:12px}
.nav-logo a{font-family:var(--font-d);font-size:18px;letter-spacing:8px;color:var(--white)}
.nav-logo-sep{color:rgba(250,248,242,.2);font-size:16px;font-weight:200}
.nav-badge{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.6);border:1px solid rgba(201,168,76,.25);padding:2px 10px}
.nav-mid{display:flex;align-items:center;justify-content:center}
.nl{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(250,248,242,.7);padding:0 14px;transition:color .2s}
.nl:hover{color:var(--white)}
.nd{color:rgba(250,248,242,.14);font-size:10px}
.nav-right{display:flex;gap:14px;justify-self:end;align-items:center}
.ni{color:rgba(250,248,242,.55);transition:color .2s;display:flex;align-items:center}
.ni:hover{color:var(--gold)}
.ni svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.admin-wrap{display:flex;flex:1}
.admin-sidebar{width:var(--side-w);flex-shrink:0;background:var(--dark);border-right:1px solid var(--border);padding:20px 0;position:sticky;top:var(--nav-h);height:calc(100vh - var(--nav-h));overflow-y:auto}
.sb-section{margin-bottom:6px;padding:0 14px}
.sb-lbl{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.32);margin-bottom:6px;padding:0 6px}
.sitem{display:flex;align-items:center;gap:11px;padding:11px 12px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(250,248,242,.42);transition:all .2s;position:relative;border-left:2px solid transparent}
.sitem:hover{background:rgba(201,168,76,.04);color:rgba(250,248,242,.8);border-left-color:rgba(201,168,76,.3)}
.sitem.active{color:var(--gold);background:rgba(201,168,76,.06);border-left-color:var(--gold)}
.sitem svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:1.4;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;opacity:.7}
.sitem.active svg{opacity:1}
.sitem-badge{margin-left:auto;background:var(--gold);color:var(--black);font-size:8px;padding:1px 6px}
.sitem.danger{color:rgba(212,122,118,.5)}
.sitem.danger:hover{color:#d47a76;background:rgba(212,122,118,.04)}
.admin-main{flex:1;padding:26px 30px;overflow-y:auto}
.top-bar{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px}
.page-title{font-family:var(--font-d);font-size:34px;font-weight:400;font-style:italic}
.page-sub{font-size:10px;letter-spacing:2px;color:rgba(250,248,242,.3);margin-top:4px}
.filter-tabs{display:flex;margin-bottom:16px}
.ftab{padding:9px 18px;font-size:8px;letter-spacing:2px;text-transform:uppercase;background:transparent;border:1px solid var(--border);font-family:var(--font-b);color:rgba(250,248,242,.3);margin-left:-1px;transition:all .2s}
.ftab:hover{color:rgba(250,248,242,.65);border-color:rgba(201,168,76,.3)}
.ftab.active{background:var(--gold);color:var(--black);border-color:var(--gold);z-index:1}
.toolbar{display:flex;gap:10px;align-items:center;margin-bottom:16px}
.search-box{display:flex;align-items:center;border:1px solid var(--border);background:var(--dark2);flex:1;max-width:320px}
.search-box input{background:transparent;border:none;outline:none;padding:9px 13px;font-size:11px;letter-spacing:1px;font-family:var(--font-b);color:var(--white);width:100%}
.search-box input::placeholder{color:rgba(250,248,242,.2)}
.search-box svg{width:13px;height:13px;fill:none;stroke:rgba(250,248,242,.3);stroke-width:1.5;stroke-linecap:round;margin-right:10px;flex-shrink:0}
.result-info{font-size:10px;letter-spacing:1.5px;color:rgba(250,248,242,.28);margin-left:auto}
.result-info strong{color:var(--gold)}
.otable{width:100%;border-collapse:collapse;background:var(--dark2);border:1px solid var(--border)}
.otable th{font-size:8px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(201,168,76,.38);padding:12px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.15)}
.otable td{padding:12px 16px;border-bottom:1px solid rgba(201,168,76,.05);font-size:11px;font-weight:200;letter-spacing:.5px;vertical-align:middle}
.otable tr:last-child td{border-bottom:none}
.otable tr:hover td{background:rgba(201,168,76,.02)}
.otag{font-size:8px;letter-spacing:1.5px;padding:3px 9px;border:1px solid;display:inline-flex;align-items:center;gap:5px}
.otag-d{width:4px;height:4px;border-radius:50%}
.t-p{border-color:rgba(201,168,76,.35);color:var(--gold)}.t-p .otag-d{background:var(--gold)}
.t-s{border-color:rgba(150,100,220,.4);color:#c084e8}.t-s .otag-d{background:#c084e8}
.t-d{border-color:rgba(80,180,80,.4);color:#7aba7a}.t-d .otag-d{background:#7aba7a}
.t-c{border-color:rgba(212,120,116,.4);color:#d47a76}.t-c .otag-d{background:#d47a76}
.act-row{display:flex;gap:6px}
.ia-btn{width:30px;height:30px;border:1px solid var(--border);background:transparent;display:flex;align-items:center;justify-content:center;transition:all .2s}
.ia-btn:hover{border-color:var(--gold)}
.ia-btn svg{width:12px;height:12px;fill:none;stroke:rgba(250,248,242,.4);stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s}
.ia-btn:hover svg{stroke:var(--gold)}
.sel-status{padding:5px 10px;border:1px solid var(--border);background:var(--dark2);font-size:9px;letter-spacing:1px;font-family:var(--font-b);color:var(--white);outline:none;transition:border-color .2s}
.sel-status:focus{border-color:var(--gold)}
.toast{position:fixed;bottom:28px;right:28px;z-index:9000;padding:11px 20px;font-size:10px;letter-spacing:1.5px;border:1px solid;display:none}
.toast.ok{background:rgba(90,154,90,.12);border-color:rgba(90,154,90,.4);color:#7aba7a}
.toast.info{background:rgba(201,168,76,.08);border-color:rgba(201,168,76,.28);color:var(--gold)}
.toast.err{background:rgba(201,80,76,.08);border-color:rgba(201,80,76,.3);color:#d47a76}
/* Modal */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:300;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(8px)}
.mo.open{opacity:1;pointer-events:all}
.modal{background:var(--dark2);width:92%;max-width:680px;max-height:88vh;overflow-y:auto;border:1px solid var(--border);transform:translateY(14px);transition:transform .3s cubic-bezier(.16,1,.3,1)}
.mo.open .modal{transform:translateY(0)}
.modal::-webkit-scrollbar{width:2px}.modal::-webkit-scrollbar-thumb{background:var(--border)}
.mhdr{padding:17px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--dark2);z-index:5}
.mhdr-t{font-family:var(--font-d);font-size:20px;font-style:italic}
.mhdr-s{font-size:9px;letter-spacing:1.5px;color:rgba(201,168,76,.45);margin-top:2px}
.mclose{width:28px;height:28px;border:1px solid var(--border);background:none;color:var(--white);display:flex;align-items:center;justify-content:center;transition:border-color .2s}
.mclose:hover{border-color:var(--gold)}
.mclose svg{width:11px;height:11px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round}
.mbody{padding:20px 22px}
.m2col{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
.mblock{background:rgba(201,168,76,.03);border:1px solid rgba(201,168,76,.1);padding:13px}
.mblock-t{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.42);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid rgba(201,168,76,.08)}
.mrow{display:flex;justify-content:space-between;margin-bottom:6px;font-size:11px;font-weight:200}
.mkey{color:rgba(250,248,242,.32)}
.mitems-wrap{border:1px solid rgba(201,168,76,.1);margin-bottom:14px;overflow:hidden}
.mitems-t{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.42);padding:9px 14px;border-bottom:1px solid rgba(201,168,76,.08);background:rgba(201,168,76,.02)}
.mitem{display:flex;align-items:center;gap:11px;padding:10px 14px;border-bottom:1px solid rgba(201,168,76,.06)}
.mitem:last-child{border-bottom:none}
.mitem-thumb{width:40px;height:50px;flex-shrink:0;overflow:hidden}
.mitem-thumb img{filter:brightness(.82)}
.mitem-name{font-size:12px;font-weight:200;margin-bottom:2px}
.mitem-meta{font-size:9px;letter-spacing:1px;color:rgba(250,248,242,.28)}
.mitem-price{margin-left:auto;font-size:12px;font-weight:300;flex-shrink:0}
.mtotals{background:rgba(201,168,76,.03);border:1px solid rgba(201,168,76,.1);padding:12px 14px;margin-bottom:14px}
.mtrow{display:flex;justify-content:space-between;font-size:11px;font-weight:200;margin-bottom:6px}
.mtrow.grand{font-size:15px;font-weight:400;color:var(--gold);padding-top:9px;border-top:1px solid var(--border);margin-bottom:0}
.mtlbl{color:rgba(250,248,242,.32)}
.status-update{background:rgba(201,168,76,.04);border:1px solid rgba(201,168,76,.15);padding:14px}
.su-lbl{font-size:8px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(201,168,76,.5);margin-bottom:10px}
.su-row{display:flex;gap:8px;align-items:center}
.su-sel{flex:1;padding:9px 12px;border:1px solid var(--border);background:var(--dark2);font-size:11px;font-family:var(--font-b);color:var(--white);outline:none}
.su-sel:focus{border-color:var(--gold)}
.btn-gold{padding:9px 20px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:8px;letter-spacing:2px;text-transform:uppercase;border:none;font-family:var(--font-b);transition:opacity .2s}.btn-gold:hover{opacity:.85}
.btn-outline{padding:9px 16px;background:transparent;color:rgba(250,248,242,.38);font-size:8px;letter-spacing:2px;text-transform:uppercase;border:1px solid var(--border);font-family:var(--font-b);transition:all .2s}.btn-outline:hover{border-color:var(--gold);color:var(--gold)}
.mfoot{padding:13px 22px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;position:sticky;bottom:0;background:var(--dark2)}
</style>
</head>
<body>
<div class="toast" id="toast"></div>
<nav>
  <div class="nav-logo"><a href="/">NEVA</a><span class="nav-logo-sep">|</span><span class="nav-badge">Admin</span></div>
  <div class="nav-mid"><a href="/Product" class="nl">Cửa hàng</a><span class="nd">|</span><a href="/Account/Profile" class="nl">Tài khoản</a></div>
  <div class="nav-right">
    <a href="/Account/Profile" class="ni"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></a>
    <a href="/Cart" class="ni"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></a>
  </div>
</nav>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="sb-section">
      <div class="sb-lbl">Tổng quan</div>
      <a href="/Admin/Dashboard" class="sitem"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
    </div>
    <div class="sb-section">
      <div class="sb-lbl">Quản lý</div>
      <a href="/Admin/Products" class="sitem"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Sản phẩm</a>
      <a href="/Admin/Orders" class="sitem active"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>Đơn hàng<span class="sitem-badge" id="pendingBadge">4</span></a>
      <a href="#" class="sitem"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>Khách hàng</a>
    </div>
    <div class="sb-section">
      <div class="sb-lbl">Hệ thống</div>
      <a href="/" class="sitem"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>Trang chủ</a>
      <a href="/Account/Login" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Đăng xuất</a>
    </div>
  </aside>
  <main class="admin-main">
    <div class="top-bar">
      <div><div class="page-title">Đơn hàng</div><div class="page-sub">Quản lý toàn bộ đơn hàng</div></div>
    </div>
    <div class="filter-tabs">
      <button class="ftab active" onclick="filterOrders('all',this)">Tất cả</button>
      <button class="ftab" onclick="filterOrders('pending',this)">Chờ duyệt</button>
      <button class="ftab" onclick="filterOrders('shipping',this)">Đang giao</button>
      <button class="ftab" onclick="filterOrders('done',this)">Đã giao</button>
      <button class="ftab" onclick="filterOrders('cancel',this)">Đã hủy</button>
    </div>
    <div class="toolbar">
      <div class="search-box"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg><input type="text" placeholder="Tìm mã đơn, khách hàng..." id="searchInput" oninput="renderOrders()"></div>
      <div class="result-info">Hiển thị <strong id="countDisplay">0</strong> đơn</div>
    </div>
    <table class="otable">
      <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Ngày đặt</th><th>Sản phẩm</th><th>Tổng tiền</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
      <tbody id="tbody"></tbody>
    </table>
  </main>
</div>

<!-- MODAL CHI TIẾT + CẬP NHẬT -->
<div class="mo" id="mo" onclick="if(event.target===this)closeMo()">
  <div class="modal">
    <div class="mhdr">
      <div><div class="mhdr-t">Chi tiết đơn hàng</div><div class="mhdr-s" id="mhdrS"></div></div>
      <button class="mclose" onclick="closeMo()"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div class="mbody">
      <div class="m2col">
        <div class="mblock"><div class="mblock-t">Thông tin đơn</div><div class="mrow"><span class="mkey">Mã đơn</span><span id="mId" style="color:var(--gold)"></span></div><div class="mrow"><span class="mkey">Ngày đặt</span><span id="mDate"></span></div><div class="mrow"><span class="mkey">Thanh toán</span><span>COD</span></div></div>
        <div class="mblock"><div class="mblock-t">Khách hàng</div><div class="mrow"><span class="mkey">Họ tên</span><span id="mCust"></span></div><div class="mrow"><span class="mkey">SĐT</span><span id="mPhone"></span></div><div class="mrow"><span class="mkey">Địa chỉ</span><span id="mAddr" style="text-align:right;max-width:140px"></span></div></div>
      </div>
      <div class="mitems-wrap"><div class="mitems-t">Sản phẩm</div><div id="mItems"></div></div>
      <div class="mtotals" id="mTotals"></div>
      <div class="status-update">
        <div class="su-lbl">Cập nhật trạng thái đơn hàng</div>
        <div class="su-row">
          <select class="su-sel" id="statusSel">
            <option value="pending">Chờ duyệt</option>
            <option value="confirmed">Đã xác nhận</option>
            <option value="shipping">Đang giao hàng</option>
            <option value="done">Đã giao hàng</option>
            <option value="cancel">Đã hủy</option>
          </select>
          <button class="btn-gold" onclick="updateStatus()">Cập nhật</button>
        </div>
      </div>
    </div>
    <div class="mfoot"><button class="btn-outline" onclick="closeMo()">Đóng</button></div>
  </div>
</div>

<script>
function toast(m,t='ok'){const el=document.getElementById('toast');el.textContent=m;el.className='toast '+t;el.style.display='block';setTimeout(()=>el.style.display='none',2500)}
function fmt(n){return n.toLocaleString('vi-VN')+'đ'}
