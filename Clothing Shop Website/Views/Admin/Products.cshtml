@model List<Clothing_Shop_Website.Models.Product>
@inject Clothing_Shop_Website.Data.AppDbContext Db
@{
    ViewData["Title"] = "Sản phẩm";
    Layout = null;
    var categories = ViewBag.Categories as List<Clothing_Shop_Website.Models.Category>;
    var totalInDb = (int)(ViewBag.TotalInDb ?? Model.Count);
    string GetSeason(int s) => s switch { 1=>"Xuân",2=>"Hạ",3=>"Thu",4=>"Đông",_=>"" };
    int TotalStock(Clothing_Shop_Website.Models.Product p) =>
        p.ProductSizes?.Sum(x => x.StockQuantity) ?? 0;
    string SizeSummary(Clothing_Shop_Website.Models.Product p) =>
        p.ProductSizes == null || !p.ProductSizes.Any()
            ? "—"
            : string.Join(", ", p.ProductSizes.OrderBy(x => x.SizeName).Select(x => $"{x.SizeName}:{x.StockQuantity}"));
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>NEVA Admin — Sản phẩm</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/neva-base.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-sanpham.css" asp-append-version="true"/>
</head>
<body>
<div class="toast" id="toast"></div>
<nav class="admin-nav">
    <span class="admin-nav-logo">NEVA</span><span class="admin-nav-sep">|</span><span class="admin-nav-badge">Admin</span>
</nav>
<div class="admin-wrap">
    <aside class="admin-sidebar">
        <div class="sb-section">
            <div class="sb-lbl">Quản lý</div>
            <a asp-controller="Admin" asp-action="Dashboard" class="sitem"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
            <a asp-controller="Admin" asp-action="Products"  class="sitem active"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Sản phẩm</a>
            <a asp-controller="Admin" asp-action="Staff" class="sitem"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Nhân viên</a>
            <a asp-controller="Admin" asp-action="Advertisements" class="sitem"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Quảng cáo</a>
        </div>
        <div class="sb-section" style="margin-top:12px">
            <a asp-controller="Account" asp-action="Logout" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Đăng xuất</a>
        </div>
    </aside>
    <main class="admin-main">
        @if (TempData["Success"] != null) {
            <div style="padding:10px 16px;background:rgba(90,154,90,.1);border:1px solid rgba(90,154,90,.3);color:#7aba7a;font-size:11px;margin-bottom:16px">✦ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null) {
            <div style="padding:10px 16px;background:rgba(180,80,80,.12);border:1px solid rgba(212,122,116,.35);color:#d4a8a4;font-size:11px;margin-bottom:16px">@TempData["Error"]</div>
        }

        <!-- TABS -->
        <div class="admin-tabs">
            <button class="atab active" onclick="switchTab('products',this)">Sản phẩm</button>
            <button class="atab" onclick="switchTab('discounts',this)">Mã giảm giá</button>
        </div>

        <!-- TAB SẢN PHẨM -->
        <div id="productsTab">
            <div class="top-bar" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px">
                <div>
                    <div class="page-title">Sản phẩm</div>
                    <div class="page-sub">
                        Hiển thị <strong style="color:var(--gold)">@Model.Count</strong> / <strong style="color:var(--gold)">@totalInDb</strong> sản phẩm trong database
                        @if (totalInDb == 0) { <span style="color:rgba(250,248,242,.4)"> · Chạy <code style="font-size:10px">Seed_Realistic_Data.sql</code> trong SSMS (UTF-8, sqlcmd -f 65001)</span> }
                    </div>
                </div>
                <div style="display:flex;gap:8px;align-items:center">
                    <button type="button" id="btnPublishAll"
                        style="display:flex;align-items:center;gap:7px;padding:9px 16px;background:transparent;border:1px solid rgba(122,184,232,.4);color:#7ab8e8;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-family:var(--font-b);cursor:pointer;transition:all .2s"
                        onmouseover="this.style.background='rgba(122,184,232,.06)'"
                        onmouseout="this.style.background='transparent'"
                        onclick="publishToFrontend()">
                        <svg viewBox="0 0 24 24" style="width:13px;height:13px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                        Cập nhật lên giao diện
                    </button>
                    <button type="button" class="btn-add" id="btnOpenAddProduct">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Thêm sản phẩm
                    </button>
                </div>
            </div>
            <!-- Filter -->
            <form method="get" asp-controller="Admin" asp-action="Products" style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap">
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Tìm sản phẩm..."
                    style="padding:9px 13px;border:1px solid var(--border);background:var(--dark2);font-size:12px;font-family:var(--font-b);color:var(--white);outline:none;flex:1;max-width:280px">
                <select name="categoryId" style="padding:9px 13px;border:1px solid var(--border);background:var(--dark2);font-size:12px;font-family:var(--font-b);color:var(--white);outline:none">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var cat in categories!)
                    {
                        @if (ViewBag.CategoryId?.ToString() == cat.CategoryID.ToString())
                        { <option value="@cat.CategoryID" selected>@cat.CategoryName</option> }
                        else
                        { <option value="@cat.CategoryID">@cat.CategoryName</option> }
                    }
                </select>
                <select name="season" style="padding:9px 13px;border:1px solid var(--border);background:var(--dark2);font-size:12px;font-family:var(--font-b);color:var(--white);outline:none">
                    <option value="">Tất cả mùa</option>
                    @foreach (var (num,name) in new[]{(1,"Xuân"),(2,"Hạ"),(3,"Thu"),(4,"Đông")})
                    {
                        @if (ViewBag.Season == num.ToString())
                        { <option value="@num" selected>@name</option> }
                        else
                        { <option value="@num">@name</option> }
                    }
                </select>
                <button type="submit" style="padding:9px 18px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:10px;letter-spacing:2px;text-transform:uppercase;border:none;font-family:var(--font-b)">Lọc</button>
                <a asp-controller="Admin" asp-action="Products" style="padding:9px 16px;border:1px solid var(--border);color:rgba(250,248,242,.5);font-size:10px;letter-spacing:2px;text-transform:uppercase;font-family:var(--font-b);text-decoration:none">Xóa lọc</a>
            </form>

            <table class="ptable" style="width:100%;border-collapse:collapse;background:var(--dark2);border:1px solid var(--border)">
                <thead><tr>
                    <th style="width:50px"></th>
                    <th>Mã</th><th>Sản phẩm</th><th>Danh mục</th><th>Mùa</th><th>Giá</th><th>Tồn kho</th><th>Thao tác</th>
                </tr></thead>
                <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8" style="text-align:center;padding:28px;color:rgba(250,248,242,.35);font-size:11px;letter-spacing:1px">
                            @if (totalInDb == 0)
                            {
                                <span>Chưa có dữ liệu. Chạy file <strong style="color:var(--gold)">DataWarehouse_Scripts/Seed_Realistic_Data.sql</strong> trong SSMS hoặc sqlcmd (-f 65001).</span>
                            }
                            else
                            {
                                <span>Không có sản phẩm khớp bộ lọc. <a asp-controller="Admin" asp-action="Products" style="color:var(--gold)">Xóa lọc</a></span>
                            }
                        </td>
                    </tr>
                }
                @foreach (var p in Model)
                {
                    var stock = TotalStock(p);
                    var lowStock = p.ProductSizes != null && p.ProductSizes.Any(s => s.StockQuantity <= s.MinimumStock);
                    <tr>
                        <td style="font-size:11px;color:rgba(201,168,76,.7);white-space:nowrap">#@p.ProductID.ToString("D3")</td>
                        <td>
                            <div style="display:flex;gap:10px;align-items:center">
                                <div style="width:44px;height:55px;overflow:hidden;flex-shrink:0"><img src="@p.ImageUrl" style="width:100%;height:100%;object-fit:cover;filter:brightness(.82)" onerror="this.style.display='none'"></div>
                                <div>
                                    <div style="font-family:'EB Garamond',serif;font-size:14px;font-style:italic;color:var(--white);margin-bottom:2px">@p.ProductName</div>
                                    @if (!string.IsNullOrEmpty(p.Description))
                                    {
                                        <div style="font-size:10px;color:rgba(250,248,242,.35);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@p.Description</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>@p.Category?.CategoryName</td>
                        <td>@GetSeason(p.Session)</td>
                        <td style="white-space:nowrap">@p.Price.ToString("N0")đ</td>
                        <td style="white-space:nowrap">
                            <span style="font-size:13px;color:@(lowStock ? "#d47a76" : "#7aba7a")">@stock</span>
                            <div style="font-size:9px;color:rgba(250,248,242,.35);margin-top:2px">@SizeSummary(p)</div>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <button onclick="openEditMo(@p.ProductID,'@Html.Raw(p.ProductName.Replace("'","\\'"))','@p.CategoryID','@p.Session','@p.Price',0,'@p.ImageUrl','@Html.Raw((p.Description??"").Replace("'","\\\'"))')"
                                    style="width:30px;height:30px;border:1px solid var(--border);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:border-color .2s"
                                    onmouseover="this.style.borderColor='var(--gold)'" onmouseout="this.style.borderColor='var(--border)'">
                                    <svg style="width:12px;height:12px;fill:none;stroke:rgba(250,248,242,.5);stroke-width:1.5;stroke-linecap:round" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                                <form method="post" asp-controller="Admin" asp-action="DeleteProduct" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productID" value="@p.ProductID">
                                    <button type="submit" onclick="return confirm('Xóa sản phẩm này?')"
                                        style="width:30px;height:30px;border:1px solid var(--border);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center"
                                        onmouseover="this.style.borderColor='#d47a76'" onmouseout="this.style.borderColor='var(--border)'">
                                        <svg style="width:12px;height:12px;fill:none;stroke:rgba(250,248,242,.5);stroke-width:1.5;stroke-linecap:round" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <!-- TAB MÃ GIẢM GIÁ -->
        <div id="discountsTab" style="display:none">
            <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px">
                <div><div class="page-title">Mã giảm giá</div></div>
                <button type="button" class="btn-add" onclick="document.getElementById('discMo').classList.add('open')">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Thêm mã
                </button>
            </div>
            <table style="width:100%;border-collapse:collapse;background:var(--dark2);border:1px solid var(--border)">
                <thead><tr>
                    <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.6);padding:12px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.15)">Mã code</th>
                    <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.6);padding:12px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.15)">Giảm giá</th>
                    <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.6);padding:12px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.15)">Số lượng</th>
                    <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.6);padding:12px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.15)">Hết hạn</th>
                    <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.6);padding:12px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.15)">Thao tác</th>
                </tr></thead>
                <tbody id="discBody">
                @foreach (var d in Db.Discounts.OrderByDescending(x => x.DiscountID))
                {
                    var isExp = d.ExpirationDate < DateTime.Now || d.UsedCount >= d.Quantity;
                    <tr>
                        <td style="padding:12px 16px;border-bottom:1px solid rgba(201,168,76,.05);font-size:12px;font-weight:200;color:rgba(250,248,242,.8)">
                            <span style="font-size:11px;letter-spacing:2px;color:var(--gold);background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);padding:3px 10px">@d.Code</span>
                        </td>
                        <td style="padding:12px 16px;border-bottom:1px solid rgba(201,168,76,.05);font-size:12px;font-weight:200;color:var(--gold)">
                            @(d.DiscountType == 1 ? $"{d.DiscountValue}%" : d.DiscountValue.ToString("N0") + "đ")
                        </td>
                        <td style="padding:12px 16px;border-bottom:1px solid rgba(201,168,76,.05);font-size:12px;font-weight:200;color:rgba(250,248,242,.8)">@d.UsedCount/@d.Quantity</td>
                        <td style="padding:12px 16px;border-bottom:1px solid rgba(201,168,76,.05);font-size:12px;font-weight:200">
                            <span style="color:@(isExp?"#d47a76":"rgba(250,248,242,.6)")">@d.ExpirationDate.ToString("dd/MM/yyyy")</span>
                        </td>
                        <td style="padding:12px 16px;border-bottom:1px solid rgba(201,168,76,.05)">
                            <form method="post" asp-controller="Admin" asp-action="DeleteDiscount">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="discountId" value="@d.DiscountID">
                                <button type="submit" onclick="return confirm('Xóa mã này?')"
                                    style="font-size:9px;letter-spacing:1.5px;color:#d47a76;border:1px solid rgba(212,122,116,.3);background:transparent;padding:4px 10px;cursor:pointer;font-family:var(--font-b)">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </main>
</div>

<!-- MODAL THÊM SẢN PHẨM = cùng form Nhập hàng (ImportStock), quay lại trang Sản phẩm sau khi lưu -->
<div id="importMo" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-hdr">Thêm sản phẩm <button type="button" class="modal-x" id="importClose">×</button></div>
        <form asp-controller="Admin" asp-action="ImportStock" method="post" enctype="multipart/form-data" id="importForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnPage" value="Products" />
            <input type="hidden" name="productId" id="impProductId" value="" />
            <input type="hidden" name="supplierId" id="impSupplierId" value="" />
            <div class="modal-grid">
                <label>Tên sản phẩm</label>
                <div>
                    <input type="text" name="productName" id="impProductName" class="modal-inp" list="prodSuggest" autocomplete="off" required />
                    <datalist id="prodSuggest"></datalist>
                </div>
                <label>Danh mục</label>
                <select name="categoryId" id="impCategoryId" class="modal-inp" required>
                    @if (categories == null || categories.Count == 0)
                    {
                        <option value="" disabled selected>Chưa có danh mục — thêm danh mục trước</option>
                    }
                    else
                    {
                        @foreach (var c in categories)
                        {
                            <option value="@c.CategoryID">@c.CategoryName</option>
                        }
                    }
                </select>
                <label>Mùa</label>
                <select name="session" id="impSession" class="modal-inp" required>
                    <option value="1">Xuân</option>
                    <option value="2">Hạ</option>
                    <option value="3">Thu</option>
                    <option value="4">Đông</option>
                </select>
                <label>Giá bán</label>
                <input type="number" step="0.01" name="salePrice" id="impSalePrice" class="modal-inp" required />
                <label>Giá gốc / vốn</label>
                <input type="number" step="0.01" name="originalPrice" id="impOriginalPrice" class="modal-inp" />
                <label>Số lượng</label>
                <input type="number" name="quantity" id="impQty" class="modal-inp" min="1" value="1" required />
                <label>Size</label>
                <input type="text" name="sizeName" id="impSize" class="modal-inp" maxlength="5" required />
                <label>Ảnh sản phẩm</label>
                <div class="dropzone" id="dropzone">
                    <input type="file" name="imageFile" id="impFile" accept="image/*" hidden />
                    <span>Kéo thả hoặc bấm để chọn</span>
                </div>
                <label>Nhà cung cấp</label>
                <div>
                    <input type="text" id="impSupplierName" class="modal-inp" list="supSuggest" autocomplete="off" placeholder="Gõ để tìm..." required />
                    <datalist id="supSuggest"></datalist>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="act-btn" id="importCancel">Hủy</button>
                <button type="submit" class="act-btn" style="border-color:var(--gold);color:var(--gold)">Lưu phiếu nhập</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL SỬA SẢN PHẨM -->
<div class="mo" id="editMo" onclick="if(event.target===this)this.classList.remove('open')" style="position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:300;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(8px)">
    <div style="background:var(--dark2);width:90%;max-width:580px;border:1px solid var(--border)">
        <div style="padding:17px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
            <div style="font-family:var(--font-d);font-size:20px;font-style:italic;color:var(--white)">Chỉnh sửa sản phẩm</div>
            <button onclick="document.getElementById('editMo').classList.remove('open')" style="width:28px;height:28px;border:1px solid var(--border);background:none;color:var(--white);cursor:pointer">✕</button>
        </div>
        <form method="post" asp-controller="Admin" asp-action="EditProduct" style="padding:22px">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productID" id="editId">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:13px">
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Tên sản phẩm</label>
                    <input name="productName" id="editName" required style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
                </div>
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Danh mục</label>
                    <select name="categoryID" id="editCat" style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
                        @if (categories == null || categories.Count == 0)
                        {
                            <option value="" disabled>Chưa có danh mục</option>
                        }
                        else
                        {
                            @foreach (var cat in categories) { <option value="@cat.CategoryID">@cat.CategoryName</option> }
                        }
                    </select>
                </div>
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Mùa</label>
                    <select name="session" id="editSeason" style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
                        <option value="1">Xuân</option><option value="2">Hạ</option><option value="3">Thu</option><option value="4">Đông</option>
                    </select>
                </div>
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Giá bán (đ)</label>
                    <input name="price" id="editPrice" type="number" required style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
                </div>

                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">URL ảnh</label>
                    <input name="imageUrl" id="editImg" style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:7px;margin-bottom:16px">
                <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Mô tả</label>
                <input name="description" id="editDesc" style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end">
                <button type="button" onclick="document.getElementById('editMo').classList.remove('open')" style="padding:10px 18px;background:transparent;color:rgba(250,248,242,.5);font-size:10px;letter-spacing:2px;text-transform:uppercase;border:1px solid var(--border);font-family:var(--font-b);cursor:pointer">Hủy</button>
                <button type="submit" style="padding:10px 22px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:10px;letter-spacing:2px;text-transform:uppercase;border:none;font-family:var(--font-b);cursor:pointer">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL THÊM MÃ GIẢM GIÁ -->
<div class="mo" id="discMo" onclick="if(event.target===this)this.classList.remove('open')" style="position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:300;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(8px)">
    <div style="background:var(--dark2);width:90%;max-width:520px;border:1px solid var(--border)">
        <div style="padding:17px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
            <div style="font-family:var(--font-d);font-size:20px;font-style:italic;color:var(--white)">Thêm mã giảm giá</div>
            <button onclick="document.getElementById('discMo').classList.remove('open')" style="width:28px;height:28px;border:1px solid var(--border);background:none;color:var(--white);cursor:pointer">✕</button>
        </div>
        <form method="post" asp-controller="Admin" asp-action="AddDiscount" style="padding:22px">
            @Html.AntiForgeryToken()
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:13px">
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Mã code</label>
                    <input name="code" required style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%;text-transform:uppercase" placeholder="VD: NEVA20">
                </div>
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Loại giảm</label>
                    <select name="discountType" style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
                        <option value="percent">Phần trăm (%)</option>
                        <option value="fixed">Số tiền cố định (đ)</option>
                    </select>
                </div>
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Giá trị giảm</label>
                    <input name="discountValue" type="number" required style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%" placeholder="VD: 20">
                </div>
                <div style="display:flex;flex-direction:column;gap:7px">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Số lượng</label>
                    <input name="quantity" type="number" required style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%" placeholder="100">
                </div>
                <div style="display:flex;flex-direction:column;gap:7px;grid-column:1/-1">
                    <label style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.8)">Ngày hết hạn</label>
                    <input name="expirationDate" type="date" required style="padding:10px 12px;border:1px solid var(--border);background:var(--dark);font-size:13px;font-family:var(--font-b);color:var(--white);outline:none;width:100%">
                </div>
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end">
                <button type="button" onclick="document.getElementById('discMo').classList.remove('open')" style="padding:10px 18px;background:transparent;color:rgba(250,248,242,.5);font-size:10px;letter-spacing:2px;text-transform:uppercase;border:1px solid var(--border);font-family:var(--font-b);cursor:pointer">Hủy</button>
                <button type="submit" style="padding:10px 22px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:10px;letter-spacing:2px;text-transform:uppercase;border:none;font-family:var(--font-b);cursor:pointer">Lưu mã</button>
            </div>
        </form>
    </div>
</div>

<script src="~/js/neva-base.js" asp-append-version="true"></script>
<script src="~/js/admin-import-modal.js" asp-append-version="true"></script>
<script>
function publishToFrontend() {
    const btn = document.getElementById('btnPublishAll');
    if (!btn) return;
    btn.disabled = true;
    btn.style.opacity = '0.6';
    fetch('/Admin/GetAllProducts', { credentials: 'same-origin' })
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.style.opacity = '1';
            const toast = document.getElementById('toast');
            if (data.success && toast) {
                toast.textContent = '✓ Đã đồng bộ ' + data.count + ' sản phẩm từ database — giao diện khách hàng dùng cùng nguồn DB.';
                toast.className = 'toast ok active';
                setTimeout(() => toast.classList.remove('active'), 4000);
            }
            window.location.href = '/Admin/Products';
        })
        .catch(() => {
            btn.disabled = false;
            btn.style.opacity = '1';
            window.location.reload();
        });
}
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.NevaAdminImportModal) {
        window.NevaAdminImportModal.init({ bindTopSellList: false, openEmptyButtonId: 'btnOpenAddProduct' });
    }
});
function openEditMo(id,name,cat,season,price,oldPrice,img,desc){
    document.getElementById('editId').value=id;
    document.getElementById('editName').value=name;
    document.getElementById('editCat').value=cat;
    document.getElementById('editSeason').value=season;
    document.getElementById('editPrice').value=price;
    document.getElementById('editImg').value=img||'';
    document.getElementById('editDesc').value=desc||'';
    const mo=document.getElementById('editMo');
    mo.style.opacity='1';mo.style.pointerEvents='all';
}
function switchTab(tab,btn){
    document.querySelectorAll('.atab').forEach(t=>t.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('productsTab').style.display=tab==='products'?'block':'none';
    document.getElementById('discountsTab').style.display=tab==='discounts'?'block':'none';
}
// Fix modal open
document.querySelectorAll('.mo').forEach(mo=>{
    const observer=new MutationObserver(()=>{
        if(mo.classList.contains('open')){mo.style.opacity='1';mo.style.pointerEvents='all';}
        else{mo.style.opacity='0';mo.style.pointerEvents='none';}
    });
    observer.observe(mo,{attributes:true,attributeFilter:['class']});
});
</script>
</body></html>
