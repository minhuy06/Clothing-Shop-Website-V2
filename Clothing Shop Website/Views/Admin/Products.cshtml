@model List<Clothing_Shop_Website.Models.Product>
@inject Clothing_Shop_Website.Data.AppDbContext Db
@{
    ViewData["Title"] = "Sản phẩm";
    Layout = null;
    var categories = ViewBag.Categories as List<Clothing_Shop_Website.Models.Category>;
    var receipts = ViewBag.Receipts as List<Clothing_Shop_Website.Models.InventoryReceipt> ?? new();
    var suppliers = ViewBag.Suppliers as List<Clothing_Shop_Website.Models.Supplier> ?? new();
    var totalInDb = (int)(ViewBag.TotalInDb ?? 0);
    var currentPage = (int)(ViewBag.Page ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 10);
    var totalFiltered = (int)(ViewBag.TotalFiltered ?? Model.Count);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var rowFrom = totalFiltered == 0 ? 0 : (currentPage - 1) * pageSize + 1;
    var rowTo = totalFiltered == 0 ? 0 : Math.Min(currentPage * pageSize, totalFiltered);
    var receiptPage = (int)(ViewBag.ReceiptPage ?? 1);
    var receiptPageSize = (int)(ViewBag.ReceiptPageSize ?? 10);
    var receiptTotal = (int)(ViewBag.ReceiptTotal ?? receipts.Count);
    var receiptTotalPages = (int)(ViewBag.ReceiptTotalPages ?? 1);

    string ProductsPageUrl(int p)
    {
        var parts = new List<string> { "page=" + p };
        if (!string.IsNullOrEmpty(ViewBag.Search as string))
            parts.Add("search=" + Uri.EscapeDataString((string)ViewBag.Search));
        if (ViewBag.CategoryId != null && !string.IsNullOrEmpty(ViewBag.CategoryId.ToString()))
            parts.Add("categoryId=" + ViewBag.CategoryId);
        if (!string.IsNullOrEmpty(ViewBag.Season as string))
            parts.Add("season=" + ViewBag.Season);
        if (receiptPage > 1)
            parts.Add("receiptPage=" + receiptPage);
        return "/Admin/Products?" + string.Join("&", parts);
    }
    string ReceiptsPageUrl(int p)
    {
        var parts = new List<string> { "page=" + currentPage, "receiptPage=" + p };
        if (!string.IsNullOrEmpty(ViewBag.Search as string))
            parts.Add("search=" + Uri.EscapeDataString((string)ViewBag.Search));
        if (ViewBag.CategoryId != null && !string.IsNullOrEmpty(ViewBag.CategoryId.ToString()))
            parts.Add("categoryId=" + ViewBag.CategoryId);
        if (!string.IsNullOrEmpty(ViewBag.Season as string))
            parts.Add("season=" + ViewBag.Season);
        return "/Admin/Products?" + string.Join("&", parts) + "#imports";
    }
    string GetSeason(int s) => s switch { 1=>"Xuân",2=>"Hạ",3=>"Thu",4=>"Đông",_=>"" };
    int SizeQty(Clothing_Shop_Website.Models.Product p, string sizeName)
    {
        var row = p.ProductSizes?.FirstOrDefault(x =>
            string.Equals(x.SizeName, sizeName, StringComparison.OrdinalIgnoreCase));
        return row?.StockQuantity ?? 0;
    }
    bool HasSize(Clothing_Shop_Website.Models.Product p, string sizeName) =>
        p.ProductSizes?.Any(x => string.Equals(x.SizeName, sizeName, StringComparison.OrdinalIgnoreCase)) == true;
    bool SizeIsLow(Clothing_Shop_Website.Models.Product p, string sizeName)
    {
        var row = p.ProductSizes?.FirstOrDefault(x =>
            string.Equals(x.SizeName, sizeName, StringComparison.OrdinalIgnoreCase));
        return row != null && row.StockQuantity <= row.MinimumStock;
    }
    int ReceiptSizeQty(Clothing_Shop_Website.Models.InventoryReceipt r, string sizeName)
    {
        return r.InventoryReceiptDetails?
            .Where(d => string.Equals(d.ProductSize?.SizeName, sizeName, StringComparison.OrdinalIgnoreCase))
            .Sum(d => d.Quantity) ?? 0;
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>NEVA Admin — Sản phẩm</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/neva-base.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-sanpham.css" asp-append-version="true"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
<style>
.ptable th.size-col, .ptable td.size-col { text-align: center; width: 44px; padding-left: 8px; padding-right: 8px; }
.ptable th.size-col { font-size: 11px; letter-spacing: 2px; color: var(--gold); }
.size-qty { font-size: 13px; font-weight: 300; color: #7aba7a; }
.size-qty.low { color: #d47a76; }
.size-qty.empty { color: rgba(250,248,242,.2); font-size: 11px; }
.pagination a.pp { text-decoration: none; }
.status-badge { font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; padding: 3px 8px; border: 1px solid; white-space: nowrap; }
.status-badge.off { color: rgba(250,248,242,.4); border-color: rgba(250,248,242,.2); }
.status-badge.on { color: #7aba7a; border-color: rgba(90,154,90,.4); background: rgba(90,154,90,.08); }
.imp-total-row { grid-column: 1 / -1; display: flex; justify-content: space-between; align-items: center; padding: 12px 14px; margin-top: 4px; background: rgba(201,168,76,.06); border: 1px solid rgba(201,168,76,.2); }
.imp-total-row span:last-child { font-size: 18px; font-weight: 300; color: var(--gold); }
.imp-line-row { border: 1px solid rgba(201,168,76,.15); padding: 12px; margin-bottom: 10px; background: rgba(0,0,0,.12); }
.imp-line-head { display: flex; gap: 8px; align-items: center; margin-bottom: 10px; }
.imp-line-head select { flex: 1; }
.imp-line-grid { display: grid; grid-template-columns: 1.2fr repeat(3, 1fr); gap: 8px; }
.imp-line-lbl { display: block; font-size: 9px; letter-spacing: 1px; color: rgba(201,168,76,.75); margin-bottom: 4px; text-transform: uppercase; }
.rv-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; margin-bottom: 16px; font-size: 12px; }
.rv-meta span { display: block; font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(201,168,76,.65); margin-bottom: 4px; }
.sup-table { width: 100%; margin-top: 24px; border-collapse: collapse; background: var(--dark2); border: 1px solid var(--border); }
.sup-table th, .sup-table td { padding: 10px 14px; border-bottom: 1px solid rgba(201,168,76,.06); font-size: 12px; }
.sup-table th { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(201,168,76,.6); font-weight: 300; background: rgba(0,0,0,.15); text-align: left; }
</style>
</head>
<body>
<div class="toast" id="toast"></div>
<nav class="admin-nav">
    <span class="admin-nav-logo">NEVA</span><span class="admin-nav-sep">|</span><span class="admin-nav-badge">Admin</span>
</nav>
<div class="admin-wrap">
    <aside class="admin-sidebar">
        <div class="sb-section">
            <div class="sb-lbl">Quản lý</div>
            <a asp-controller="Admin" asp-action="Dashboard" class="sitem"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
            <a asp-controller="Admin" asp-action="Products"  class="sitem active"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Sản phẩm</a>
            <a asp-controller="Admin" asp-action="Staff" class="sitem"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Nhân viên</a>
            <a asp-controller="Admin" asp-action="Advertisements" class="sitem"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Quảng cáo</a>
        </div>
        <div class="sb-section" style="margin-top:12px">
            <a asp-controller="Account" asp-action="Logout" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Đăng xuất</a>
        </div>
    </aside>
    <main class="admin-main">
        @if (TempData["Success"] != null) {
            <div style="padding:10px 16px;background:rgba(90,154,90,.1);border:1px solid rgba(90,154,90,.3);color:#7aba7a;font-size:11px;margin-bottom:16px">✦ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null) {
            <div style="padding:10px 16px;background:rgba(180,80,80,.12);border:1px solid rgba(212,122,116,.35);color:#d4a8a4;font-size:11px;margin-bottom:16px">@TempData["Error"]</div>
        }

        <!-- TABS -->
        <div class="admin-tabs">
            <button class="atab active" onclick="switchTab('products',this)">Sản phẩm</button>
            <button class="atab" onclick="switchTab('imports',this)">Nhập hàng</button>
            <button class="atab" onclick="switchTab('discounts',this)">Mã giảm giá</button>
        </div>

        <!-- TAB SẢN PHẨM -->
        <div id="productsTab">
            <div class="top-bar" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px">
                <div>
                    <div class="page-title">Sản phẩm</div>
                </div>
                <div style="display:flex;gap:8px;align-items:center">
                    <button type="button" class="btn-add" id="btnOpenImportReceipt" style="background:transparent;border:1px solid rgba(201,168,76,.45);color:var(--gold)">
                        <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                        Thêm phiếu nhập
                    </button>
                    <button type="button" class="btn-add" id="btnOpenAddProduct">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Thêm sản phẩm
                    </button>
                </div>
            </div>
            <!-- Filter -->
            <form method="get" asp-controller="Admin" asp-action="Products" style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap">
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Tìm sản phẩm..."
                    style="padding:9px 13px;border:1px solid var(--border);background:var(--dark2);font-size:12px;font-family:var(--font-b);color:var(--white);outline:none;flex:1;max-width:280px">
                <select name="categoryId" style="padding:9px 13px;border:1px solid var(--border);background:var(--dark2);font-size:12px;font-family:var(--font-b);color:var(--white);outline:none">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var cat in categories!)
                    {
                        @if (ViewBag.CategoryId?.ToString() == cat.CategoryID.ToString())
                        { <option value="@cat.CategoryID" selected>@cat.CategoryName</option> }
                        else
                        { <option value="@cat.CategoryID">@cat.CategoryName</option> }
                    }
                </select>
                <select name="season" style="padding:9px 13px;border:1px solid var(--border);background:var(--dark2);font-size:12px;font-family:var(--font-b);color:var(--white);outline:none">
                    <option value="">Tất cả mùa</option>
                    @foreach (var (num,name) in new[]{(1,"Xuân"),(2,"Hạ"),(3,"Thu"),(4,"Đông")})
                    {
                        @if (ViewBag.Season == num.ToString())
                        { <option value="@num" selected>@name</option> }
                        else
                        { <option value="@num">@name</option> }
                    }
                </select>
                <button type="submit" style="padding:9px 18px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:10px;letter-spacing:2px;text-transform:uppercase;border:none;font-family:var(--font-b)">Lọc</button>
                <a asp-controller="Admin" asp-action="Products" style="padding:9px 16px;border:1px solid var(--border);color:rgba(250,248,242,.5);font-size:10px;letter-spacing:2px;text-transform:uppercase;font-family:var(--font-b);text-decoration:none">Xóa lọc</a>
            </form>

            <table class="ptable" style="width:100%;border-collapse:collapse;background:var(--dark2);border:1px solid var(--border)">
                <thead><tr>
                    <th>Mã</th><th>Sản phẩm</th><th>Danh mục</th><th>Mùa</th>
                    <th class="size-col">S</th><th class="size-col">M</th><th class="size-col">L</th>
                    <th>Giá</th><th>Trạng thái</th><th>Thao tác</th>
                </tr></thead>
                <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="10" style="text-align:center;padding:28px;color:rgba(250,248,242,.35);font-size:11px;letter-spacing:1px">
                            @if (totalInDb == 0)
                            {
                                <span>Chưa có dữ liệu. Chạy file <strong style="color:var(--gold)">DataWarehouse_Scripts/Seed_Realistic_Data.sql</strong> trong SSMS hoặc sqlcmd (-f 65001).</span>
                            }
                            else
                            {
                                <span>Không có sản phẩm khớp bộ lọc. <a asp-controller="Admin" asp-action="Products" style="color:var(--gold)">Xóa lọc</a></span>
                            }
                        </td>
                    </tr>
                }
                @foreach (var p in Model)
                {
                    <tr>
                        <td style="font-size:11px;color:rgba(201,168,76,.7);white-space:nowrap">#@p.ProductID.ToString("D3")</td>
                        <td>
                            <div style="display:flex;gap:10px;align-items:center">
                                <div style="width:44px;height:55px;overflow:hidden;flex-shrink:0"><img src="@p.ImageUrl" style="width:100%;height:100%;object-fit:cover;filter:brightness(.82)" onerror="this.style.display='none'"></div>
                                <div>
                                    <div style="font-family:'EB Garamond',serif;font-size:14px;font-style:italic;color:var(--white);margin-bottom:2px">@p.ProductName</div>
                                    @if (!string.IsNullOrEmpty(p.Description))
                                    {
                                        <div style="font-size:10px;color:rgba(250,248,242,.35);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@p.Description</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>@p.Category?.CategoryName</td>
                        <td>@GetSeason(p.Session)</td>
                        @foreach (var sz in new[] { "S", "M", "L" })
                        {
                            var qty = SizeQty(p, sz);
                            var has = HasSize(p, sz);
                            var low = SizeIsLow(p, sz);
                            <td class="size-col">
                                @if (has)
                                {
                                    <span class="size-qty @(low ? "low" : "")">@qty</span>
                                }
                                else
                                {
                                    <span class="size-qty empty">—</span>
                                }
                            </td>
                        }
                        <td style="white-space:nowrap">@p.Price.ToString("N0") ₫</td>
                        <td>
                            <span class="status-badge @(p.Status == 1 ? "on" : "off")">@(p.Status == 1 ? "Đã hiển thị" : "Chưa hiển thị")</span>
                        </td>
                        <td>
                            <div class="act-row">
                                <button type="button" class="btn-edit-product ia-btn" data-id="@p.ProductID" title="Sửa thông tin">
                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                                <button type="button" class="btn-publish-row ia-btn publish" data-id="@p.ProductID" data-name="@p.ProductName" data-status="@p.Status" title="@(p.Status == 1 ? "Ẩn khỏi giao diện" : "Hiển thị lên giao diện")">
                                    <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                                </button>
                                @if (p.Status != 1)
                                {
                                <form method="post" asp-controller="Admin" asp-action="DeleteProduct" class="btn-del-product-form" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productID" value="@p.ProductID">
                                    <button type="submit" class="ia-btn del" title="Xóa" onclick="return confirm('Xóa sản phẩm này?')">
                                        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
                                    </button>
                                </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    @if (currentPage > 1)
                    {
                        <a class="pp" href="@ProductsPageUrl(currentPage - 1)" title="Trang trước">‹</a>
                    }
                    @for (var i = 1; i <= totalPages; i++)
                    {
                        <a class="pp @(i == currentPage ? "on" : "")" href="@ProductsPageUrl(i)">@i</a>
                    }
                    @if (currentPage < totalPages)
                    {
                        <a class="pp" href="@ProductsPageUrl(currentPage + 1)" title="Trang sau">›</a>
                    }
                </div>
            }
        </div>

        <!-- TAB NHẬP HÀNG -->
        <div id="importsTab" style="display:none">
            <div class="top-bar" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px">
                <div class="page-title">Phiếu nhập hàng</div>
                <button type="button" class="btn-add" id="btnOpenAddSupplier">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Thêm nhà cung cấp
                </button>
            </div>
            <table class="ptable">
                <thead><tr>
                    <th>Số phiếu</th><th>Ngày nhập</th><th>Nhà cung cấp</th><th>Sản phẩm</th>
                    <th class="size-col">S</th><th class="size-col">M</th><th class="size-col">L</th>
                    <th>Tổng tiền</th><th>Thao tác</th>
                </tr></thead>
                <tbody>
                @if (receipts.Count == 0)
                {
                    <tr><td colspan="9" style="text-align:center;padding:28px;color:rgba(250,248,242,.35);font-size:11px">Chưa có phiếu nhập hàng.</td></tr>
                }
                @foreach (var r in receipts)
                {
                    var details = r.InventoryReceiptDetails?.ToList() ?? new List<Clothing_Shop_Website.Models.InventoryReceiptDetail>();
                    var totalAmt = details.Sum(d => d.Quantity * d.ImportPrice);
                    var productNames = details
                        .Select(d => d.ProductSize?.Product?.ProductName)
                        .Where(n => !string.IsNullOrEmpty(n))
                        .Distinct()
                        .ToList();
                    var pname = productNames.Count == 0 ? "—" : (productNames.Count == 1 ? productNames[0] : productNames[0] + " +" + (productNames.Count - 1));
                    <tr>
                        <td style="color:rgba(201,168,76,.75);white-space:nowrap">#@r.ReceiptID.ToString("D6")</td>
                        <td>@r.ImportDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@r.Supplier?.SupplierName</td>
                        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@string.Join(", ", productNames)">@pname</td>
                        @foreach (var sz in new[] { "S", "M", "L" })
                        {
                            var rq = ReceiptSizeQty(r, sz);
                            <td class="size-col"><span class="size-qty @(rq == 0 ? "empty" : "")">@(rq == 0 ? "—" : rq.ToString())</span></td>
                        }
                        <td style="color:var(--gold);white-space:nowrap">@totalAmt.ToString("N0") ₫</td>
                        <td>
                            <div class="act-row">
                                <button type="button" class="ia-btn btn-view-receipt" data-id="@r.ReceiptID" title="Xem phiếu">
                                    <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                                <a href="/Admin/ExportReceipt?receiptId=@r.ReceiptID" class="ia-btn" title="Xuất xlsx" style="text-decoration:none;color:var(--gold)">
                                    <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                </a>
                                <button type="button" class="ia-btn del btn-del-receipt" data-id="@r.ReceiptID" title="Xóa phiếu">
                                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            @if (receiptTotalPages > 1)
            {
                <div class="pagination">
                    @if (receiptPage > 1)
                    {
                        <a class="pp" href="@ReceiptsPageUrl(receiptPage - 1)" title="Trang trước">‹</a>
                    }
                    @for (var i = 1; i <= receiptTotalPages; i++)
                    {
                        <a class="pp @(i == receiptPage ? "on" : "")" href="@ReceiptsPageUrl(i)">@i</a>
                    }
                    @if (receiptPage < receiptTotalPages)
                    {
                        <a class="pp" href="@ReceiptsPageUrl(receiptPage + 1)" title="Trang sau">›</a>
                    }
                </div>
            }
            <table class="sup-table">
                <thead><tr>
                    <th>Tên nhà cung cấp</th><th>SĐT</th><th>Thành phố</th><th>Quốc gia</th><th>Thao tác</th>
                </tr></thead>
                <tbody>
                @if (suppliers.Count == 0)
                {
                    <tr><td colspan="5" style="text-align:center;padding:20px;color:rgba(250,248,242,.35);font-size:11px">Chưa có nhà cung cấp.</td></tr>
                }
                @foreach (var s in suppliers)
                {
                    <tr>
                        <td>@s.SupplierName</td>
                        <td>@(s.Phone ?? "-")</td>
                        <td>@(s.City ?? "-")</td>
