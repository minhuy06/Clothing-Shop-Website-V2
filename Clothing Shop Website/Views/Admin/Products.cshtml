@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEVA Admin — Sản phẩm</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--gold:#c9a84c;--gold2:#e8c96a;--black:#050402;--dark:#0c0a07;--dark2:#14100a;--white:#faf8f2;--border:rgba(201,168,76,0.18);--font-d:'Playfair Display',serif;--font-b:'Josefin Sans',sans-serif;--font-a:'EB Garamond',serif;--nav-h:52px;--side-w:220px}
body{font-family:var(--font-b);background:var(--black);color:var(--white);min-height:100vh;display:flex;flex-direction:column}
a{text-decoration:none;color:inherit}
img{display:block;width:100%;height:100%;object-fit:cover}
nav{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 44px;height:var(--nav-h);background:rgba(5,4,2,.97);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;flex-shrink:0}
.nav-logo{font-family:var(--font-d);font-size:18px;letter-spacing:8px;justify-self:start;display:flex;align-items:center;gap:12px}
.nav-logo a{font-family:var(--font-d);font-size:18px;letter-spacing:8px;color:var(--white)}
.nav-logo-sep{color:rgba(250,248,242,.2);font-size:16px;font-weight:200}
.nav-badge{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.6);border:1px solid rgba(201,168,76,.25);padding:2px 10px}
.nav-mid{display:flex;align-items:center;justify-content:center}
.nl{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(250,248,242,.7);padding:0 14px;transition:color .2s}
.nl:hover{color:var(--white)}
.nd{color:rgba(250,248,242,.14);font-size:10px}
.nav-right{display:flex;gap:14px;justify-self:end;align-items:center}
.ni{color:rgba(250,248,242,.55);transition:color .2s;display:flex;align-items:center}
.ni:hover{color:var(--gold)}
.ni svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.admin-wrap{display:flex;flex:1}
.admin-sidebar{width:var(--side-w);flex-shrink:0;background:var(--dark);border-right:1px solid var(--border);padding:20px 0;position:sticky;top:var(--nav-h);height:calc(100vh - var(--nav-h));overflow-y:auto}
.sb-section{margin-bottom:6px;padding:0 14px}
.sb-lbl{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.32);margin-bottom:6px;padding:0 6px}
.sitem{display:flex;align-items:center;gap:11px;padding:11px 12px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(250,248,242,.42);transition:all .2s;position:relative;border-left:2px solid transparent}
.sitem:hover{background:rgba(201,168,76,.04);color:rgba(250,248,242,.8);border-left-color:rgba(201,168,76,.3)}
.sitem.active{color:var(--gold);background:rgba(201,168,76,.06);border-left-color:var(--gold)}
.sitem svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:1.4;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;opacity:.7}
.sitem.active svg{opacity:1}
.sitem-badge{margin-left:auto;background:var(--gold);color:var(--black);font-size:8px;padding:1px 6px}
.sitem.danger{color:rgba(212,122,118,.5)}
.sitem.danger:hover{color:#d47a76;background:rgba(212,122,118,.04)}
.admin-main{flex:1;padding:26px 30px;overflow-y:auto}
.top-bar{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px}
.page-title{font-family:var(--font-d);font-size:34px;font-weight:400;font-style:italic}
.page-sub{font-size:10px;letter-spacing:2px;color:rgba(250,248,242,.3);margin-top:4px}
.btn-add{padding:10px 22px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:9px;letter-spacing:2.5px;text-transform:uppercase;border:none;font-family:var(--font-b);transition:opacity .2s;display:flex;align-items:center;gap:8px}
.btn-add:hover{opacity:.85}
.btn-add svg{width:13px;height:13px;fill:none;stroke:var(--black);stroke-width:2;stroke-linecap:round}
.toolbar{display:flex;gap:10px;align-items:center;margin-bottom:16px;flex-wrap:wrap}
.search-box{display:flex;align-items:center;border:1px solid var(--border);background:var(--dark2);flex:1;min-width:200px;max-width:300px}
.search-box input{background:transparent;border:none;outline:none;padding:9px 13px;font-size:11px;letter-spacing:1px;font-family:var(--font-b);color:var(--white);width:100%}
.search-box input::placeholder{color:rgba(250,248,242,.2)}
.search-box svg{width:13px;height:13px;fill:none;stroke:rgba(250,248,242,.3);stroke-width:1.5;stroke-linecap:round;margin-right:10px}
.fsel{padding:9px 13px;border:1px solid var(--border);background:var(--dark2);font-size:10px;letter-spacing:1px;font-family:var(--font-b);color:var(--white);outline:none}
.fsel:focus{border-color:var(--gold)}
.result-info{font-size:10px;letter-spacing:1.5px;color:rgba(250,248,242,.28);margin-left:auto}
.result-info strong{color:var(--gold)}
.ptable{width:100%;border-collapse:collapse;background:var(--dark2);border:1px solid var(--border)}
.ptable::before{content:'';display:block}
.ptable th{font-size:8px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(201,168,76,.38);padding:12px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.15)}
.ptable td{padding:12px 16px;border-bottom:1px solid rgba(201,168,76,.05);font-size:11px;font-weight:200;letter-spacing:.5px;vertical-align:middle}
.ptable tr:last-child td{border-bottom:none}
.ptable tr:hover td{background:rgba(201,168,76,.02)}
.prow-thumb{width:44px;height:55px;flex-shrink:0;overflow:hidden}
.prow-thumb img{filter:brightness(.82)}
.prow-info{display:flex;align-items:center;gap:12px}
.prow-name{font-family:var(--font-a);font-size:13px;font-style:italic;margin-bottom:2px}
.prow-cat{font-size:9px;letter-spacing:1.5px;color:rgba(201,168,76,.5)}
.badge-new{font-size:7px;letter-spacing:2px;padding:2px 7px;background:var(--gold);color:var(--black)}
.badge-sale{font-size:7px;letter-spacing:2px;padding:2px 7px;border:1px solid rgba(201,168,76,.4);color:var(--gold)}
.act-row{display:flex;gap:6px}
.ia-btn{width:30px;height:30px;border:1px solid var(--border);background:transparent;display:flex;align-items:center;justify-content:center;transition:all .2s}
.ia-btn:hover{border-color:var(--gold)}
.ia-btn svg{width:12px;height:12px;fill:none;stroke:rgba(250,248,242,.4);stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s}
.ia-btn:hover svg{stroke:var(--gold)}
.ia-btn.del:hover{border-color:#d47a76}
.ia-btn.del:hover svg{stroke:#d47a76}
.pstock{font-size:11px;font-weight:200}
.pstock.low{color:#d47a76}
.pstock.ok{color:#7aba7a}
/* Pagination */
.pagination{display:flex;justify-content:flex-end;gap:3px;margin-top:16px}
.pp{width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:10px;border:1px solid var(--border);background:transparent;color:rgba(250,248,242,.32);transition:all .2s;font-family:var(--font-b)}
.pp:hover,.pp.on{background:var(--gold);color:var(--black);border-color:var(--gold)}
/* Modal */
.toast{position:fixed;bottom:28px;right:28px;z-index:9000;padding:11px 20px;font-size:10px;letter-spacing:1.5px;border:1px solid;display:none}
.toast.ok{background:rgba(90,154,90,.12);border-color:rgba(90,154,90,.4);color:#7aba7a}
.toast.info{background:rgba(201,168,76,.08);border-color:rgba(201,168,76,.28);color:var(--gold)}
.toast.err{background:rgba(201,80,76,.08);border-color:rgba(201,80,76,.3);color:#d47a76}
.mo{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:300;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(8px)}
.mo.open{opacity:1;pointer-events:all}
.modal{background:var(--dark2);width:90%;max-width:580px;border:1px solid var(--border);transform:translateY(14px);transition:transform .3s cubic-bezier(.16,1,.3,1)}
.mo.open .modal{transform:translateY(0)}
.mhdr{padding:17px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.mhdr-t{font-family:var(--font-d);font-size:20px;font-style:italic}
.mclose{width:28px;height:28px;border:1px solid var(--border);background:none;color:var(--white);display:flex;align-items:center;justify-content:center;transition:border-color .2s}
.mclose:hover{border-color:var(--gold)}
.mclose svg{width:11px;height:11px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round}
.mbody{padding:20px 22px;max-height:70vh;overflow-y:auto}
.mbody::-webkit-scrollbar{width:2px}.mbody::-webkit-scrollbar-thumb{background:var(--border)}
.mfoot{padding:13px 22px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.frow.full{grid-template-columns:1fr}
.fgroup{display:flex;flex-direction:column;gap:6px}
.flabel{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.5)}
.finput,.fselect{padding:9px 11px;border:1px solid var(--border);background:rgba(201,168,76,.03);font-size:12px;font-family:var(--font-b);font-weight:200;color:var(--white);outline:none;transition:border-color .2s;width:100%}
.finput:focus,.fselect:focus{border-color:var(--gold)}
.finput::placeholder{color:rgba(250,248,242,.18)}
.btn-gold{padding:9px 20px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:8px;letter-spacing:2px;text-transform:uppercase;border:none;font-family:var(--font-b);transition:opacity .2s}.btn-gold:hover{opacity:.85}
.btn-outline{padding:9px 16px;background:transparent;color:rgba(250,248,242,.38);font-size:8px;letter-spacing:2px;text-transform:uppercase;border:1px solid var(--border);font-family:var(--font-b);transition:all .2s}.btn-outline:hover{border-color:var(--gold);color:var(--gold)}
</style>
</head>
<body>
<div class="toast" id="toast"></div>
<nav>
  <div class="nav-logo"><a href="/">NEVA</a><span class="nav-logo-sep">|</span><span class="nav-badge">Admin</span></div>
  <div class="nav-mid"><a href="/Product" class="nl">Cửa hàng</a><span class="nd">|</span><a href="/Account/Profile" class="nl">Tài khoản</a></div>
  <div class="nav-right">
    <a href="/Account/Profile" class="ni"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></a>
    <a href="/Cart" class="ni"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></a>
  </div>
</nav>
<div class="admin-wrap">
  <aside class="admin-sidebar">
    <div class="sb-section">
      <div class="sb-lbl">Tổng quan</div>
      <a href="/Admin/Dashboard" class="sitem"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
    </div>
    <div class="sb-section">
      <div class="sb-lbl">Quản lý</div>
      <a href="/Admin/Products" class="sitem active"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Sản phẩm</a>
      <a href="/Admin/Orders" class="sitem"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>Đơn hàng<span class="sitem-badge">4</span></a>
      <a href="#" class="sitem"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>Khách hàng</a>
    </div>
    <div class="sb-section">
      <div class="sb-lbl">Hệ thống</div>
      <a href="/" class="sitem"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>Trang chủ</a>
      <a href="/Account/Login" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Đăng xuất</a>
    </div>
  </aside>
  <main class="admin-main">
    <div class="top-bar">
      <div><div class="page-title">Sản phẩm</div><div class="page-sub">Quản lý toàn bộ sản phẩm</div></div>
      <button class="btn-add" onclick="openModal(-1)"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Thêm sản phẩm</button>
    </div>
    <div class="toolbar">
      <div class="search-box"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg><input type="text" placeholder="Tìm sản phẩm..." id="searchInput" oninput="renderTable()"></div>
      <select class="fsel" id="catFilter" onchange="renderTable()">
        <option value="">Tất cả danh mục</option>
        <option>Đầm</option><option>Áo blouse</option><option>Áo khoác</option><option>Quần</option><option>Bộ suit</option>
      </select>
      <select class="fsel" id="seasonFilter" onchange="renderTable()">
        <option value="">Tất cả mùa</option>
        <option>Xuân</option><option>Hè</option><option>Thu</option><option>Đông</option>
      </select>
      <div class="result-info">Hiển thị <strong id="countDisplay">0</strong> sản phẩm</div>
    </div>
    <table class="ptable" id="pTable">
      <thead><tr><th style="width:44px"></th><th>Sản phẩm</th><th>Danh mục</th><th>Mùa</th><th>Giá</th><th>Tồn kho</th><th>Trạng thái</th><th style="width:100px">Thao tác</th></tr></thead>
      <tbody id="tbody"></tbody>
    </table>
    <div class="pagination"><div class="pp on">1</div><div class="pp">2</div><div class="pp">3</div><div class="pp">›</div></div>
  </main>
</div>

<!-- MODAL THÊM/SỬA -->
<div class="mo" id="mo" onclick="if(event.target===this)closeMo()">
  <div class="modal">
    <div class="mhdr"><div class="mhdr-t" id="moTitle">Thêm sản phẩm</div><button class="mclose" onclick="closeMo()"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="mbody">
      <div class="frow full"><div class="fgroup"><label class="flabel">Tên sản phẩm</label><input class="finput" id="fName" placeholder="VD: Đầm dạ hội ren thêu"></div></div>
      <div class="frow">
        <div class="fgroup"><label class="flabel">Danh mục</label><select class="fselect" id="fCat"><option>Đầm</option><option>Áo blouse</option><option>Áo khoác</option><option>Quần</option><option>Bộ suit</option></select></div>
        <div class="fgroup"><label class="flabel">Mùa</label><select class="fselect" id="fSeason"><option>Xuân</option><option>Hè</option><option>Thu</option><option>Đông</option></select></div>
      </div>
      <div class="frow">
        <div class="fgroup"><label class="flabel">Giá bán (đ)</label><input class="finput" id="fPrice" type="number" placeholder="1350000"></div>
        <div class="fgroup"><label class="flabel">Giá gốc (đ, nếu có)</label><input class="finput" id="fOldPrice" type="number" placeholder="0"></div>
      </div>
      <div class="frow">
        <div class="fgroup"><label class="flabel">Tồn kho</label><input class="finput" id="fStock" type="number" placeholder="50"></div>
        <div class="fgroup"><label class="flabel">Trạng thái</label><select class="fselect" id="fBadge"><option value="">Bình thường</option><option value="new">Mới</option><option value="sale">Sale</option></select></div>
      </div>
      <div class="frow full"><div class="fgroup"><label class="flabel">URL ảnh</label><input class="finput" id="fImg" placeholder="https://images.unsplash.com/..."></div></div>
      <div class="frow full"><div class="fgroup"><label class="flabel">Mô tả</label><input class="finput" id="fDesc" placeholder="Mô tả ngắn về sản phẩm..."></div></div>
    </div>
    <div class="mfoot"><button class="btn-outline" onclick="closeMo()">Hủy</button><button class="btn-gold" onclick="saveProd()">Lưu sản phẩm</button></div>
  </div>
</div>

<script>
function toast(m,t='ok'){const el=document.getElementById('toast');el.textContent=m;el.className='toast '+t;el.style.display='block';setTimeout(()=>el.style.display='none',2500)}
let products=[
  {id:1,name:'Đầm dạ hội ren thêu',cat:'Đầm',season:'Đông',price:3850000,old:0,stock:12,badge:'new',img:'https://images.unsplash.com/photo-1601924994987-69e26d50dc26?w=100&q=80',desc:'Đầm dạ hội thêu ren tinh xảo.'},
  {id:2,name:'Váy midi dáng A-line',cat:'Đầm',season:'Xuân',price:1650000,old:0,stock:24,badge:'',img:'https://images.unsplash.com/photo-1515372039744-b8f02a3ae446?w=100&q=80',desc:'Váy midi dáng A-line thanh lịch.'},
  {id:3,name:'Áo khoác blazer linen',cat:'Áo khoác',season:'Thu',price:2250000,old:2800000,stock:8,badge:'sale',img:'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?w=100&q=80',desc:'Blazer linen cao cấp.'},
  {id:4,name:'Áo blouse lụa cổ V',cat:'Áo blouse',season:'Hè',price:980000,old:0,stock:31,badge:'new',img:'https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?w=100&q=80',desc:'Áo blouse lụa mềm mại.'},
  {id:5,name:'Quần wide-leg linen',cat:'Quần',season:'Hè',price:1350000,old:0,stock:19,badge:'',img:'https://images.unsplash.com/photo-1506629082955-511b1aa562c8?w=100&q=80',desc:'Quần ống rộng chất linen.'},
  {id:6,name:'Đầm xẻ tà tối giản',cat:'Đầm',season:'Thu',price:2100000,old:2600000,stock:5,badge:'sale',img:'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=100&q=80',desc:'Đầm xẻ tà dáng maxi.'},
  {id:7,name:'Áo khoác dạ tweed',cat:'Áo khoác',season:'Đông',price:3200000,old:0,stock:3,badge:'new',img:'https://images.unsplash.com/photo-1548624313-0396c75e4b1a?w=100&q=80',desc:'Áo khoác dạ tweed cao cấp.'},
  {id:8,name:'Bộ suit vest nữ tính',cat:'Bộ suit',season:'Thu',price:4500000,old:0,stock:7,badge:'',img:'https://images.unsplash.com/photo-1632149877166-f75d49000351?w=100&q=80',desc:'Bộ suit vest nữ tính.'},
];
let editId=-1;
function fmt(n){return n.toLocaleString('vi-VN')+'đ'}
function renderTable(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  const cat=document.getElementById('catFilter').value;
  const season=document.getElementById('seasonFilter').value;
  let list=products.filter(p=>{
    if(q&&!p.name.toLowerCase().includes(q)&&!p.cat.toLowerCase().includes(q)) return false;
    if(cat&&p.cat!==cat) return false;
    if(season&&p.season!==season) return false;
    return true;
  });
  document.getElementById('countDisplay').textContent=list.length;
  document.getElementById('tbody').innerHTML=list.map(p=>`
    <tr>
      <td><div class="prow-thumb"><img src="${p.img}" alt="" loading="lazy" onerror="this.style.display='none'"></div></td>
      <td><div class="prow-info"><div><div class="prow-name">${p.name}</div><div class="prow-cat">${p.desc.substring(0,40)}...</div></div>${p.badge==='new'?'<span class="badge-new">Mới</span>':p.badge==='sale'?'<span class="badge-sale">Sale</span>':''}</div></td>
      <td>${p.cat}</td>
      <td>${p.season}</td>
      <td style="white-space:nowrap">${fmt(p.price)}${p.old?`<br><span style="font-size:10px;color:rgba(250,248,242,.25);text-decoration:line-through">${fmt(p.old)}</span>`:''}</td>
      <td><span class="pstock ${p.stock<=5?'low':'ok'}">${p.stock} cái</span></td>
      <td><span style="font-size:9px;letter-spacing:1px;color:rgba(250,248,242,.35)">${p.stock>0?'Còn hàng':'Hết hàng'}</span></td>
      <td><div class="act-row">
        <button class="ia-btn" onclick="openModal(${p.id})" title="Chỉnh sửa"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
        <button class="ia-btn del" onclick="delProd(${p.id})" title="Xóa"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg></button>
      </div></td>
    </tr>`).join('');
}
function openModal(id){
  editId=id;
  document.getElementById('moTitle').textContent=id===-1?'Thêm sản phẩm mới':'Chỉnh sửa sản phẩm';
  if(id!==-1){const p=products.find(x=>x.id===id);document.getElementById('fName').value=p.name;document.getElementById('fCat').value=p.cat;document.getElementById('fSeason').value=p.season;document.getElementById('fPrice').value=p.price;document.getElementById('fOldPrice').value=p.old;document.getElementById('fStock').value=p.stock;document.getElementById('fBadge').value=p.badge;document.getElementById('fImg').value=p.img;document.getElementById('fDesc').value=p.desc}
  else{['fName','fPrice','fOldPrice','fStock','fImg','fDesc'].forEach(i=>document.getElementById(i).value='')}
  document.getElementById('mo').classList.add('open');
}
function closeMo(){document.getElementById('mo').classList.remove('open')}
function saveProd(){
  const name=document.getElementById('fName').value.trim();
  if(!name){toast('Vui lòng nhập tên sản phẩm!','err');return}
  const p={name,cat:document.getElementById('fCat').value,season:document.getElementById('fSeason').value,price:parseInt(document.getElementById('fPrice').value)||0,old:parseInt(document.getElementById('fOldPrice').value)||0,stock:parseInt(document.getElementById('fStock').value)||0,badge:document.getElementById('fBadge').value,img:document.getElementById('fImg').value,desc:document.getElementById('fDesc').value};
  if(editId===-1){p.id=Date.now();products.push(p);toast('✦ Đã thêm sản phẩm!','info')}
  else{const i=products.findIndex(x=>x.id===editId);products[i]={...products[i],...p};toast('✦ Đã cập nhật sản phẩm!','info')}
  closeMo();renderTable();
}
function delProd(id){if(!confirm('Xóa sản phẩm này?'))return;products=products.filter(x=>x.id!==id);renderTable();toast('Đã xóa sản phẩm.')}
renderTable();
</script>
</body>
</html>