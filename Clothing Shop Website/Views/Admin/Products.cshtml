<script>
function showToast(msg, type) {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.className = 'toast ' + (type || 'ok') + ' active';
    setTimeout(() => toast.classList.remove('active'), 4000);
}
window.showToast = showToast;

let pendingPublish = { id: null, btn: null, name: '', status: 0 };

function openPublishConfirm(productId, btn) {
    const status = parseInt(btn?.getAttribute('data-status') || '0', 10);
    pendingPublish = {
        id: productId,
        btn: btn,
        name: btn?.getAttribute('data-name') || ('#' + String(productId).padStart(3, '0')),
        status: status
    };
    const isOn = status === 1;
    document.getElementById('publishConfirmTitle').textContent = isOn ? 'Ẩn khỏi giao diện' : 'Cập nhật lên giao diện';
    document.getElementById('publishConfirmName').textContent = pendingPublish.name;
    document.getElementById('publishConfirmText').innerHTML = isOn
        ? 'Xác nhận ẩn sản phẩm <strong id="publishConfirmName" style="color:var(--gold);font-weight:400">' + pendingPublish.name + '</strong> khỏi giao diện khách hàng?'
        : 'Xác nhận hiển thị sản phẩm <strong id="publishConfirmName" style="color:var(--gold);font-weight:400">' + pendingPublish.name + '</strong> trên giao diện khách hàng?';
    document.getElementById('publishConfirmMo')?.classList.add("open");
}

function closePublishConfirm() {
    document.getElementById('publishConfirmMo')?.classList.remove('open');
    pendingPublish = { id: null, btn: null, name: '', status: 0 };
}

async function confirmPublish() {
    const { id, btn } = pendingPublish;
    if (!id) return;
    const okBtn = document.getElementById('publishConfirmOk');
    if (okBtn) { okBtn.disabled = true; okBtn.style.opacity = '0.6'; }
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    const fd = new FormData();
    fd.append('__RequestVerificationToken', token);
    fd.append('productId', String(id));
    try {
        const r = await fetch('/Admin/PublishProduct', { method: 'POST', body: fd, credentials: 'same-origin' });
        const data = await r.json();
        closePublishConfirm();
        if (!data.success) {
            showToast(data.message || 'Không cập nhật được.', 'err');
            return;
        }
        showToast('✓ ' + (data.message || 'Đã cập nhật.'), 'ok');
        const tr = btn?.closest('tr');
        const badge = tr?.querySelector('.status-badge');
        const newStatus = data.status ?? 1;
        if (badge) {
            badge.classList.toggle('on', newStatus === 1);
            badge.classList.toggle('off', newStatus !== 1);
            badge.textContent = newStatus === 1 ? 'Đã hiển thị' : 'Chưa hiển thị';
        }
        if (btn) {
            btn.setAttribute('data-status', String(newStatus));
            btn.title = newStatus === 1 ? 'Ẩn khỏi giao diện' : 'Hiển thị lên giao diện';
        }
        const actRow = tr?.querySelector('.act-row');
        let delForm = tr?.querySelector('.btn-del-product-form');
        if (newStatus === 1 && delForm) {
            delForm.remove();
        } else if (newStatus !== 1 && !delForm && actRow) {
            const wrap = document.createElement('form');
            wrap.method = 'post';
            wrap.action = '/Admin/DeleteProduct';
            wrap.className = 'btn-del-product-form';
            wrap.style.display = 'inline';
            wrap.innerHTML = '<input type="hidden" name="__RequestVerificationToken" value="' + token + '" />' +
                '<input type="hidden" name="productID" value="' + id + '" />' +
                '<button type="submit" class="ia-btn del" title="Xóa" onclick="return confirm(\'Xóa sản phẩm này?\')">' +
                '<svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg></button>';
            actRow.appendChild(wrap);
        }
    } catch {
        showToast('Lỗi kết nối khi cập nhật.', 'err');
    } finally {
        if (okBtn) { okBtn.disabled = false; okBtn.style.opacity = '1'; }
    }
}
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.NevaImportReceipt) {
        window.NevaImportReceipt.init();
    }

    document.querySelectorAll('.btn-publish-row').forEach(btn => {
        btn.addEventListener('click', () => openPublishConfirm(btn.getAttribute('data-id'), btn));
    });

    initPublishConfirmModal();
    initAddProductModal();
    initEditProductModal();
});

function initPublishConfirmModal() {
    const mo = document.getElementById('publishConfirmMo');
    if (!mo) return;
    document.getElementById('publishConfirmClose')?.addEventListener('click', closePublishConfirm);
    document.getElementById('publishConfirmCancel')?.addEventListener('click', closePublishConfirm);
    document.getElementById('publishConfirmOk')?.addEventListener('click', confirmPublish);
    mo.addEventListener('click', e => { if (e.target === mo) closePublishConfirm(); });
}

function initAddProductModal() {
    const mo = document.getElementById('addMo');
    if (!mo) return;
    function closeAdd() { mo.classList.remove('open'); }
    document.getElementById('btnOpenAddProduct')?.addEventListener('click', () => {
        document.getElementById('addForm')?.reset();
        document.getElementById('addStockS').value = 0;
        document.getElementById('addStockM').value = 0;
        document.getElementById('addStockL').value = 0;
        mo.classList.add('open');
    });
    document.getElementById('addClose')?.addEventListener('click', closeAdd);
    document.getElementById('addCancel')?.addEventListener('click', closeAdd);
    mo.addEventListener('click', e => { if (e.target === mo) closeAdd(); });
}

let editImageUpload = null;

function initEditProductModal() {
    const mo = document.getElementById('editMo');
    if (!mo) return;

    if (window.NevaProductImageUpload) {
        editImageUpload = window.NevaProductImageUpload.init({ prefix: 'edit', aspectRatio: 4 / 5 });
        document.getElementById('editCropCancel2')?.addEventListener('click', () => {
            document.getElementById('editCropCancel')?.click();
        });
    }

    function closeEdit() { mo.classList.remove('open'); }

    document.getElementById('editClose')?.addEventListener('click', closeEdit);
    document.getElementById('editCancel')?.addEventListener('click', closeEdit);
    mo.addEventListener('click', e => { if (e.target === mo) closeEdit(); });

    document.querySelectorAll('.btn-edit-product').forEach(btn => {
        btn.addEventListener('click', async function () {
            const id = this.getAttribute('data-id');
            if (!id) return;
            try {
                const res = await fetch('/Admin/GetProduct?id=' + encodeURIComponent(id), { credentials: 'same-origin' });
                const data = await res.json();
                if (!data.success || !data.product) {
                    alert(data.message || 'Không tải được sản phẩm.');
                    return;
                }
                const p = data.product;
                document.getElementById('editId').value = p.id;
                document.getElementById('editMoTitle').textContent = '#' + String(p.id).padStart(3, '0');
                document.getElementById('editName').value = p.name || '';
                document.getElementById('editCat').value = p.categoryId;
                document.getElementById('editSeason').value = p.season;
                document.getElementById('editPrice').value = p.price;
                document.getElementById('editColor').value = p.color || '';
                document.getElementById('editStyle').value = p.style || '';
                document.getElementById('editMaterial').value = p.material || '';
                document.getElementById('editDesc').value = p.description || '';
                const qtyFor = (name) => {
                    const row = (p.sizes || []).find(s => String(s.sizeName).toUpperCase() === name);
                    return row ? row.stockQuantity : 0;
                };
                document.getElementById('editStockS').value = qtyFor('S');
                document.getElementById('editStockM').value = qtyFor('M');
                document.getElementById('editStockL').value = qtyFor('L');
                editImageUpload?.showCurrent(p.imageUrl || '');
                mo.classList.add('open');
            } catch {
                alert('Lỗi kết nối khi tải thông tin sản phẩm.');
            }
        });
    });
}

function switchTab(tab,btn){
    document.querySelectorAll('.atab').forEach(t=>t.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('productsTab').style.display=tab==='products'?'block':'none';
    document.getElementById('importsTab').style.display=tab==='imports'?'block':'none';
    document.getElementById('discountsTab').style.display=tab==='discounts'?'block':'none';
}
(function () {
    const params = new URLSearchParams(window.location.search);
    if (window.location.hash === '#imports' || params.get('receiptPage')) {
        const tabBtn = document.querySelector('.atab[onclick*="imports"]');
        if (tabBtn) switchTab('imports', tabBtn);
    }
})();
document.querySelectorAll('.mo').forEach(mo => {
    const observer = new MutationObserver(() => {
        if (mo.classList.contains('open')) { mo.style.opacity = '1'; mo.style.pointerEvents = 'all'; }
        else { mo.style.opacity = '0'; mo.style.pointerEvents = 'none'; }
    });
    observer.observe(mo, { attributes: true, attributeFilter: ['class'] });
});
</script>
</body></html>
