@model List<Clothing_Shop_Website.Models.User>
@{
    ViewData["Title"] = "Nhân viên";
    Layout = null;
    var days = new[] { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };
    var shifts = new[] { (1, "Ca sáng"), (2, "Ca chiều"), (3, "Ca tối") };
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>NEVA Admin — Nhân viên</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/neva-base.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/admin-staff.css" asp-append-version="true"/>
</head>
<body>
<div class="toast" id="toast"></div>
<nav class="admin-nav">
    <span class="admin-nav-logo">NEVA</span><span class="admin-nav-sep">|</span><span class="admin-nav-badge">Admin</span>
</nav>
<div class="admin-wrap">
    <aside class="admin-sidebar">
        <div class="sb-section">
            <div class="sb-lbl">Quản lý</div>
            <a asp-controller="Admin" asp-action="Dashboard" class="sitem"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
            <a asp-controller="Admin" asp-action="Products" class="sitem"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Sản phẩm</a>
            <a asp-controller="Admin" asp-action="Staff" class="sitem active"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Nhân viên</a>
            <a asp-controller="Admin" asp-action="Advertisements" class="sitem"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Quảng cáo</a>
        </div>
        <div class="sb-section" style="margin-top:12px">
            <a asp-controller="Account" asp-action="Logout" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Đăng xuất</a>
        </div>
    </aside>
    <main class="admin-main">

        @if (TempData["Success"] != null)
        {
            <div style="padding:10px 16px;background:rgba(90,154,90,.1);border:1px solid rgba(90,154,90,.3);color:#7aba7a;font-size:11px;margin-bottom:16px">✦ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="padding:10px 16px;background:rgba(180,80,80,.12);border:1px solid rgba(212,122,116,.35);color:#d4a8a4;font-size:11px;margin-bottom:16px">@TempData["Error"]</div>
        }

        <!-- TABS -->
        <div class="admin-tabs">
            <button class="atab active" onclick="switchTab('staff',this)">Danh sách nhân viên</button>
            <button class="atab" onclick="switchTab('shifts',this)">Ca làm việc</button>
        </div>

        <!-- ═══ TAB: DANH SÁCH NHÂN VIÊN ═══ -->
        <div id="staffListTab">
            <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px">
                <div>
                    <div class="page-title">Nhân viên</div>
                    <div class="page-sub">Quản lý <strong style="color:var(--gold)">@Model.Count</strong> nhân viên</div>
                </div>
                <button type="button" class="btn-add" onclick="openAddStaff()">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Thêm nhân viên
                </button>
            </div>

            <table class="staff-table">
                <thead>
                    <tr>
                        <th style="width:50px">#</th>
                        <th>Nhân viên</th>
                        <th>Ngày vào làm</th>
                        <th>Lương</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @{ int idx = 0; }
                @foreach (var u in Model)
                {
                    idx++;
                    var hd = u.StaffDetail?.HireDate.ToString("dd/MM/yyyy") ?? "—";
                    var hdVal = u.StaffDetail?.HireDate.ToString("yyyy-MM-dd") ?? "";
                    var sal = u.StaffDetail?.Salary ?? 0;
                    var shiftCount = u.StaffDetail?.StaffShifts?.Count ?? 0;
                    <tr>
                        <td style="color:rgba(250,248,242,.3);font-size:12px">@idx</td>
                        <td>
                            <div class="staff-name-cell">
                                <div class="staff-avatar">@(u.FullName.Length > 0 ? u.FullName[0].ToString().ToUpper() : "?")</div>
                                <div>
                                    <div class="staff-name">@u.FullName</div>
                                    <div class="staff-phone">@u.Phone</div>
                                </div>
                            </div>
                        </td>
                        <td>@hd</td>
                        <td style="color:var(--gold)">@sal.ToString("N0")đ</td>
                        <td>
                            <span class="status-badge @(u.Status == 1 ? "status-active" : "status-locked")">
                                @(u.Status == 1 ? "Hoạt động" : "Đã khóa")
                            </span>
                        </td>
                        <td>
                            <div class="staff-action-btns">
                                <button type="button" class="sab shift" title="Ca làm việc (@shiftCount ca)"
                                    onclick="document.querySelectorAll('.atab')[1].click();document.getElementById('shiftStaffSelect').value='@u.UserID';loadShiftsForStaff('@u.UserID')">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </button>
                                <button type="button" class="sab" title="Sửa"
                                    onclick="openEditStaff('@u.UserID','@Html.Raw(u.FullName.Replace("'","\\'"))','@u.Phone','@hdVal','@sal')">
                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                                <button type="button" class="sab del" title="Xóa"
                                    onclick="openDeleteStaff('@u.UserID','@Html.Raw(u.FullName.Replace("'","\\'"))')">
                                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" style="text-align:center;padding:32px;color:rgba(250,248,242,.25);font-size:12px">Chưa có nhân viên nào. Bấm "Thêm nhân viên" để bắt đầu.</td></tr>
                }
                </tbody>
            </table>
        </div>

        <!-- ═══ TAB: CA LÀM VIỆC ═══ -->
        <div id="shiftsTab" style="display:none">
            <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px;flex-wrap:wrap;gap:10px">
                <div>
                    <div class="page-title">Ca làm việc</div>
                    <div class="page-sub">Chọn nhân viên để xem và chỉnh sửa ca làm</div>
                </div>
                <div style="display:flex;align-items:center;gap:10px">
                    <select id="shiftStaffSelect" class="shift-staff-sel" onchange="loadShiftsForStaff(this.value)">
                        <option value="">— Chọn nhân viên —</option>
                        @foreach (var u in Model)
                        {
                            <option value="@u.UserID">@u.FullName</option>
                        }
                    </select>
                    <button type="button" id="btnSaveShifts" class="btn-add" style="white-space:nowrap">
                        <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Lưu ca làm việc
                    </button>
                </div>
            </div>

            <div class="abox" style="padding:0">
                <div class="abox-hdr"><div class="abox-t">Lưới ca làm việc trong tuần</div><div style="font-size:10px;color:rgba(250,248,242,.35);letter-spacing:1px">Bấm ô để chọn / bỏ chọn</div></div>
                <div class="shift-grid-container">
                    <table class="shift-grid">
                        <thead>
                            <tr>
                                <th></th>
                                @foreach (var d in days)
                                {
                                    <th>@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (shiftType, shiftLabel) in shifts)
                            {
                                <tr>
                                    <td>@shiftLabel</td>
                                    @foreach (var d in days)
                                    {
                                        <td>
                                            <div class="shift-cell-inner">
                                                <div class="shift-box" data-type="@shiftType" data-day="@d" title="@shiftLabel — @d"></div>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="padding:12px 16px;border-top:1px solid var(--border);font-size:10px;color:rgba(250,248,242,.3);letter-spacing:1px">
                    <span style="display:inline-flex;align-items:center;gap:6px">
                        <span style="width:14px;height:14px;background:rgba(201,168,76,.15);border:1.5px solid var(--gold);display:inline-block"></span> Đã phân ca
                    </span>
                    <span style="display:inline-flex;align-items:center;gap:6px;margin-left:16px">
                        <span style="width:14px;height:14px;background:rgba(0,0,0,.2);border:1.5px solid rgba(201,168,76,.2);display:inline-block"></span> Chưa phân ca
                    </span>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- ═══ SHARED POPUP: ADD / EDIT / DELETE ═══ -->
@Html.AntiForgeryToken()
<div id="staffMo" class="modal-overlay" style="display:none;backdrop-filter:blur(8px)">
    <div class="modal-box" style="max-width:500px">
        <div class="modal-hdr">
            <span id="staffMoTitle">THÊM NHÂN VIÊN</span>
            <button id="staffMoClose" class="modal-x">×</button>
        </div>

        <!-- ─── Chế độ THÊM & SỬA (dùng chung form) ─── -->
        <div id="moSection_add" class="mo-mode-section active">
            <form method="post" asp-controller="Admin" asp-action="AddStaff" id="addForm">
                @Html.AntiForgeryToken()
                <div class="modal-grid">
                    <label>Họ và tên</label>
                    <input type="text" name="fullName" class="modal-inp" required placeholder="Nguyễn Văn A" />
                    <label>Số điện thoại</label>
                    <input type="tel" name="phone" class="modal-inp" required placeholder="09xxxxxxxx" />
                    <label>Mật khẩu</label>
                    <input type="password" name="password" class="modal-inp" required placeholder="Tối thiểu 6 ký tự" minlength="6" />
                    <label>Ngày vào làm</label>
                    <input type="date" name="hireDate" class="modal-inp" required />
                    <label>Lương (đ/tháng)</label>
                    <input type="number" name="salary" class="modal-inp" required min="0" placeholder="0" />
                </div>
                <div class="modal-actions">
                    <button type="button" id="staffMoCancel" class="act-btn">Hủy</button>
                    <button type="submit" class="act-btn" style="border-color:var(--gold);color:var(--gold)">Thêm nhân viên</button>
                </div>
            </form>
        </div>

        <!-- ─── Chế độ SỬA ─── -->
        <div id="moSection_edit" class="mo-mode-section">
            <form method="post" asp-controller="Admin" asp-action="EditStaff">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="editUserId" />
                <div class="modal-grid">
                    <label>Họ và tên</label>
                    <input type="text" name="fullName" id="editFullName" class="modal-inp" required />
                    <label>Số điện thoại</label>
                    <input type="tel" name="phone" id="editPhone" class="modal-inp" required />
                    <label>Mật khẩu mới</label>
                    <input type="password" name="password" id="editPassword" class="modal-inp" placeholder="Để trống = giữ nguyên" minlength="6" />
                    <label>Ngày vào làm</label>
                    <input type="date" name="hireDate" id="editHireDate" class="modal-inp" required />
                    <label>Lương (đ/tháng)</label>
                    <input type="number" name="salary" id="editSalary" class="modal-inp" required min="0" />
                </div>
                <div class="modal-actions">
                    <button type="button" id="staffMoCancel2"
                        style="font-size:9px;letter-spacing:1.5px;text-transform:uppercase;font-family:var(--font-b);padding:8px 16px;border:1px solid var(--border);background:transparent;color:rgba(250,248,242,.5);cursor:pointer"
                        onclick="document.getElementById('staffMo').classList.remove('open');setTimeout(()=>document.getElementById('staffMo').style.display='none',300)">Hủy</button>
                    <button type="submit" class="act-btn" style="border-color:var(--gold);color:var(--gold)">Lưu thay đổi</button>
                </div>
            </form>
        </div>

        <!-- ─── Chế độ XÓA ─── -->
        <div id="moSection_delete" class="mo-mode-section">
            <form method="post" asp-controller="Admin" asp-action="DeleteStaff">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="deleteUserId" />
                <div class="confirm-text">
                    Bạn có chắc muốn xóa nhân viên <strong id="deleteStaffName"></strong>?
                    <span class="warn">⚠ Thao tác này không thể hoàn tác. Toàn bộ dữ liệu ca làm việc của nhân viên cũng sẽ bị xóa.</span>
                </div>
                <div class="modal-actions">
                    <button type="button" id="staffMoDelCancel"
                        style="font-size:9px;letter-spacing:1.5px;text-transform:uppercase;font-family:var(--font-b);padding:8px 16px;border:1px solid var(--border);background:transparent;color:rgba(250,248,242,.5);cursor:pointer"
                        onclick="document.getElementById('staffMo').classList.remove('open');setTimeout(()=>document.getElementById('staffMo').style.display='none',300)">Hủy</button>
                    <button type="submit" class="act-btn" style="border-color:#d47a76;color:#d47a76">Xóa nhân viên</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/neva-base.js" asp-append-version="true"></script>
<script src="~/js/admin-staff.js" asp-append-version="true"></script>
<script>
// Expose loadShiftsForStaff globally for inline onclick
function loadShiftsForStaff(userId) {
    if (!userId) {
        document.querySelectorAll('.shift-box').forEach(b => b.classList.remove('checked'));
        return;
    }
    fetch('/Admin/GetStaffShifts?userId=' + userId)
        .then(r => r.json())
        .then(data => {
            document.querySelectorAll('.shift-box').forEach(b => b.classList.remove('checked'));
            data.forEach(s => {
                const box = document.querySelector(`.shift-box[data-type="${s.shiftType}"][data-day="${s.dayOfWeek}"]`);
                if (box) box.classList.add('checked');
            });
        });
}
</script>
</body>
</html>
