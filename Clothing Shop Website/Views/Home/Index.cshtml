<script>
const c=document.getElementById('cursor'),r=document.getElementById('ring');
document.addEventListener('mousemove',e=>{
  c.style.left=e.clientX-3+'px';c.style.top=e.clientY-3+'px';
  r.style.left=e.clientX-15+'px';r.style.top=e.clientY-15+'px';
});
document.querySelectorAll('a,button').forEach(el=>{
  el.addEventListener('mouseenter',()=>{r.style.transform='scale(1.5)';c.style.transform='scale(0.5)'});
  el.addEventListener('mouseleave',()=>{r.style.transform='scale(1)';c.style.transform='scale(1)'});
});
let cur=0;
const slides=document.querySelectorAll('.hs'),dots=document.querySelectorAll('.sd');
function go(n){
  slides[cur].classList.remove('on');dots[cur].classList.remove('on');
  cur=(n+slides.length)%slides.length;
  slides[cur].classList.add('on');dots[cur].classList.add('on');
}
function ns(){go(cur+1)}
function ps(){go(cur-1)}
dots.forEach((d,i)=>d.addEventListener('click',()=>go(i)));
setInterval(ns,5000);
</script>
