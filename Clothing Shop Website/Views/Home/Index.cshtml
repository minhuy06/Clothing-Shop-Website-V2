@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEVA — Haute Couture</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#c9a84c;--gold2:#e8c96a;--gold3:#f0d87a;
  --black:#050402;--dark:#0c0a07;--dark2:#14100a;
  --white:#faf8f2;--border:rgba(201,168,76,0.18);
  --font-d:'Playfair Display',serif;
  --font-b:'Josefin Sans',sans-serif;
  --font-a:'EB Garamond',serif;
  --nav-h:52px;
}
html,body{margin:0;padding:0}
body{font-family:var(--font-b);background:var(--black);color:var(--white);overflow-x:hidden;cursor:none}
a{text-decoration:none;color:inherit}
img{display:block;width:100%;height:100%;object-fit:cover}
.cursor{position:fixed;width:7px;height:7px;background:var(--gold);border-radius:50%;pointer-events:none;z-index:9999;transition:transform 0.1s}
.cursor-ring{position:fixed;width:30px;height:30px;border:1px solid rgba(201,168,76,0.65);border-radius:50%;pointer-events:none;z-index:9998;transition:left 0.07s,top 0.07s;opacity:0.7}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 44px;
  background:rgba(5,4,2,0.97);backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border);
}
.nav-logo{font-family:var(--font-d);font-size:18px;letter-spacing:8px;color:var(--white);font-weight:400}
.nav-mid{display:flex;align-items:center}
.nl{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(250,248,242,0.42);padding:0 14px;cursor:none;transition:color 0.2s}
.nl:hover{color:var(--white)}
.nl.g{color:var(--gold)}
.nd{color:rgba(250,248,242,0.14);font-size:10px}
.nav-right{display:flex;gap:16px}
.ni{cursor:none;color:rgba(250,248,242,0.5);transition:color 0.2s;display:flex;align-items:center}
.ni:hover{color:var(--gold)}
.ni svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}

/* ── HERO BLOCK ── */
.hero-block{
  display:grid;
  grid-template-columns:52px calc(40% - 52px) 1fr;
  height:calc(100vh - var(--nav-h));
  margin-top:var(--nav-h);
}

/* ── GOLD STRIP ── */
.gs{
  background:
    linear-gradient(180deg,
      #d4a535 0%,
      #b8862a 8%,
      #8a6018 25%,
      #6b4810 45%,
      #4a3008 65%,
      #2e1c05 82%,
      #1a1004 100%
    );
  display:flex;flex-direction:column;align-items:center;
  justify-content:space-between;
  padding:24px 0 20px;
  overflow:hidden;
  position:relative;
}
/* Subtle sheen on gold strip */
.gs::before{
  content:'';position:absolute;top:0;left:0;right:0;height:35%;
  background:linear-gradient(180deg,rgba(255,230,120,0.12) 0%,transparent 100%);
  pointer-events:none;
}
.gs-n{
  font-family:var(--font-d);font-size:52px;font-weight:700;
  color:rgba(20,12,2,0.35);
  writing-mode:vertical-rl;letter-spacing:-3px;user-select:none;
  text-shadow:0 2px 8px rgba(0,0,0,0.4);
  margin-top:8px;
}
.gs-arr{
  font-size:13px;color:rgba(250,248,242,0.4);
  animation:ab 2s ease-in-out infinite;cursor:none;
  margin-bottom:8px;
}
@@keyframes ab{0%,100%{transform:translateY(0)}50%{transform:translateY(6px)}}

/* ── HERO PANEL ── */
.hp{position:relative;overflow:hidden;background:var(--dark2)}
.hs{position:absolute;inset:0;opacity:0;transition:opacity 1s ease}
.hs.on{opacity:1}
.hs img{
  filter:brightness(0.48) contrast(1.1) saturate(0.85);
  object-position:center top;
}
.hv{
  position:absolute;inset:0;
  background:
    linear-gradient(to right,rgba(5,4,2,0.65) 0%,rgba(5,4,2,0.1) 60%,transparent 100%),
    linear-gradient(to top,rgba(5,4,2,0.75) 0%,rgba(5,4,2,0.1) 45%,transparent 70%);
}
.ht{position:absolute;bottom:72px;left:40px;right:28px;z-index:3}

/* ── CREST LOGO — đúng như ảnh ── */
.crest-wrap{
  width:72px;height:72px;position:relative;
  margin-bottom:18px;
}
/* Outer ring */
.crest-outer{
  position:absolute;inset:0;border-radius:50%;
  border:1.5px solid rgba(201,168,76,0.55);
}
/* Inner ring */
.crest-inner-ring{
  position:absolute;inset:6px;border-radius:50%;
  border:1px solid rgba(201,168,76,0.3);
}
/* Main circle */
.crest-body{
  position:absolute;inset:10px;border-radius:50%;
  background:linear-gradient(145deg,rgba(201,168,76,0.14) 0%,rgba(30,18,4,0.7) 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:0;
}
/* Leaf ornament top/bottom */
.crest-leaf-t,.crest-leaf-b{
  font-size:7px;color:rgba(201,168,76,0.55);
  line-height:1;letter-spacing:0px;
}
.crest-letter{
  font-family:var(--font-d);font-size:22px;font-weight:500;
  color:rgba(250,235,150,0.88);line-height:1;
  text-shadow:0 1px 8px rgba(0,0,0,0.5);
}
.crest-brand{
  font-size:5px;letter-spacing:3px;text-transform:uppercase;
  color:rgba(250,235,150,0.45);margin-top:1px;
}
/* Horizontal lines on sides of crest */
.crest-line-l,.crest-line-r{
  position:absolute;top:50%;height:1px;width:8px;
  background:rgba(201,168,76,0.35);
}
.crest-line-l{left:2px;transform:translateY(-50%)}
.crest-line-r{right:2px;transform:translateY(-50%)}

.ht-title{
  font-family:var(--font-d);
  font-size:clamp(22px,2.4vw,35px);
  font-weight:400;color:var(--white);
  line-height:1.2;margin-bottom:14px;
  text-shadow:0 2px 24px rgba(0,0,0,0.6);
}
.ht-link{
  font-size:8px;letter-spacing:3px;text-transform:uppercase;
  color:var(--gold);border-bottom:1px solid rgba(201,168,76,0.35);
  padding-bottom:2px;display:inline-block;
  transition:border-color 0.2s;cursor:none;
}
.ht-link:hover{border-color:var(--gold)}
/* Slide arrows */
.sa{
  position:absolute;top:50%;transform:translateY(-50%);z-index:5;
  width:28px;height:46px;
  background:rgba(5,4,2,0.45);border:1px solid rgba(250,248,242,0.1);
  display:flex;align-items:center;justify-content:center;
  font-size:17px;color:rgba(250,248,242,0.4);cursor:none;
  transition:all 0.2s;font-family:serif;
}
.sa:hover{border-color:rgba(201,168,76,0.5);color:var(--gold)}
.sp{left:0}.sn{right:0}
.sdots{position:absolute;bottom:18px;left:40px;display:flex;gap:5px;z-index:5}
.sd{width:18px;height:2px;background:rgba(250,248,242,0.18);cursor:none;transition:all 0.3s}
.sd.on{width:28px;background:var(--gold)}

/* ── RIGHT GRID — 3 cols ── */
.rg{
  display:grid;
  grid-template-columns:1fr 1.08fr 1fr;
  grid-template-rows:1fr 1fr;
  gap:2px;
  background:rgba(0,0,0,0.55);
}

/* Ambassador — full height left */
.ca{grid-row:1/3;position:relative;overflow:hidden;cursor:none}
.ca img{
  filter:brightness(0.62) contrast(1.06);
  object-position:top center;
  transition:transform 0.8s ease;
}
.ca:hover img{transform:scale(1.04)}
.cao{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(5,4,2,0.92) 0%,rgba(5,4,2,0.18) 42%,transparent 62%);
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:20px 16px;
}
.ca-tag{font-size:7px;letter-spacing:2px;text-transform:uppercase;color:rgba(250,248,242,0.38);margin-bottom:5px}
.ca-name{
  font-family:var(--font-d);font-size:24px;font-style:italic;
  color:var(--white);line-height:1.1;margin-bottom:4px;
}
.ca-sub{font-size:7px;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);margin-bottom:13px}
.ca-btn{
  display:block;padding:8px 0;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:var(--black);font-size:7px;letter-spacing:2.5px;
  text-transform:uppercase;font-family:var(--font-b);
  cursor:none;border:none;text-align:center;
  transition:opacity 0.2s;
}
.ca-btn:hover{opacity:0.85}

/* Middle cells x2 */
.cm{position:relative;overflow:hidden;cursor:none;background:var(--dark2)}
.cm img{filter:brightness(0.68) contrast(1.06);transition:transform 0.6s ease}
.cm:hover img{transform:scale(1.06)}
.cmo{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(5,4,2,0.9) 0%,rgba(5,4,2,0.05) 52%,transparent 72%);
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:11px 13px;
}
.c-tag{font-size:7px;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);opacity:0.85;margin-bottom:3px}
.c-name{font-family:var(--font-a);font-size:12px;font-style:italic;color:var(--white);margin-bottom:2px;line-height:1.3}
.c-code{font-size:7px;letter-spacing:1px;color:rgba(250,248,242,0.32);margin-bottom:3px}
.c-price{font-size:12px;font-weight:300;color:var(--gold)}

/* Right tall cell */
.cr{grid-row:1/3;position:relative;overflow:hidden;cursor:none;background:var(--dark2)}
.cr img{
  filter:brightness(0.65) contrast(1.06);
  object-position:top center;
  transition:transform 0.7s ease;
}
.cr:hover img{transform:scale(1.04)}
.cro{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(5,4,2,0.92) 0%,transparent 52%);
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:14px 13px;
}
.c-row{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:6px;margin-top:6px}
.c-bst{
  font-size:7px;letter-spacing:2px;text-transform:uppercase;
  padding:5px 12px;border:1px solid rgba(201,168,76,0.5);
  color:var(--gold);cursor:none;font-family:var(--font-b);
  background:transparent;transition:all 0.2s;
}
.c-bst:hover{background:rgba(201,168,76,0.1)}

/* ── MARQUEE ── */
.mq{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:10px 0;overflow:hidden;background:var(--dark)}
.mqi{display:inline-block;animation:mq 24s linear infinite;white-space:nowrap}
.mqi span{font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:300;padding:0 36px;font-family:var(--font-b)}
.mqi .dot{color:rgba(201,168,76,0.3)}
@@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── SECOND ROW ── */
.sr{
  display:grid;
  grid-template-columns:52px 1fr 1fr 1fr 300px;
  height:315px;
  border-top:1px solid rgba(201,168,76,0.07);
}
.sr-strip{
  background:linear-gradient(180deg,#c49832 0%,#7a5518 35%,#3a2008 70%,#180e04 100%);
}
.sr-cell{position:relative;overflow:hidden;cursor:none;background:var(--dark2)}
.sr-cell img{filter:brightness(0.65) contrast(1.08);object-position:top center;transition:transform 0.6s ease}
.sr-cell:hover img{transform:scale(1.05)}
.tp{
  background:linear-gradient(155deg,#14100a,#080604);
  display:flex;flex-direction:column;justify-content:center;
  padding:30px 26px;
  border-left:1px solid rgba(201,168,76,0.1);
  position:relative;overflow:hidden;
}
.tp::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0.22}
.tp-sp{
  display:inline-block;padding:4px 10px;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:var(--black);font-size:7px;letter-spacing:3px;text-transform:uppercase;
  font-family:var(--font-b);margin-bottom:12px;align-self:flex-start;
}
.tp-t{font-family:var(--font-d);font-size:22px;font-weight:400;line-height:1.1;color:var(--white);margin-bottom:7px}
.tp-t em{font-style:italic;color:var(--gold)}
.tp-d{font-size:10px;font-weight:200;letter-spacing:0.5px;color:rgba(250,248,242,0.28);line-height:1.8;margin-bottom:8px;max-width:235px}
.tp-p{font-size:11px;font-weight:300;color:var(--gold);margin-bottom:14px;letter-spacing:0.3px}
.tp-btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:7px 16px;border:1px solid rgba(201,168,76,0.4);
  color:var(--gold);font-size:7px;letter-spacing:2.5px;text-transform:uppercase;
  font-family:var(--font-b);cursor:none;background:transparent;
  transition:all 0.2s;align-self:flex-start;
}
.tp-btn:hover{background:rgba(201,168,76,0.07);border-color:var(--gold)}

/* ── VIP BAR ── */
.vb{display:grid;grid-template-columns:52px 1fr 1fr;border-top:1px solid var(--border);background:var(--dark)}
.vb-gs{background:linear-gradient(180deg,#7a5518,#231508)}
.vc{display:flex;align-items:center;gap:16px;padding:20px 36px;border-right:1px solid var(--border);position:relative}
.vc:last-child{border-right:none}
.vc::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0.16}
.vc-svg{width:32px;height:32px;flex-shrink:0;opacity:0.65}
.vc-t{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:4px}
.vc-d{font-size:10px;font-weight:200;letter-spacing:0.3px;color:rgba(250,248,242,0.28);line-height:1.6}

/* ── FOOTER ── */
footer{background:var(--dark);padding:56px 44px 32px;border-top:1px solid var(--border)}
.fl{height:1px;margin-bottom:48px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0.16}
.ft{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:52px;margin-bottom:48px}
.f-logo{font-family:var(--font-d);font-size:26px;letter-spacing:7px;display:block;margin-bottom:12px}
.f-tag{font-size:10px;font-weight:200;letter-spacing:1px;color:rgba(250,248,242,0.2);line-height:2;max-width:180px}
.fct{font-size:8px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:18px}
.fc a{display:block;font-size:10px;font-weight:200;letter-spacing:1px;color:rgba(250,248,242,0.25);margin-bottom:9px;transition:color 0.2s}
.fc a:hover{color:var(--gold)}
.fb{display:flex;justify-content:space-between;padding-top:22px;border-top:1px solid var(--border);font-size:8px;letter-spacing:2px;color:rgba(250,248,242,0.14)}
</style>
</head>
<body>
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="ring"></div>

<!-- NAV -->
<nav>
  <a href="/" class="nav-logo">NEVA</a>
  <div class="nav-mid">
    <a href="/Product" class="nl">Bộ Sưu Tập</a>
    <span class="nd">|</span>
    <a href="/Product" class="nl">Sản Phẩm</a>
    <span class="nd">|</span>
    <a href="#" class="nl g">Haute Couture</a>
    <span class="nd">|</span>
    <a href="/Account/Profile" class="nl">Tài Khoản</a>
  </div>
  <div class="nav-right">
    <a href="/Product" class="ni"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg></a>
    <a href="/Account/Profile" class="ni"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></a>
    <a href="/Cart" class="ni"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></a>
  </div>
</nav>

<!-- HERO BLOCK -->
<div class="hero-block">

  <!-- Gold strip -->
  <div class="gs">
    <span class="gs-n">N</span>
    <span class="gs-arr">↓</span>
  </div>

  <!-- Hero slideshow — váy ren nâu vàng champagne -->
  <div class="hp">
    <div class="hs on">
      <!-- Đầm ren couture champagne/gold tone -->
      <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=900&q=88" alt="NEVA Couture">
    </div>
    <div class="hs">
      <!-- Đầm dạ hội lấp lánh -->
      <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=900&q=88" alt="NEVA Couture 2">
    </div>
    <div class="hs">
      <!-- Váy couture elegant -->
      <img src="https://images.unsplash.com/photo-1566479179817-c6fa1b6c2de0?w=900&q=88" alt="NEVA Couture 3">
    </div>
    <div class="hv"></div>
    <div class="ht">
      <!-- Crest logo đúng như ảnh -->
      <div class="crest-wrap">
        <div class="crest-outer"></div>
        <div class="crest-inner-ring"></div>
        <div class="crest-body">
          <span class="crest-leaf-t">✦</span>
          <span class="crest-letter">N</span>
          <span class="crest-brand">NEVA</span>
          <span class="crest-leaf-b">✦</span>
        </div>
        <div class="crest-line-l"></div>
        <div class="crest-line-r"></div>
      </div>
      <h1 class="ht-title">NEVA. Haute Couture.<br>Tuyệt Tác Đến Từ Bên Trong.</h1>
      <a href="/Product" class="ht-link">Khám Phá Di Sản</a>
    </div>
    <div class="sa sp" onclick="ps()">‹</div>
    <div class="sa sn" onclick="ns()">›</div>
    <div class="sdots" id="dots">
      <div class="sd on"></div><div class="sd"></div><div class="sd"></div>
    </div>
  </div>

  <!-- Right grid: 3 cols -->
  <div class="rg">

    <!-- Col 1: Ambassador dọc full height -->
    <div class="ca">
      <!-- Người mặc đầm dạ hội sang trọng -->
      <img src="https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=600&q=88" alt="Ambassador">
      <div class="cao">
        <div class="ca-tag">Đại sứ thương hiệu · Hồ Ngọc Hà</div>
        <div class="ca-name">Chạm Đến<br>Hoàn Mỹ.</div>
        <div class="ca-sub">Eclipse Panthera Collection</div>
        <a href="/Product" class="ca-btn">Xem Chi Tiết</a>
      </div>
    </div>

    <!-- Col 2 top: vải leopard texture -->
    <div class="cm">
      <img src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=500&q=88" alt="Eclipse fabric">
      <div class="cmo">
        <div class="c-tag">Eclipse Panthera</div>
        <div class="c-name">Khối Vọng Phương Đông</div>
        <div class="c-code">2651W322607H021 · 1.350.000 ₫</div>
      </div>
    </div>

    <!-- Col 2 bottom: người mặc đồ tối -->
    <div class="cm">
      <img src="https://images.unsplash.com/photo-1483985988355-763728e1935b?w=500&q=88" alt="Eclipse outfit">
      <div class="cmo">
        <div class="c-tag">Eclipse Panthera</div>
        <div class="c-name">Khối Vọng Phương Đông</div>
        <div class="c-code">2651W322607H021 · 1.350.000 ₫</div>
      </div>
    </div>

    <!-- Col 3: váy dài full height — nền sáng/trắng như ảnh -->
    <div class="cr">
      <img src="https://images.unsplash.com/photo-1515372039744-b8f02a3ae446?w=500&q=88" alt="Maxi dress">
      <div class="cro">
        <div class="c-tag">Eclipse Panthera</div>
        <div class="c-name">Chân váy maxi bèo Eclipse Panthera</div>
        <div class="c-code">2651W322607H021</div>
        <div class="c-row">
          <div class="c-price">1.390.000 ₫</div>
          <a href="/Product" class="c-bst">Xem BST</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MARQUEE -->
<div class="mq">
  <div class="mqi">
    <span>Miễn phí vận chuyển toàn quốc</span><span class="dot"> ◆ </span>
    <span>Haute Couture · Thiết kế độc quyền</span><span class="dot"> ◆ </span>
