@model Clothing_Shop_Website.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/hoso.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/thanh-toan.css" asp-append-version="true" />
}

@if (TempData["Error"] != null)
{
    <div style="background:rgba(212,122,118,.1);border-bottom:1px solid rgba(212,122,118,.25);color:#d47a76;font-size:11px;letter-spacing:1.5px;padding:12px 52px;text-align:center">✦ @TempData["Error"]</div>
}

<div class="steps-bar">
    <div class="step done"><div class="step-num">✓</div><span class="step-lbl">Giỏ hàng</span></div>
    <div class="step-line done"></div>
    <div class="step active"><div class="step-num">2</div><span class="step-lbl">Thanh toán</span></div>
    <div class="step-line wait"></div>
    <div class="step wait"><div class="step-num">3</div><span class="step-lbl">Hoàn tất</span></div>
</div>

<div class="checkout-layout">
    <div>
        <form method="post" asp-controller="Order" asp-action="PlaceOrder" id="orderForm">
            @Html.AntiForgeryToken()

            <div class="form-box">
                <div class="form-box-title">
                    <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                    Địa chỉ giao hàng
                </div>

                @if (Model.Addresses.Any())
                {
                    <div class="frow full" style="margin-bottom:14px">
                        <div class="fgroup">
                            <label class="flabel">Chọn địa chỉ có sẵn</label>
                            <select class="fselect" id="addrSelect" onchange="fillAddr(this)">
                                <option value="">-- Nhập địa chỉ mới --</option>
                                @foreach (var addr in Model.Addresses)
                                {
                                    <option value="@addr.FullName|@addr.Phone|@addr.DetailedAddress|@addr.Province_City">
                                        @addr.FullName — @addr.DetailedAddress, @addr.Province_City
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                }

                <div class="frow">
                    <div class="fgroup">
                        <label class="flabel">Họ và tên người nhận</label>
                        <input class="finput" type="text" name="receiverName" id="rcvName"
                               value="@Context.Session.GetString("FullName")" required>
                    </div>
                    <div class="fgroup">
                        <label class="flabel">Số điện thoại</label>
                        <input class="finput" type="tel" name="receiverPhone" id="rcvPhone"
                               value="@Context.Session.GetString("Phone")" required>
                    </div>
                </div>
                <div class="frow">
                    <div class="fgroup">
                        <label class="flabel">Tỉnh / Thành phố</label>
                        <select class="fselect" name="shippingProvince" id="rcvProvince" required>
                            <option value="">-- Chọn tỉnh/thành --</option>
                            <option>Đà Nẵng</option>
                            <option>Hà Nội</option>
                            <option>TP. Hồ Chí Minh</option>
                            <option>Cần Thơ</option>
                            <option>Hải Phòng</option>
                            <option>Huế</option>
                        </select>
                    </div>
                    <div class="fgroup">
                        <label class="flabel">Địa chỉ chi tiết</label>
                        <input class="finput" type="text" name="shippingAddress" id="rcvAddr"
                               placeholder="Số nhà, tên đường, phường/xã..." required>
                    </div>
                </div>
            </div>

            <div class="form-box">
                <div class="form-box-title">
                    <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                    Phương thức thanh toán
                </div>
                <div class="pay-cod">
                    <div class="pay-cod-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg></div>
                    <div>
                        <div class="pay-cod-name">Thanh toán khi nhận hàng (COD)</div>
                        <div class="pay-cod-desc">Thanh toán bằng tiền mặt khi nhận được hàng</div>
                    </div>
                    <div class="pay-cod-check"></div>
                </div>
            </div>

            <div class="form-box">
                <div class="form-box-title">
                    <svg viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" /><line x1="7" y1="7" x2="7.01" y2="7" /></svg>
                    Mã giảm giá & Điểm thưởng
                </div>
                <div class="frow">
                    <div class="fgroup">
                        <label class="flabel">Mã giảm giá</label>
                        <input class="finput" type="text" name="discountCode" placeholder="Nhập mã ưu đãi..." style="text-transform:uppercase"
                               value="@Model.CouponCode">
                    </div>
                    <div class="fgroup">
                        <label class="flabel">Dùng điểm thưởng (có @Model.RewardPoints.ToString("N0") điểm)</label>
                        <input class="finput" type="number" name="usePoints" min="0" max="@Model.RewardPoints"
                               placeholder="0" value="@(Model.UsePoints > 0 ? Model.UsePoints : "")">
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.CouponMessage))
                {
                    <p style="font-size:11px;margin-top:8px;color:@(Model.CouponDiscount > 0 ? "#7aba7a" : "#d47a76")">@Model.CouponMessage</p>
                }
            </div>
        </form>
    </div>

    <div class="order-side">
        <div class="summary-box">
            <div class="summary-title">Đơn hàng của bạn</div>
            <div class="order-items">
                @foreach (var item in Model.CartItems)
                {
                    var img = string.IsNullOrWhiteSpace(item.ProductSize.Product.ImageUrl)
                        ? "https://images.unsplash.com/photo-1483985988355-763728e1935b?w=200&q=80"
                        : item.ProductSize.Product.ImageUrl;
                    <div class="oitem">
                        <div class="oitem-thumb">
                            <img src="@img" alt="@item.ProductSize.Product.ProductName"
                                 onerror="this.src='https://images.unsplash.com/photo-1483985988355-763728e1935b?w=200&q=80'">
                            <div class="oitem-qty">@item.Quantity</div>
                        </div>
                        <div style="flex:1">
                            <div class="oitem-name">@item.ProductSize.Product.ProductName</div>
                            <div class="oitem-meta">
                                Size: @item.ProductSize.SizeName
                            </div>
                        </div>
                        <div class="oitem-price">@((item.ProductSize.Product.Price * item.Quantity).ToString("N0"))đ</div>
                    </div>
                }
            </div>
            <hr class="sdiv">

            <div class="srow">
                <span class="slabel">Hạng thành viên</span>
                <span class="tier-badge @Model.TierCssClass">@Model.MembershipTier</span>
            </div>
            <div class="srow"><span class="slabel">Tạm tính</span><span>@Model.Subtotal.ToString("N0")đ</span></div>
            <div class="srow"><span class="slabel">Vận chuyển</span><span>@(Model.Shipping == 0 ? "Miễn phí" : Model.Shipping.ToString("N0") + "đ")</span></div>
            @if (Model.CouponDiscount > 0)
            {
                <div class="srow"><span class="slabel">Mã giảm giá</span><span style="color:#7aba7a">−@Model.CouponDiscount.ToString("N0")đ</span></div>
            }
            @if (Model.PointsDiscount > 0)
            {
                <div class="srow"><span class="slabel">Điểm thưởng</span><span style="color:#7aba7a">−@Model.PointsDiscount.ToString("N0")đ</span></div>
            }
            @if (Model.TierDiscount > 0)
            {
                <div class="srow"><span class="slabel">Ưu đãi hạng (@Model.TierDiscountPercent%)</span><span style="color:#7aba7a">−@Model.TierDiscount.ToString("N0")đ</span></div>
            }
            <div class="srow total"><span>Tổng thanh toán</span><span>@Model.Total.ToString("N0")đ</span></div>

            <button type="submit" form="orderForm" class="btn-order">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                Đặt hàng ngay
            </button>
            <p class="secure">
                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                Thanh toán COD · Bảo mật 100%
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/thanh-toan.js" asp-append-version="true"></script>
}
