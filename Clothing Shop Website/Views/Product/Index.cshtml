<div class="popup-overlay" id="popupOverlay" onclick="if(event.target===this)closePopup()">
  <div class="popup-modal">
    <div class="popup-gallery">
      <div class="popup-main">👕</div>
      <div class="popup-close" onclick="closePopup()">×</div>
    </div>
    <div class="popup-info">
      <div class="popup-cat">Áo thun · NEVA Premium</div>
      <h2 class="popup-name">Áo thun basic oversize</h2>
      <div class="popup-price-row"><span class="popup-price">320.000 ₫</span></div>
      <hr class="popup-divider">
      <div class="plabel">Màu sắc</div>
      <div class="popup-colors">
        <div class="pclr-item active"><div class="pclr-circle" style="background:#1a1a1a;border-color:var(--gold)"></div><span class="pclr-name">Đen</span></div>
        <div class="pclr-item"><div class="pclr-circle" style="background:#f5f2ed;border:1px solid #666"></div><span class="pclr-name">Kem</span></div>
        <div class="pclr-item"><div class="pclr-circle" style="background:#6b7c6b"></div><span class="pclr-name">Rêu</span></div>
      </div>
      <div class="plabel">Chọn size</div>
      <div class="popup-sizes">
        <div class="psz out">XS</div>
        <div class="psz active">S</div>
        <div class="psz">M</div>
        <div class="psz">L</div>
        <div class="psz">XL</div>
      </div>
      <div class="plabel">Số lượng</div>
      <div class="qty-row">
        <button class="qbtn" onclick="changeQty(-1)">−</button>
        <input class="qval" type="number" value="1" min="1" id="qtyIn">
        <button class="qbtn" onclick="changeQty(1)">+</button>
      </div>
      <button class="btn-addcart" onclick="window.location='/Cart'">Thêm vào giỏ hàng</button>
      <button class="btn-wish-full">♡ Lưu yêu thích</button>
      <p class="popup-desc">100% cotton organic cao cấp. Dáng oversize thoải mái, đường may tinh tế. Phù hợp mặc hàng ngày hoặc layer cùng áo khoác.</p>
    </div>
  </div>
</div>

<script>
const cursor=document.getElementById('cursor'),ring=document.getElementById('cursorRing');
document.addEventListener('mousemove',e=>{cursor.style.left=e.clientX-4+'px';cursor.style.top=e.clientY-4+'px';ring.style.left=e.clientX-18+'px';ring.style.top=e.clientY-18+'px'});
function openPopup(){document.getElementById('popupOverlay').classList.add('open');document.body.style.overflow='hidden'}
function closePopup(){document.getElementById('popupOverlay').classList.remove('open');document.body.style.overflow=''}
function changeQty(d){const i=document.getElementById('qtyIn');let v=parseInt(i.value)+d;if(v<1)v=1;i.value=v}
document.querySelectorAll('.psz:not(.out)').forEach(b=>b.addEventListener('click',()=>{document.querySelectorAll('.psz').forEach(x=>x.classList.remove('active'));b.classList.add('active')}));
document.querySelectorAll('.pclr-item').forEach(i=>i.addEventListener('click',()=>{document.querySelectorAll('.pclr-item').forEach(x=>x.classList.remove('active'));i.classList.add('active')}));
document.querySelectorAll('.sz-btn').forEach(b=>b.addEventListener('click',()=>b.classList.toggle('active')));
</script>
