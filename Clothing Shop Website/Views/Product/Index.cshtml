@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEVA — Bộ sưu tập</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#c9a84c;--gold2:#e8c96a;
  --black:#050402;--dark:#0c0a07;--dark2:#14100a;--dark3:#1e1a12;
  --white:#faf8f2;--border:rgba(201,168,76,0.18);
  --font-d:'Playfair Display',serif;--font-b:'Josefin Sans',sans-serif;--font-a:'EB Garamond',serif;
  --nav-h:52px;
}
body{font-family:var(--font-b);background:var(--black);color:var(--white)}
a{text-decoration:none;color:inherit}
img{display:block;width:100%;height:100%;object-fit:cover}

/* NAV — đồng bộ trang chủ */
nav{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 44px;height:var(--nav-h);background:rgba(5,4,2,.97);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50}
.nav-logo{font-family:var(--font-d);font-size:18px;letter-spacing:8px;color:var(--white);justify-self:start;display:flex;align-items:center;gap:12px}
.nav-logo a{font-family:var(--font-d);font-size:18px;letter-spacing:8px;color:var(--white)}
.nav-logo-sep{color:rgba(250,248,242,.2);font-size:16px;font-weight:200}
.nav-mid{display:flex;align-items:center;justify-content:center}
.nl{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(250,248,242,.7);padding:0 14px;transition:color .2s}
.nl:hover{color:var(--white)}.nl.active{color:var(--gold)}
.nd{color:rgba(250,248,242,.14);font-size:10px}
.nav-search{display:flex;align-items:center;border:1px solid var(--border);background:rgba(201,168,76,.04);transition:border-color .2s}
.nav-search:focus-within{border-color:rgba(201,168,76,.45)}
.nav-search input{background:transparent;border:none;outline:none;padding:7px 12px;font-size:10px;letter-spacing:1px;font-family:var(--font-b);color:var(--white);width:150px;transition:width .3s}
.nav-search input::placeholder{color:rgba(250,248,242,.22)}
.nav-search input:focus{width:190px}
.nav-search-btn{width:30px;height:30px;display:flex;align-items:center;justify-content:center;color:rgba(250,248,242,.4);background:transparent;border:none;transition:color .2s}
.nav-search-btn:hover{color:var(--gold)}
.nav-search-btn svg{width:13px;height:13px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round}
.nav-right{display:flex;gap:14px;justify-self:end;align-items:center}
.ni{color:rgba(250,248,242,.55);transition:color .2s;display:flex;align-items:center}
.ni:hover{color:var(--gold)}
.ni svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}

/* PAGE BANNER */
.page-banner{padding:48px 52px 40px;background:linear-gradient(160deg,var(--dark2),var(--black));border-bottom:1px solid var(--border);position:relative;overflow:hidden}
.page-banner::after{content:'';position:absolute;bottom:0;left:52px;right:52px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.25}
.pb-bg{position:absolute;right:60px;top:50%;transform:translateY(-50%);font-family:var(--font-d);font-size:140px;font-weight:700;color:rgba(201,168,76,.03);letter-spacing:-8px;user-select:none;pointer-events:none}
.breadcrumb{font-size:9px;letter-spacing:2px;color:rgba(250,248,242,.28);margin-bottom:12px;display:flex;gap:8px;align-items:center}
.breadcrumb a{color:rgba(250,248,242,.28)}.breadcrumb a:hover{color:var(--gold)}
.page-title{font-family:var(--font-d);font-size:44px;font-weight:400;line-height:1}
.page-title em{font-style:italic;color:var(--gold)}

/* LAYOUT */
.shop-layout{display:flex;min-height:calc(100vh - var(--nav-h))}

/* SIDEBAR */
.sidebar{width:255px;flex-shrink:0;background:var(--dark);border-right:1px solid var(--border);padding:28px 22px;position:sticky;top:var(--nav-h);height:calc(100vh - var(--nav-h));overflow-y:auto}
.sidebar::-webkit-scrollbar{width:2px}.sidebar::-webkit-scrollbar-thumb{background:var(--border)}
.filter-hdr{display:flex;align-items:center;gap:10px;font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:24px}
.filter-hdr svg{width:13px;height:13px;fill:none;stroke:var(--gold);stroke-width:1.5;stroke-linecap:round}
.fg{margin-bottom:22px;padding-bottom:22px;border-bottom:1px solid var(--border)}
.fg:last-of-type{border-bottom:none;margin-bottom:0;padding-bottom:0}
.fg-title{font-size:9px;font-weight:300;letter-spacing:2.5px;text-transform:uppercase;color:rgba(250,248,242,.65);margin-bottom:12px}

/* Custom checkbox */
.fc-item{display:flex;align-items:center;gap:9px;margin-bottom:9px}
.fc-box{width:13px;height:13px;flex-shrink:0;border:1px solid rgba(201,168,76,.3);background:transparent;display:flex;align-items:center;justify-content:center;transition:all .2s}
.fc-box.on{background:var(--gold);border-color:var(--gold)}
.fc-box.on::after{content:'';width:6px;height:4px;border-left:1.5px solid var(--black);border-bottom:1.5px solid var(--black);transform:rotate(-45deg) translateY(-1px);display:block}
.fc-label{font-size:11px;font-weight:200;letter-spacing:1px;color:rgba(250,248,242,.45);flex:1;transition:color .2s}
.fc-item:hover .fc-label{color:rgba(250,248,242,.75)}

/* Price range */
.price-inputs{display:flex;gap:7px;align-items:center;margin-top:6px}
.price-in{flex:1;padding:7px 9px;background:var(--dark2);border:1px solid var(--border);font-size:10px;font-family:var(--font-b);font-weight:200;color:var(--white);outline:none;transition:border-color .2s}
.price-in:focus{border-color:var(--gold)}
.price-sep{font-size:10px;color:rgba(250,248,242,.25)}

/* Size grid */
.size-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-top:7px}
.sz-btn{padding:6px 4px;border:1px solid var(--border);font-size:8px;letter-spacing:1px;text-align:center;background:transparent;color:rgba(250,248,242,.35);transition:all .2s;font-family:var(--font-b)}
.sz-btn:hover,.sz-btn.on{background:var(--gold);color:var(--black);border-color:var(--gold)}

/* Season */
.season-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:7px}
.season-btn{
  padding:8px 6px;border:1px solid var(--border);
  font-size:8px;letter-spacing:1.5px;text-transform:uppercase;
  text-align:center;background:transparent;color:rgba(250,248,242,.35);
  transition:all .2s;font-family:var(--font-b);
  display:flex;align-items:center;justify-content:center;gap:5px;
}
.season-btn:hover,.season-btn.on{background:rgba(201,168,76,.12);color:var(--gold);border-color:rgba(201,168,76,.45)}
.season-btn svg{width:11px;height:11px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;flex-shrink:0}

.btn-apply{width:100%;padding:10px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:8px;letter-spacing:3px;text-transform:uppercase;border:none;font-family:var(--font-b);margin-top:6px;transition:opacity .2s}
.btn-apply:hover{opacity:.85}
.btn-reset{width:100%;padding:8px;background:transparent;color:rgba(250,248,242,.25);font-size:8px;letter-spacing:2px;text-transform:uppercase;border:1px solid var(--border);font-family:var(--font-b);margin-top:5px;transition:all .2s}
.btn-reset:hover{border-color:var(--gold);color:var(--gold)}

/* MAIN */
.shop-main{flex:1;padding:22px 34px}
.toolbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.result-info{font-size:10px;letter-spacing:1.5px;color:rgba(250,248,242,.28)}
.result-info strong{color:var(--gold)}
.toolbar-right{display:flex;align-items:center;gap:14px}
.sort-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(250,248,242,.28)}
.sort-sel{padding:7px 12px;border:1px solid var(--border);background:var(--dark2);font-size:9px;letter-spacing:1px;font-family:var(--font-b);color:var(--white);outline:none}
.sort-sel:focus{border-color:var(--gold)}

/* Bulk add to cart */
.bulk-bar{
  display:none;align-items:center;justify-content:space-between;
  padding:12px 16px;background:rgba(201,168,76,.08);
  border:1px solid rgba(201,168,76,.3);margin-bottom:14px;
}
.bulk-bar.show{display:flex}
.bulk-info{font-size:10px;letter-spacing:1.5px;color:var(--gold)}
.btn-bulk-cart{padding:8px 22px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:8px;letter-spacing:2.5px;text-transform:uppercase;border:none;font-family:var(--font-b);transition:opacity .2s;display:flex;align-items:center;gap:8px}
.btn-bulk-cart:hover{opacity:.85}
.btn-bulk-cart svg{width:13px;height:13px;fill:none;stroke:var(--black);stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}

/* GRID */
.products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:40px}
.pcard{background:var(--dark2);position:relative;overflow:hidden;transition:transform .4s cubic-bezier(.16,1,.3,1)}
.pcard:hover{transform:translateY(-5px);z-index:2;box-shadow:0 20px 50px rgba(0,0,0,.5)}
.pcard:hover .pquick{opacity:1;transform:translateY(0)}
.pcard:hover .pimg-inner{transform:scale(1.05)}
.pthumb{aspect-ratio:3/4;position:relative;overflow:hidden}
.pimg-inner{width:100%;height:100%;transition:transform .6s cubic-bezier(.16,1,.3,1)}
.pimg-inner img{filter:brightness(.82) contrast(1.04)}
.pcard:hover .pimg-inner img{filter:brightness(.9)}

/* Checkbox select */
.pcheck-wrap{
  position:absolute;top:12px;left:12px;z-index:3;
  width:22px;height:22px;
  border:1.5px solid rgba(250,248,242,.4);
  background:rgba(5,4,2,.55);
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;
}
.pcheck-wrap.checked{background:var(--gold);border-color:var(--gold)}
.pcheck-wrap.checked::after{content:'';width:10px;height:7px;border-left:2px solid var(--black);border-bottom:2px solid var(--black);transform:rotate(-45deg) translateY(-1px);display:block}
.pcard:not(:hover) .pcheck-wrap:not(.checked){opacity:0}
.pcard:hover .pcheck-wrap{opacity:1}

.pbadge{position:absolute;top:12px;right:12px;padding:3px 9px;font-size:7px;letter-spacing:2px;text-transform:uppercase;font-family:var(--font-b);z-index:2}
.badge-new{background:var(--gold);color:var(--black)}
.badge-sale{background:transparent;border:1px solid var(--gold);color:var(--gold)}

.pquick{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:7px;letter-spacing:3px;text-transform:uppercase;padding:11px;text-align:center;opacity:0;transform:translateY(6px);transition:all .3s;z-index:2;display:flex;align-items:center;justify-content:center;gap:7px}
.pquick svg{width:11px;height:11px;fill:none;stroke:var(--black);stroke-width:1.8;stroke-linecap:round}

.pinfo{padding:13px 15px 16px;border-top:1px solid var(--border)}
.pcat{font-size:7px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.58);margin-bottom:4px}
.pname{font-family:var(--font-a);font-size:14px;font-style:italic;color:var(--white);margin-bottom:7px}
.price-row{display:flex;align-items:baseline;gap:8px}
.price{font-size:13px;font-weight:300;letter-spacing:.5px}
.price-old{font-size:10px;color:rgba(250,248,242,.22);text-decoration:line-through}
.szrow{display:flex;gap:3px;margin-top:6px}
.s{font-size:7px;letter-spacing:1px;padding:2px 5px;border:1px solid rgba(201,168,76,.13);color:rgba(250,248,242,.25)}

/* Empty */
.empty-state{grid-column:1/-1;text-align:center;padding:80px 20px;color:rgba(250,248,242,.2)}
.empty-state svg{width:48px;height:48px;fill:none;stroke:rgba(201,168,76,.2);stroke-width:1;stroke-linecap:round;margin:0 auto 16px;display:block}
.empty-state p{font-size:12px;letter-spacing:1.5px}

/* PAGINATION */
.pagination{display:flex;justify-content:center;gap:3px;margin-bottom:48px}
.ppage{width:34px;height:34px;display:flex;align-items:center;justify-content:center;font-size:10px;letter-spacing:1px;border:1px solid var(--border);background:transparent;color:rgba(250,248,242,.32);transition:all .2s;font-family:var(--font-b)}
.ppage:hover,.ppage.on{background:var(--gold);color:var(--black);border-color:var(--gold)}

/* TOAST */
.toast{position:fixed;bottom:28px;right:28px;z-index:9000;padding:11px 20px;font-size:10px;letter-spacing:1.5px;border:1px solid;display:none}
.toast.ok{background:rgba(90,154,90,.12);border-color:rgba(90,154,90,.4);color:#7aba7a}
.toast.info{background:rgba(201,168,76,.08);border-color:rgba(201,168,76,.28);color:var(--gold)}

/* MODAL */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:200;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .35s;backdrop-filter:blur(10px)}
.mo.open{opacity:1;pointer-events:all}
.modal{background:var(--dark);width:92%;max-width:880px;display:grid;grid-template-columns:1fr 1fr;max-height:90vh;overflow:hidden;border:1px solid var(--border);transform:translateY(20px);transition:transform .35s cubic-bezier(.16,1,.3,1)}
.mo.open .modal{transform:translateY(0)}
.mgallery{position:relative;background:var(--dark2);min-height:460px;overflow:hidden}
.mgallery img{width:100%;height:100%;object-fit:cover;filter:brightness(.84)}
.mclose{position:absolute;top:13px;right:13px;width:32px;height:32px;border:1px solid rgba(250,248,242,.18);background:rgba(5,4,2,.65);display:flex;align-items:center;justify-content:center;z-index:5;transition:border-color .2s}
.mclose:hover{border-color:var(--gold)}
.mclose svg{width:13px;height:13px;fill:none;stroke:rgba(250,248,242,.65);stroke-width:1.8;stroke-linecap:round}
.minfo{padding:32px 28px;overflow-y:auto;max-height:90vh}
.minfo::-webkit-scrollbar{width:2px}.minfo::-webkit-scrollbar-thumb{background:var(--border)}
.m-cat{font-size:7px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.62);margin-bottom:9px}
.m-name{font-family:var(--font-d);font-size:28px;font-weight:400;font-style:italic;line-height:1.1;margin-bottom:12px}
.m-prow{display:flex;align-items:baseline;gap:11px;margin-bottom:4px}
.m-price{font-size:20px;font-weight:300;letter-spacing:.5px}
.m-old{font-size:13px;color:rgba(250,248,242,.22);text-decoration:line-through}
.m-div{border:none;border-top:1px solid var(--border);margin:18px 0;position:relative}
.m-div::after{content:'◆';position:absolute;top:-8px;left:50%;transform:translateX(-50%);font-size:8px;color:var(--gold);background:var(--dark);padding:0 8px}
.m-lbl{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:rgba(250,248,242,.32);margin-bottom:9px}
.m-sizes{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:18px}
.msz{min-width:40px;padding:7px 9px;border:1px solid var(--border);font-size:9px;letter-spacing:1px;text-align:center;background:transparent;color:rgba(250,248,242,.42);font-family:var(--font-b);transition:all .2s}
.msz:hover,.msz.on{background:var(--gold);color:var(--black);border-color:var(--gold)}
.m-colors{display:flex;gap:9px;margin-bottom:18px}
.mc-item{display:flex;flex-direction:column;align-items:center;gap:4px}
.mc-circle{width:26px;height:26px;border-radius:50%;border:2px solid transparent;transition:border-color .2s}
.mc-item.on .mc-circle{border-color:var(--gold)}
.mc-name{font-size:7px;color:rgba(250,248,242,.28);letter-spacing:1px}
.m-qty{display:flex;align-items:center;gap:7px;margin-bottom:18px}
.qbtn{width:32px;height:32px;border:1px solid var(--border);background:transparent;color:var(--white);font-size:15px;display:flex;align-items:center;justify-content:center;transition:border-color .2s}
.qbtn:hover{border-color:var(--gold)}
.qval{width:44px;height:32px;border:1px solid var(--border);background:var(--dark2);text-align:center;font-size:12px;font-family:var(--font-b);color:var(--white);outline:none}
.btn-cart{width:100%;padding:13px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:8px;letter-spacing:3px;text-transform:uppercase;border:none;font-family:var(--font-b);margin-bottom:0;transition:opacity .2s;display:flex;align-items:center;justify-content:center;gap:9px}
.btn-cart:hover{opacity:.88}
.btn-cart svg{width:13px;height:13px;fill:none;stroke:var(--black);stroke-width:1.8;stroke-linecap:round}
.m-desc{font-size:11px;font-weight:200;letter-spacing:.5px;color:rgba(250,248,242,.32);line-height:1.9;margin-top:16px}
</style>
</head>
<body>
<div class="toast" id="toast"></div>

<nav>
  <div class="nav-logo">
    <a href="/">NEVA</a>
    <span class="nav-logo-sep">|</span>
  </div>
  <div class="nav-mid">
    <a href="/Product" class="nl active">Bộ sưu tập</a>
    <span class="nd">|</span>
    <a href="/" class="nl">Haute Couture</a>
    <span class="nd">|</span>
    <a href="/Account/Login" class="nl" id="navAccount">Tài khoản</a>
  </div>
  <div class="nav-right">
    <div class="nav-search">
      <input type="text" id="searchInput" placeholder="Tìm sản phẩm..." oninput="applyFilters()">
      <button class="nav-search-btn" onclick="applyFilters()">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
      </button>
    </div>
    <a href="/Account/Profile" class="ni"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></a>
    <a href="/Cart" class="ni"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg></a>
  </div>
</nav>

<div class="page-banner">
  <div class="pb-bg">NEVA</div>
  <div class="breadcrumb"><a href="/">Trang chủ</a><span>›</span><span style="color:var(--gold)">Bộ sưu tập</span></div>
  <h1 class="page-title">Tất cả <em>sản phẩm</em></h1>
</div>

<div class="shop-layout">
  <aside class="sidebar">
    <div class="filter-hdr">
      <svg viewBox="0 0 24 24"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="12" y1="18" x2="12" y2="18"/></svg>
      Bộ lọc
    </div>

    <!-- Danh mục — không có số -->
    <div class="fg">
      <div class="fg-title">Danh mục</div>
      <div class="fc-item" data-cat="Đầm"><div class="fc-box on"></div><label class="fc-label">Đầm & Váy</label></div>
      <div class="fc-item" data-cat="Áo blouse"><div class="fc-box"></div><label class="fc-label">Áo blouse</label></div>
      <div class="fc-item" data-cat="Áo khoác"><div class="fc-box"></div><label class="fc-label">Áo khoác</label></div>
      <div class="fc-item" data-cat="Quần"><div class="fc-box"></div><label class="fc-label">Quần</label></div>
      <div class="fc-item" data-cat="Bộ suit"><div class="fc-box"></div><label class="fc-label">Bộ suit</label></div>
    </div>

    <!-- Mùa -->
    <div class="fg">
      <div class="fg-title">Mùa</div>
      <div class="season-grid">
        <div class="season-btn" data-season="Xuân">
          <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 1 0 20"/><path d="M12 8c-2 2-2 5 0 7"/><path d="M8 6c0 3 2 5 4 6"/></svg>
          Xuân
        </div>
        <div class="season-btn" data-season="Hè">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          Hè
        </div>
        <div class="season-btn" data-season="Thu">
          <svg viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          Thu
        </div>
        <div class="season-btn" data-season="Đông">
          <svg viewBox="0 0 24 24"><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/><path d="M20 16l-4-4 4-4"/><path d="M4 8l4 4-4 4"/><path d="M16 4l-4 4-4-4"/><path d="M8 20l4-4 4 4"/></svg>
          Đông
        </div>
      </div>
    </div>

    <!-- Giá -->
    <div class="fg">
      <div class="fg-title">Khoảng giá</div>
      <div class="price-inputs">
        <input class="price-in" type="number" id="priceMin" value="0" placeholder="Từ">
        <span class="price-sep">—</span>
        <input class="price-in" type="number" id="priceMax" value="5000000" placeholder="Đến">
      </div>
    </div>

    <!-- Size -->
    <div class="fg">
      <div class="fg-title">Size</div>
      <div class="size-grid">
        <div class="sz-btn" data-size="XS">XS</div>
        <div class="sz-btn on" data-size="S">S</div>
        <div class="sz-btn on" data-size="M">M</div>
        <div class="sz-btn" data-size="L">L</div>
        <div class="sz-btn" data-size="XL">XL</div>
        <div class="sz-btn" data-size="28">28</div>
        <div class="sz-btn" data-size="30">30</div>
        <div class="sz-btn" data-size="32">32</div>
      </div>
    </div>

    <button class="btn-apply" onclick="applyFilters()">Áp dụng bộ lọc</button>
    <button class="btn-reset" onclick="resetFilters()">Xóa tất cả</button>
  </aside>

  <main class="shop-main">
    <div class="toolbar">
      <div class="result-info">Hiển thị <strong id="countDisplay">0</strong> sản phẩm</div>
      <div class="toolbar-right">
        <span class="sort-label">Sắp xếp</span>
        <select class="sort-sel" id="sortSel" onchange="applySort()">
          <option value="newest">Mới nhất</option>
          <option value="price_asc">Giá: Thấp → Cao</option>
          <option value="price_desc">Giá: Cao → Thấp</option>
          <option value="popular">Bán chạy nhất</option>
        </select>
      </div>
    </div>

    <!-- Bulk cart bar -->
    <div class="bulk-bar" id="bulkBar">
      <span class="bulk-info" id="bulkInfo">0 sản phẩm được chọn</span>
      <button class="btn-bulk-cart" onclick="addSelectedToCart()">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Thêm vào giỏ hàng
      </button>
    </div>

    <div class="products-grid" id="productGrid"></div>
    <div class="pagination" id="pagination"></div>
  </main>
</div>

<!-- MODAL -->
<div class="mo" id="mo" onclick="if(event.target===this)closeMo()">
  <div class="modal">
    <div class="mgallery">
      <img id="mImg" src="" alt="">
      <div class="mclose" onclick="closeMo()">
        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </div>
    </div>
    <div class="minfo">
      <div class="m-cat" id="mCat"></div>
      <div class="m-name" id="mName"></div>
      <div class="m-prow"><span class="m-price" id="mPrice"></span><span class="m-old" id="mOld"></span></div>
      <hr class="m-div">
      <div class="m-lbl">Màu sắc</div>
      <div class="m-colors" id="mColors"></div>
      <div class="m-lbl">Chọn size</div>
      <div class="m-sizes" id="mSizes"></div>
      <div class="m-lbl">Số lượng</div>
      <div class="m-qty">
        <button class="qbtn" onclick="chQty(-1)">−</button>
        <input class="qval" type="number" value="1" min="1" id="qtyIn">
        <button class="qbtn" onclick="chQty(1)">+</button>
      </div>
      <button class="btn-cart" onclick="addCart()">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Thêm vào giỏ hàng
      </button>
      <p class="m-desc" id="mDesc"></p>
    </div>
  </div>
</div>

<script>
function toast(m,t='ok'){const el=document.getElementById('toast');el.textContent=m;el.className='toast '+t;el.style.display='block';setTimeout(()=>el.style.display='none',2500)}

const ALL=[
  {id:1,cat:'Đầm',name:'Đầm dạ hội ren thêu',price:3850000,old:0,badge:'new',pop:95,season:'Đông',
   img:'https://images.unsplash.com/photo-1601924994987-69e26d50dc26?w=600&q=85',
   sizes:['XS','S','M','L'],colors:[{c:'#1a1a1a',n:'Đen'},{c:'#d4a535',n:'Vàng'}],
   desc:'Đầm dạ hội thêu ren tinh xảo. Chất liệu lụa cao cấp, đường may tỉ mỉ từng chi tiết.'},
  {id:2,cat:'Đầm',name:'Váy midi dáng A-line',price:1650000,old:0,badge:'',pop:88,season:'Xuân',
   img:'https://images.unsplash.com/photo-1515372039744-b8f02a3ae446?w=600&q=85',
   sizes:['XS','S','M','L','XL'],colors:[{c:'#f5f0e8',n:'Kem'},{c:'#1a1a1a',n:'Đen'}],
   desc:'Váy midi dáng A-line thanh lịch, phù hợp cho các buổi tiệc và sự kiện sang trọng.'},
  {id:3,cat:'Áo khoác',name:'Áo khoác blazer linen',price:2250000,old:2800000,badge:'sale',pop:76,season:'Thu',
   img:'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?w=600&q=85',
   sizes:['S','M','L','XL'],colors:[{c:'#3d3530',n:'Nâu'},{c:'#1a1a1a',n:'Đen'}],
   desc:'Blazer linen cao cấp dáng structured. Phong cách tối giản sang trọng, dễ phối đồ.'},
  {id:4,cat:'Áo blouse',name:'Áo blouse lụa cổ V',price:980000,old:0,badge:'new',pop:82,season:'Hè',
   img:'https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?w=600&q=85',
   sizes:['XS','S','M','L'],colors:[{c:'#f5f0e8',n:'Kem'},{c:'#c9a84c',n:'Vàng'}],
   desc:'Áo blouse lụa mềm mại, cổ chữ V thanh lịch. Chất liệu thoáng mát, dễ mặc.'},
  {id:5,cat:'Quần',name:'Quần wide-leg linen',price:1350000,old:0,badge:'',pop:71,season:'Hè',
   img:'https://images.unsplash.com/photo-1506629082955-511b1aa562c8?w=600&q=85',
   sizes:['XS','S','M','L','XL'],colors:[{c:'#f5f0e8',n:'Kem'},{c:'#1a1a1a',n:'Đen'}],
   desc:'Quần ống rộng chất linen cao cấp. Dáng suông thoải mái, phù hợp mọi vóc dáng.'},
  {id:6,cat:'Đầm',name:'Đầm xẻ tà tối giản',price:2100000,old:2600000,badge:'sale',pop:90,season:'Thu',
   img:'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=600&q=85',
   sizes:['XS','S','M'],colors:[{c:'#1a1a1a',n:'Đen'},{c:'#3d3530',n:'Nâu'}],
   desc:'Đầm xẻ tà dáng maxi tinh tế. Thiết kế tối giản nhưng đầy sức hút.'},
  {id:7,cat:'Áo khoác',name:'Áo khoác dạ tweed',price:3200000,old:0,badge:'new',pop:65,season:'Đông',
   img:'https://images.unsplash.com/photo-1548624313-0396c75e4b1a?w=600&q=85',
   sizes:['S','M','L'],colors:[{c:'#6b4c3b',n:'Caramel'},{c:'#1a1a1a',n:'Đen'}],
   desc:'Áo khoác dạ tweed cao cấp. Thiết kế cổ điển sang trọng, giữ ấm hoàn hảo.'},
  {id:8,cat:'Bộ suit',name:'Bộ suit vest nữ tính',price:4500000,old:0,badge:'',pop:60,season:'Thu',
   img:'https://images.unsplash.com/photo-1632149877166-f75d49000351?w=600&q=85',
   sizes:['XS','S','M','L'],colors:[{c:'#f5f0e8',n:'Kem'},{c:'#1a1a1a',n:'Đen'}],
   desc:'Bộ suit vest nữ tính với thiết kế tinh tế. Chất vải cao cấp, đường may sắc sảo.'},
  {id:9,cat:'Đầm',name:'Đầm cocktail vai trần',price:1890000,old:0,badge:'new',pop:85,season:'Xuân',
   img:'https://images.unsplash.com/photo-1502716119720-b23a93e5fe1b?w=600&q=85',
   sizes:['XS','S','M','L'],colors:[{c:'#1a1a1a',n:'Đen'},{c:'#d4a535',n:'Vàng'}],
   desc:'Đầm cocktail vai trần thanh lịch. Phù hợp cho các buổi tiệc tối và sự kiện đặc biệt.'},
  {id:10,cat:'Áo blouse',name:'Áo blouse cổ nơ lụa',price:1150000,old:1400000,badge:'sale',pop:74,season:'Xuân',
   img:'https://images.unsplash.com/photo-1503342394128-c104d54dba01?w=600&q=85',
   sizes:['XS','S','M','L'],colors:[{c:'#f5f0e8',n:'Kem'},{c:'#1a1a1a',n:'Đen'}],
   desc:'Áo blouse cổ nơ lụa cao cấp. Nữ tính, thanh lịch, phù hợp công sở và tiệc nhỏ.'},
  {id:11,cat:'Quần',name:'Quần culottes cao cấp',price:1480000,old:0,badge:'new',pop:68,season:'Hè',
   img:'https://images.unsplash.com/photo-1509631179647-0177331693ae?w=600&q=85',
   sizes:['XS','S','M','L','XL'],colors:[{c:'#1a1a1a',n:'Đen'},{c:'#f5f0e8',n:'Kem'}],
   desc:'Quần culottes dáng rộng sang trọng. Chất liệu lụa nhẹ, thoáng mát, dễ di chuyển.'},
  {id:12,cat:'Bộ suit',name:'Co-ord set linen cao cấp',price:3600000,old:4200000,badge:'sale',pop:78,season:'Hè',
   img:'https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=600&q=85',
   sizes:['XS','S','M','L'],colors:[{c:'#f5f0e8',n:'Kem'},{c:'#6b4c3b',n:'Caramel'}],
   desc:'Bộ co-ord set linen cao cấp gồm áo và quần. Thanh lịch, tối giản, dễ mặc mọi dịp.'},
];

const PER_PAGE=9;
let filtered=[...ALL];
let currentPage=1;
let selected=new Set();
let currentModalId=null;

function fmt(n){return n.toLocaleString('vi-VN')+'đ'}

// Checkbox select
function toggleSelect(id){
  if(selected.has(id)) selected.delete(id);
  else selected.add(id);
  updateBulkBar();
  renderGrid();
}
function updateBulkBar(){
  const bar=document.getElementById('bulkBar');
  const info=document.getElementById('bulkInfo');
  if(selected.size>0){
    bar.classList.add('show');
    info.textContent=selected.size+' sản phẩm được chọn';
  } else {
    bar.classList.remove('show');
  }
}
function addSelectedToCart(){
  toast(`✦ Đã thêm ${selected.size} sản phẩm vào giỏ hàng!`,'info');
  selected.clear();
  updateBulkBar();
  renderGrid();
}

function renderGrid(){
  const start=(currentPage-1)*PER_PAGE;
  const page=filtered.slice(start,start+PER_PAGE);
  document.getElementById('countDisplay').textContent=filtered.length;
  const grid=document.getElementById('productGrid');
  if(!page.length){
    grid.innerHTML=`<div class="empty-state"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg><p>Không tìm thấy sản phẩm phù hợp</p></div>`;
    document.getElementById('pagination').innerHTML='';
    return;
  }
  grid.innerHTML=page.map(p=>`
    <div class="pcard">
      <div class="pthumb">
        <div class="pimg-inner">
          <img src="${p.img}" alt="${p.name}" loading="lazy"
            onerror="this.parentElement.style.background='#14100a';this.style.display='none'">
        </div>
        <div class="pcheck-wrap ${selected.has(p.id)?'checked':''}"
          onclick="event.stopPropagation();toggleSelect(${p.id})"></div>
        ${p.badge?`<span class="pbadge badge-${p.badge}">${p.badge==='new'?'Mới':'Sale'}</span>`:''}
        <div class="pquick" onclick="openModal(${p.id})">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/></svg>
          Xem nhanh
        </div>
      </div>
      <div class="pinfo">
        <div class="pcat">${p.cat} · ${p.season}</div>
        <div class="pname">${p.name}</div>
        <div class="price-row">
          <span class="price">${fmt(p.price)}</span>
          ${p.old?`<span class="price-old">${fmt(p.old)}</span>`:''}
        </div>
        <div class="szrow">${p.sizes.slice(0,4).map(s=>`<span class="s">${s}</span>`).join('')}</div>
      </div>
    </div>`).join('');
  renderPagination();
}

function renderPagination(){
  const total=Math.ceil(filtered.length/PER_PAGE);
  if(total<=1){document.getElementById('pagination').innerHTML='';return}
  let h='';
  if(currentPage>1) h+=`<div class="ppage" onclick="goPage(${currentPage-1})">‹</div>`;
  for(let i=1;i<=total;i++) h+=`<div class="ppage ${i===currentPage?'on':''}" onclick="goPage(${i})">${i}</div>`;
  if(currentPage<total) h+=`<div class="ppage" onclick="goPage(${currentPage+1})">›</div>`;
  document.getElementById('pagination').innerHTML=h;
}
function goPage(n){currentPage=n;renderGrid();window.scrollTo({top:0,behavior:'smooth'})}

function applyFilters(){
  const cats=[...document.querySelectorAll('.fc-item .fc-box.on')].map(b=>b.parentElement.dataset.cat).filter(Boolean);
  const seasons=[...document.querySelectorAll('.season-btn.on')].map(b=>b.dataset.season);
  const sizes=[...document.querySelectorAll('.sz-btn.on')].map(b=>b.dataset.size);
  const minP=parseInt(document.getElementById('priceMin').value)||0;
  const maxP=parseInt(document.getElementById('priceMax').value)||9999999;
  const search=document.getElementById('searchInput').value.toLowerCase().trim();
  filtered=ALL.filter(p=>{
    if(cats.length&&!cats.some(cat=>p.cat.includes(cat))) return false;
    if(seasons.length&&!seasons.includes(p.season)) return false;
    if(p.price<minP||p.price>maxP) return false;
    if(sizes.length&&!sizes.some(s=>p.sizes.includes(s))) return false;
    if(search&&!p.name.toLowerCase().includes(search)&&!p.cat.toLowerCase().includes(search)) return false;
    return true;
  });
  applySort(false);
  currentPage=1;
  renderGrid();
  if(search||cats.length||seasons.length||sizes.length) toast(`✦ Tìm thấy ${filtered.length} sản phẩm`,'info');
}

function resetFilters(){
  document.querySelectorAll('.fc-box').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.sz-btn').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.season-btn').forEach(b=>b.classList.remove('on'));
  document.getElementById('priceMin').value=0;
  document.getElementById('priceMax').value=5000000;
  document.getElementById('searchInput').value='';
  filtered=[...ALL];
  currentPage=1;
  renderGrid();
  toast('Đã xóa bộ lọc');
}

function applySort(rerender=true){
  const v=document.getElementById('sortSel').value;
  if(v==='price_asc') filtered.sort((a,b)=>a.price-b.price);
  else if(v==='price_desc') filtered.sort((a,b)=>b.price-a.price);
  else if(v==='popular') filtered.sort((a,b)=>b.pop-a.pop);
  else filtered.sort((a,b)=>b.id-a.id);
  if(rerender){currentPage=1;renderGrid()}
}

// Filter interactions
document.querySelectorAll('.fc-item').forEach(item=>{
  item.addEventListener('click',()=>item.querySelector('.fc-box').classList.toggle('on'));
});
document.querySelectorAll('.sz-btn').forEach(b=>b.addEventListener('click',()=>b.classList.toggle('on')));
document.querySelectorAll('.season-btn').forEach(b=>b.addEventListener('click',()=>b.classList.toggle('on')));

// Modal
function openModal(id){
  const p=ALL.find(x=>x.id===id);
  currentModalId=id;
  document.getElementById('mImg').src=p.img;
  document.getElementById('mCat').textContent=p.cat+' · '+p.season;
  document.getElementById('mName').textContent=p.name;
  document.getElementById('mPrice').textContent=fmt(p.price);
  document.getElementById('mOld').textContent=p.old?fmt(p.old):'';
  document.getElementById('mDesc').textContent=p.desc;
  document.getElementById('mColors').innerHTML=p.colors.map((cl,i)=>`
    <div class="mc-item ${i===0?'on':''}" onclick="selColor(this)">
      <div class="mc-circle" style="background:${cl.c};${cl.c==='#f5f0e8'?'box-shadow:inset 0 0 0 1px rgba(0,0,0,.12)':''}"></div>
      <span class="mc-name">${cl.n}</span>
    </div>`).join('');
  document.getElementById('mSizes').innerHTML=p.sizes.map((s,i)=>`
    <div class="msz ${i===1?'on':''}" onclick="selSize(this)">${s}</div>`).join('');
  document.getElementById('mo').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeMo(){document.getElementById('mo').classList.remove('open');document.body.style.overflow=''}
function selSize(el){document.querySelectorAll('.msz').forEach(s=>s.classList.remove('on'));el.classList.add('on')}
function selColor(el){document.querySelectorAll('.mc-item').forEach(s=>s.classList.remove('on'));el.classList.add('on')}
function chQty(d){const i=document.getElementById('qtyIn');let v=parseInt(i.value)+d;if(v<1)v=1;i.value=v}
function addCart(){
  const sz=document.querySelector('.msz.on');
  if(!sz){toast('Vui lòng chọn size!','info');return}
  const qty=parseInt(document.getElementById('qtyIn').value)||1;
  closeMo();
  toast(`✦ Đã thêm ${qty} sản phẩm vào giỏ hàng!`,'ok');
}

renderGrid();
</script>
</body>
</html>