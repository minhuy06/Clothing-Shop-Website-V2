<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — NEVA</title>

    <!-- Base CSS -->
    <link rel="stylesheet" href="~/css/neva-base.css" asp-append-version="true" />

    <!-- CSS riêng của từng trang -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Toast chung -->
    <div class="neva-toast" id="nevaToast"></div>

    <!-- ── NAV ── -->
    <nav class="neva-nav">
        <!-- Logo trái -->
        <div class="nav-logo">
            <a asp-controller="Home" asp-action="Index">NEVA</a>
            <span class="nav-logo-sep">|</span>
        </div>

        <!-- Links giữa -->
        <div class="nav-mid">
            <a asp-controller="Product" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                Bộ sưu tập
            </a>
            <span class="nav-divider">|</span>
            <a asp-controller="Home" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                Haute Couture
            </a>
            <span class="nav-divider">|</span>
            <a asp-controller="Account" asp-action="@(User.Identity!.IsAuthenticated ? "Profile" : "Login")"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" ? "active" : "")">
                Tài khoản
            </a>
        </div>

        <!-- Icons phải -->
        <div class="nav-right">
            <!-- Giỏ hàng -->
            <a asp-controller="Cart" asp-action="Index"
                   class="nav-icon @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cart" ? "active" : "")"
                   data-page="cart">
                <svg viewBox="0 0 24 24">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 01-8 0" />
                </svg>
            </a>
            <!-- Tài khoản -->
            <a asp-controller="Account" asp-action="@(User.Identity!.IsAuthenticated ? "Profile" : "Login")"
                   class="nav-icon @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" ? "active" : "")"
                   data-page="account">
                <svg viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </a>
        </div>
    </nav>

    <!-- ── NỘI DUNG TRANG ── -->
    <main>
        @RenderBody()
    </main>

    <!-- ── FOOTER ── -->
    <footer class="neva-footer">
        <div class="footer-line"></div>
        <div class="footer-grid">
            <div>
                <span class="footer-logo">NEVA</span>
                <p class="footer-tagline">
                    Nghệ thuật thời trang. Mỗi sản phẩm là một tác phẩm được tạo ra để tồn tại vượt thời gian.
                </p>
            </div>
            <div class="footer-col">
                <div class="footer-col-title">Khám phá</div>
                <a asp-controller="Product" asp-action="Index">Bộ sưu tập mới</a>
                <a asp-controller="Home" asp-action="Index">Haute Couture</a>
                <a href="#">Nam</a>
                <a href="#">Nữ</a>
            </div>
            <div class="footer-col">
                <div class="footer-col-title">Hỗ trợ</div>
                <a href="#">Hướng dẫn size</a>
                <a href="#">Chính sách đổi trả</a>
                <a asp-controller="Order" asp-action="History">Theo dõi đơn hàng</a>
                <a href="#">Liên hệ</a>
            </div>
            <div class="footer-col">
                <div class="footer-col-title">Theo dõi</div>
                <a href="#">Instagram</a>
                <a href="#">TikTok</a>
                <a href="#">Facebook</a>
                <a href="#">Pinterest</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© 2025 NEVA Fashion House. All rights reserved.</span>
            <span>Da Nang · Vietnam</span>
        </div>
    </footer>

    <!-- Base JS -->
    <script src="~/js/neva-base.js" asp-append-version="true"></script>

    <!-- JS riêng của từng trang -->
    @await RenderSectionAsync("Scripts", required: false)

