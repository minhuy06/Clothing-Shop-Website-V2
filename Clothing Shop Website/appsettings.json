{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost; Database=ClothingShopWebsiteDB; Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Cube": {
    "ConnectionString": "Provider=MSOLAP;Data Source=localhost;Catalog=ClothingShop_Cube;",
    "CubeName": "ClothingShop_Cube",
    "MeasureTotalRevenue": "[Measures].[Total Revenue]",
    "MeasureQuantity": "[Measures].[Quantity]",
    "MeasureFactSalesCount": "[Measures].[Fact Sales Count]",
    "HierarchySourceProductId": "[Dim Product].[Source Product ID].[Source Product ID]",
    "HierarchyCategoryName": "[Dim Product].[Category Name].[Category Name]",
    "HierarchySeason": "[Dim Product].[Season].[Season]",
    "HierarchyAgeGroup": "[Dim Customer].[Age Group].[Age Group]",
    "HierarchyFullDate": "[Dim Time].[Full Date].[Full Date]",
    "HierarchyCustomerKey": "[Dim Customer].[Customer Key].[Customer Key]"
  }
}