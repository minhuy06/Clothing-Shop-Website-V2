@model List<Clothing_Shop_Website.Models.Advertisement>

@using Clothing_Shop_Website.Helper

@{

    ViewData["Title"] = "Quảng cáo";

    Layout = null;

    string PosLabel(string p) => p switch { "popup" => "Popup", "sidebar" => "Sidebar", _ => p };

    string DiscLabel(Advertisement ad)

    {

        if (ad.DiscountValue <= 0) return "";

        return ad.DiscountType == 1

            ? $"Giảm {ad.DiscountValue:0.##}%"

            : $"Giảm {ad.DiscountValue:N0}đ";

    }

}

<!DOCTYPE html>

<html lang="vi">

<head>

<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">

<title>NEVA Admin — Quảng cáo</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Josefin+Sans:wght@200;300;400&display=swap" rel="stylesheet">

<link rel="stylesheet" href="~/css/neva-base.css" asp-append-version="true"/>

<link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true"/>

<link rel="stylesheet" href="~/css/admin-staff.css" asp-append-version="true"/>

<link rel="stylesheet" href="~/css/admin-ads.css" asp-append-version="true"/>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

</head>

<body>

<div class="toast" id="toast"></div>

<nav class="admin-nav">

    <a asp-controller="Home" asp-action="Index" class="admin-nav-logo">NEVA</a><span class="admin-nav-sep">|</span><span class="admin-nav-badge">Admin</span>

</nav>

<div class="admin-wrap">

    <aside class="admin-sidebar">

        <div class="sb-section">

            <div class="sb-lbl">Quản lý</div>

            <a asp-controller="Admin" asp-action="Dashboard" class="sitem"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>

            <a asp-controller="Admin" asp-action="Products" class="sitem"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Sản phẩm</a>

            <a asp-controller="Admin" asp-action="Staff" class="sitem"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Nhân viên</a>

            <a asp-controller="Admin" asp-action="Advertisements" class="sitem active"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Quảng cáo</a>

        </div>

        <div class="sb-section" style="margin-top:12px">

            <a asp-controller="Account" asp-action="Logout" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Đăng xuất</a>

        </div>

    </aside>

    <main class="admin-main">



        @if (TempData["Success"] != null)

        {

            <div style="padding:10px 16px;background:rgba(90,154,90,.1);border:1px solid rgba(90,154,90,.3);color:#7aba7a;font-size:11px;margin-bottom:16px">✦ @TempData["Success"]</div>

        }

        @if (TempData["Error"] != null)

        {

            <div style="padding:10px 16px;background:rgba(180,80,80,.12);border:1px solid rgba(212,122,118,.35);color:#d4a8a4;font-size:11px;margin-bottom:16px">@TempData["Error"]</div>

        }



        <div class="ads-page-hdr">

            <div>

                <div class="page-title">Quảng cáo</div>

                <div class="page-sub">Quản lý <strong style="color:var(--gold)">@Model.Count</strong> quảng cáo · Popup &amp; sidebar trên shop</div>

            </div>

            <button type="button" class="btn-add" id="btnOpenAddAd">

                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>

                Thêm quảng cáo

            </button>

        </div>



        @if (Model.Count == 0)

        {

            <div class="ads-empty">

                <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>

                <div style="font-size:14px;margin-bottom:6px;color:rgba(250,248,242,.5)">Chưa có quảng cáo</div>

                <div style="font-size:10px;letter-spacing:1.5px;color:rgba(250,248,242,.28)">Bấm nút vàng bên trên để tạo chiến dịch đầu tiên</div>

            </div>

        }

        else

        {

            <div class="ads-grid">

                @foreach (var ad in Model)

                {

                    var disc = DiscLabel(ad);

                    var promoOn = AdPromotionHelper.IsPromotionActive(ad);

                    var fallbackImg = ad.Product?.ImageUrl ?? "";

                    <div class="ad-card">

                        <div class="ad-img-wrap">

                            @if (!string.IsNullOrEmpty(disc))

                            {

                                <span class="ad-discount-ribbon">@disc</span>

                            }

                            @if (!string.IsNullOrEmpty(ad.ImageUrl))

                            {

                                <img src="@ad.ImageUrl" alt="@ad.Title"

                                     data-fallback="@fallbackImg"

                                     onerror="if(this.dataset.fallback&&!this.dataset.tried){this.dataset.tried='1';this.src=this.dataset.fallback}else{this.style.display='none';this.parentElement.insertAdjacentHTML('beforeend','<div class=ad-img-placeholder style=display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:rgba(201,168,76,.4);font-size:10px;letter-spacing:1px'><span>Ảnh lỗi</span></div>')}" />

                            }

                            else if (!string.IsNullOrEmpty(fallbackImg))

                            {

                                <img src="@fallbackImg" alt="@ad.Title" />

                            }

                            else

                            {

                                <div class="ad-img-placeholder" style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:rgba(201,168,76,.35);font-size:10px;letter-spacing:1px">

                                    <span>Chưa có ảnh</span>

                                </div>

                            }

                        </div>

                        <div class="ad-body">

                            <div class="ad-title" title="@ad.Title">@ad.Title</div>

                            <div class="ad-meta">

                                <span class="ad-chip pos">@PosLabel(ad.Position)</span>

                                <span class="ad-chip @(ad.IsActive ? "on" : "off")">@(ad.IsActive ? "Đang hiện" : "Ẩn")</span>

                                @if (disc.Length > 0)

                                {

                                    <span class="ad-chip" style="color:var(--gold);border-color:rgba(201,168,76,.35)">@(promoOn ? "Đang KM" : "Hết hạn")</span>

                                }

                            </div>

                            @if (ad.Product != null)

                            {

                                var sale = AdPromotionHelper.GetSalePrice(ad.Product.Price, ad);

                                <div class="ad-product-line">

                                    SP: @ad.Product.ProductName

                                    @if (promoOn && sale < ad.Product.Price)

                                    {

                                        <span style="color:var(--gold)"> · @sale.ToString("N0")đ</span>

                                        <span style="text-decoration:line-through;opacity:.45">@ad.Product.Price.ToString("N0")đ</span>

                                    }

                                </div>

                            }

                            <div class="ad-date-line">

                                Tạo @ad.CreatedDate.ToString("dd/MM/yyyy")

                                @if (ad.StartDate.HasValue || ad.EndDate.HasValue)

                                {

                                    <span> · @(ad.StartDate?.ToString("dd/MM/yy") ?? "…") → @(ad.EndDate?.ToString("dd/MM/yy") ?? "…")</span>

                                }

                            </div>

                            <div class="ad-actions">

                                <form method="post" asp-controller="Admin" asp-action="ToggleAdActive">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="adId" value="@ad.AdID" />

                                    <button type="submit" class="ad-btn">@(ad.IsActive ? "Ẩn đi" : "Hiện lên")</button>

                                </form>

                                <form method="post" asp-controller="Admin" asp-action="DeleteAdvertisement">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="adId" value="@ad.AdID" />

                                    <button type="submit" class="ad-btn del"

                                        onclick="return confirm('Xóa quảng cáo &quot;@Html.Raw(ad.Title.Replace("\"",""))&quot;?')">Xóa</button>

                                </form>

                            </div>

                        </div>

                    </div>

                }

            </div>

        }

    </main>

</div>



<!-- Modal tạo quảng cáo -->

<div id="addAdMo" class="ads-modal-overlay" aria-hidden="true">

    <div class="ads-modal" role="dialog" aria-labelledby="addAdTitle">

        <div class="ads-modal-hdr">

            <div>

                <h2 id="addAdTitle">Tạo quảng cáo mới</h2>

                <p>Ảnh · sản phẩm · mức giảm · thời gian hiển thị</p>

            </div>

            <button type="button" class="ads-modal-x" data-close-ad-modal aria-label="Đóng">×</button>

        </div>

        <form method="post" asp-controller="Admin" asp-action="AddAdvertisement" enctype="multipart/form-data" id="addAdForm">

            @Html.AntiForgeryToken()

            <div class="ads-modal-body">

                <div class="ads-form-section">

                    <div class="ads-section-title">Thông tin chung</div>

                    <div class="ads-field">

                        <label for="adTitle">Tiêu đề chiến dịch</label>

                        <input type="text" id="adTitle" name="title" class="ads-inp" required maxlength="200"

                               placeholder="VD: Sale hè rực rỡ — giảm 20%" />

                    </div>

                    <input type="hidden" name="position" id="adPosition" value="popup" />

                    <div class="ads-field">

                        <label>Vị trí hiển thị</label>

                        <div class="ads-pos-grid">

                            <label class="ads-pos-card is-selected" data-pos="popup">

                                <input type="radio" name="_posUi" value="popup" checked />

                                <strong>Popup</strong>

                                <span>Hộp thoại khi vào trang chủ · tỉ lệ ảnh 4:5</span>

                            </label>

                            <label class="ads-pos-card" data-pos="sidebar">

                                <input type="radio" name="_posUi" value="sidebar" />

                                <strong>Sidebar</strong>

                                <span>Khung góc phải menu · tỉ lệ 16:10</span>

                            </label>

                        </div>

                    </div>

                </div>



                <div class="ads-form-section">

                    <div class="ads-section-title">Sản phẩm &amp; khuyến mãi</div>

                    <div class="ads-field">

                        <label for="adProductSearch">Sản phẩm được quảng cáo</label>

                        <div class="ad-product-picker">

                            <input type="text" id="adProductSearch" class="ads-inp ad-product-search"

                                   placeholder="Gõ tên hoặc mã sản phẩm..." autocomplete="off" />

                            <input type="hidden" name="productId" id="adProductId" value="" />

                            <div id="adProductResults" class="ad-product-results" hidden></div>

                            <div id="adProductSelected" class="ad-product-selected" hidden>

                                <div class="ad-product-selected-inner">

                                    <span id="adProductSelectedText"></span>

                                    <button type="button" id="adProductClear" class="ad-product-clear" title="Bỏ chọn">×</button>

                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="ads-field">

                        <label>Loại giảm giá</label>

                        <div class="ads-disc-type">

                            <label><input type="radio" name="discountType" value="1" checked /> Giảm %</label>

                            <label><input type="radio" name="discountType" value="0" /> Giảm VNĐ</label>

                        </div>

                        <div class="ads-row-2">

                            <div>

                                <label for="adDiscountValue">Mức giảm</label>

                                <div style="display:flex;align-items:stretch">

                                    <input type="number" id="adDiscountValue" name="discountValue" class="ads-inp"

                                           min="0" step="0.01" value="10" required style="flex:1;border-right:none" />

                                    <span id="adDiscountSuffix" style="display:flex;align-items:center;padding:0 12px;border:1px solid var(--border);border-left:none;background:rgba(0,0,0,.2);font-size:12px;color:var(--gold)">%</span>

                                </div>

                            </div>

                            <div></div>

                        </div>

                    </div>

                    <div class="ads-row-2">

                        <div class="ads-field">
                            <label for="adStartDate">Bắt đầu (tùy chọn)</label>
                            <div class="ads-date-wrap">
                                <input type="date" id="adStartDate" name="startDate" class="ads-inp ads-date-inp" />
                                <button type="button" class="ads-date-btn" data-date-for="adStartDate" aria-label="Mở lịch" tabindex="-1">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </button>
                            </div>
                        </div>
                        <div class="ads-field">
                            <label for="adEndDate">Kết thúc (tùy chọn)</label>
                            <div class="ads-date-wrap">
                                <input type="date" id="adEndDate" name="endDate" class="ads-inp ads-date-inp" />
                                <button type="button" class="ads-date-btn" data-date-for="adEndDate" aria-label="Mở lịch" tabindex="-1">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </button>
                            </div>
                        </div>

                    </div>

                </div>



                <div class="ads-form-section">

                    <div class="ads-section-title">Ảnh quảng cáo</div>

                    <div class="ads-dropzone" id="adDropzone">

                        <input type="file" name="imageFile" id="adImageFile" accept="image/*" hidden />

                        <span>Kéo thả hoặc bấm chọn ảnh · <em id="adCropRatioHint" style="font-style:normal;color:var(--gold)">Popup 4:5</em></span>

                    </div>

                    <div class="ads-preview-thumb" id="adImgPreview">

                        <img id="adPreviewImg" alt="Xem trước" />

                    </div>

                </div>

            </div>

            <div class="ads-modal-foot">

                <button type="button" class="ads-btn-ghost" data-close-ad-modal">Hủy</button>

                <button type="submit" class="ads-btn-submit">Đăng quảng cáo</button>

            </div>

        </form>

    </div>

</div>



<!-- Modal cắt ảnh -->
<div id="adCropMo" class="modal-overlay ad-crop-overlay">
    <div class="ad-crop-box">
        <div class="ad-crop-hdr">
            <span>Cắt ảnh quảng cáo · <em id="adCropModalHint" style="font-style:normal;opacity:.7">Popup 4:5</em></span>
            <button type="button" class="modal-x" id="adCropCancel" aria-label="Đóng">×</button>
        </div>
        <div class="ad-crop-body">
            <img id="adCropImg" alt="" />
        </div>
        <div class="ad-crop-foot">
            <button type="button" class="btn-outline" id="adCropCancel2">Hủy</button>
            <button type="button" class="ad-crop-apply" id="adCropApply">Áp dụng</button>
        </div>
    </div>
</div>



<script src="~/js/neva-base.js" asp-append-version="true"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="~/js/admin-ads.js" asp-append-version="true"></script>

<script src="~/js/admin-ad-image.js" asp-append-version="true"></script>

<script src="~/js/admin-ad-product.js" asp-append-version="true"></script>

</body>

</html>

