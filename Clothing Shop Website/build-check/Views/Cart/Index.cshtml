@model List<Clothing_Shop_Website.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    decimal subtotal = Model.Sum(c => (c.UnitPrice ?? c.ProductSize.Product.Price) * c.Quantity);
    decimal shipping = subtotal >= 500000 ? 0 : 30000;
    int rewardPoints = (int)(ViewBag.RewardPoints ?? 0);
    string savedCoupon = ViewBag.SavedCoupon as string ?? "";
    int savedUsePoints = (int)(ViewBag.SavedUsePoints ?? 0);
}
@section Styles {
    <link rel="stylesheet" href="~/css/gio-hang.css" asp-append-version="true" />
}

<div class="page-banner">
    <div class="page-banner-bg">CART</div>
    <div class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a><span>›</span>
        <span style="color:var(--gold)">Giỏ hàng</span>
    </div>
    <h1 class="page-title">Giỏ <em>hàng</em></h1>
    <p class="page-sub" id="cartSubtitle">@Model.Count sản phẩm trong giỏ</p>
</div>

<div class="cart-layout">
    <div>
        <div class="cart-box">
            <div class="select-bar">
                <span class="select-label">@Model.Count sản phẩm</span>
                @if (Model.Any())
                {
                    <form method="post" asp-controller="Cart" asp-action="Clear">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="del-selected" onclick="return confirm('Xóa tất cả?')">
                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" /></svg>
                            Xóa tất cả
                        </button>
                    </form>
                }
            </div>
            <div class="cart-head">
                <span></span><span>Sản phẩm</span><span>Đơn giá</span>
                <span>Số lượng</span><span>Tổng</span><span></span>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-cart">
                    <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 01-8 0" /></svg>
                    <p>Giỏ hàng của bạn đang trống</p>
                    <a asp-controller="Product" asp-action="Index"
                       style="display:inline-block;padding:12px 28px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--black);font-size:10px;letter-spacing:2.5px;text-transform:uppercase;font-family:var(--font-b)">
                        Khám phá sản phẩm
                    </a>
                </div>
            }

            @foreach (var item in Model)
            {
                var cartImg = ProductImageHelper.Resolve(item.ProductSize.Product.ImageUrl, item.ProductSize.Product.ProductID);
                var unit = item.UnitPrice ?? item.ProductSize.Product.Price;
                <div class="cart-row">
                    <div></div>
                    <div class="cart-product">
                        <div class="cart-thumb">
                            <img src="@cartImg" alt="@item.ProductSize.Product.ProductName"
                                 onerror="this.src='@ProductImageHelper.PlaceholderPath'">
                        </div>
                        <div>
                            <div class="cart-pname">@item.ProductSize.Product.ProductName</div>
                            <div class="cart-pmeta">
                                @item.ProductSize.Product.Category?.CategoryName
                                <span style="margin:0 6px;color:rgba(250,248,242,.2)">|</span>
                                <span style="color:var(--gold); border: 1px solid rgba(201,168,76,.3); padding: 1px 6px; border-radius: 2px; font-size: 10px;">
                                    Size: @item.ProductSize.SizeName
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="cart-price">@unit.ToString("N0")đ</div>

                    <div class="qty-row">
                        <form method="post" asp-controller="Cart" asp-action="UpdateQuantity" style="display:flex;gap:5px;align-items:center">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartId" value="@item.CartID">
                            <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="qbtn">−</button>
                            <span class="qval" style="display:flex;align-items:center;justify-content:center">@item.Quantity</span>
                            <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="qbtn">+</button>
                        </form>
                    </div>

                    <div class="cart-total">@((unit * item.Quantity).ToString("N0"))đ</div>

                    <form method="post" asp-controller="Cart" asp-action="Remove">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="cartId" value="@item.CartID">
                        <button type="submit" class="cart-remove">
                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" /><path d="M10 11v6" /><path d="M14 11v6" /></svg>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>

    <div class="summary-side">
        <div class="points-box points-box--nav">
            <div class="points-header">
                <div>
                    <div class="points-label">Điểm thưởng của bạn</div>
                    <div class="points-amount" id="pointsDisplay">@rewardPoints.ToString("N0") điểm</div>
                </div>
                <span class="points-badge">NEVA Rewards</span>
            </div>
        </div>

        @if (Model.Any())
        {
            <div id="cartConfig" hidden
                 data-subtotal="@subtotal.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                 data-shipping="@shipping.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                 data-points="@rewardPoints"
                 data-saved-coupon="@savedCoupon"
                 data-saved-use-points="@savedUsePoints"></div>

            <div class="coupon-box">
                <div class="box-title">Mã giảm giá</div>
                <div class="coup-row">
                    <input type="text" id="couponInput" class="coup-in" placeholder="Nhập mã ưu đãi..." value="@savedCoupon" autocomplete="off">
                    <button type="button" class="coup-btn" id="btnApplyCoupon">Áp dụng</button>
                </div>
                <p class="promo-msg" id="couponMsg"></p>
            </div>

            <div class="points-box">
                <div class="points-rate">Quy đổi: <span>100 điểm = 10.000đ</span> · Tối đa 30% giá trị đơn</div>
                <div class="points-input-wrap">
                    <input type="number" id="pointsInput" class="points-in" min="0" max="@rewardPoints" placeholder="Số điểm muốn dùng" value="@(savedUsePoints > 0 ? savedUsePoints : "")">
                    <button type="button" class="points-btn" id="btnApplyPoints">Dùng điểm</button>
                </div>
                <input type="range" id="pointsSlider" class="points-slider" min="0" max="@rewardPoints" value="@savedUsePoints" step="100">
                <div class="points-info">
                    <span class="pts-discount" id="ptsSaving">Giảm: 0đ</span>
                </div>
                <div class="points-applied @(savedUsePoints > 0 ? "show" : "")" id="pointsApplied">
                    <div class="pts-applied-text" id="pointsAppliedText"></div>
                    <button type="button" class="pts-cancel" id="btnCancelPoints">Hủy</button>
                </div>
            </div>
        }

        <div class="ship-note">
            <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" /><polygon points="16 8 20 8 23 11 23 16 16 16 16 8" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
            @if (subtotal >= 500000)
            {
                <span style="color:#7aba7a">✓ Bạn được miễn phí vận chuyển!</span>
            }
            else
            {
                <span>Thêm <strong style="margin:0 4px;color:var(--gold)">@((500000 - subtotal).ToString("N0"))đ</strong> để miễn phí vận chuyển</span>
            }
        </div>

        <div class="summary-box">
            <div class="summary-title">Tóm tắt đơn</div>
            <div class="srow"><span class="slabel">Tạm tính</span><span id="sumSubtotal">@subtotal.ToString("N0")đ</span></div>
            <div class="srow"><span class="slabel">Phí vận chuyển</span><span id="sumShip">@(shipping == 0 ? "Miễn phí" : shipping.ToString("N0") + "đ")</span></div>
            <div class="srow" id="rowDiscount" hidden><span class="slabel">Giảm giá</span><span id="sumDiscount">— 0đ</span></div>
            <div class="srow" id="rowPoints" hidden><span class="slabel">Điểm thưởng</span><span id="sumPoints">— 0đ</span></div>
            <div class="srow total"><span>Tổng cộng</span><span id="sumTotal">@((subtotal + shipping).ToString("N0"))đ</span></div>
        </div>

        @if (Model.Any())
        {
            <button type="button" id="btnCheckout" class="btn-checkout" style="display:flex;align-items:center;justify-content:center;gap:10px;width:100%;cursor:pointer">
                <svg viewBox="0 0 24 24"><path d="M5 12h14" /><path d="M12 5l7 7-7 7" /></svg>
                Thanh toán ngay
            </button>
        }
        <a asp-controller="Product" asp-action="Index" class="btn-continue">← Tiếp tục mua sắm</a>
        <p class="secure">
            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
            Thanh toán an toàn · COD toàn quốc
        </p>
    </div>
</div>

@section Scripts {
    <script src="~/js/gio-hang.js" asp-append-version="true"></script>
}
