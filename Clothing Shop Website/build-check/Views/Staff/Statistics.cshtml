@model Clothing_Shop_Website.ViewModels.AdminDashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Thống kê";
    Layout = null;

    var revenuePoints = Model.RevenueLastMonths.Select(r => new { label = r.Label, revenue = r.Revenue }).ToList();
    var catPie = Model.RevenueByCategory.Select(r => new { label = r.Label, amount = r.Amount }).ToList();

    var statsPayload = JsonSerializer.Serialize(new
    {
        revenue6m = revenuePoints,
        catPie = catPie
    });
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>NEVA — Thống kê</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Josefin+Sans:wght@200;300;400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/neva-base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/staff.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
    <div class="toast" id="toast"></div>
    <nav class="admin-nav">
        <span class="admin-nav-logo">NEVA</span><span class="admin-nav-sep">|</span><span class="staff-nav-badge">Nhân viên</span>
    </nav>
    <div class="admin-wrap">
        <aside class="admin-sidebar">
            <div class="sb-section">
                <div class="sb-lbl">Nhân viên</div>
                <a asp-controller="Staff" asp-action="Inventory" class="sitem"><svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>Kho hàng</a>
                <a asp-controller="Staff" asp-action="Customers" class="sitem"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>Khách hàng</a>
                <a asp-controller="Staff" asp-action="Orders" class="sitem"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>Đơn hàng</a>
                <a asp-controller="Staff" asp-action="Statistics" class="sitem active"><svg viewBox="0 0 24 24"><rect x="3" y="12" width="4" height="9" /><rect x="10" y="8" width="4" height="13" /><rect x="17" y="3" width="4" height="18" /></svg>Thống kê</a>
            </div>
            <div class="sb-section" style="margin-top:12px">
                <a asp-controller="Account" asp-action="Logout" class="sitem danger"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>Đăng xuất</a>
            </div>
        </aside>
        <main class="admin-main">

            @if (!string.IsNullOrEmpty(Model.CubeError))
            {
                <div style="padding:10px 16px;background:rgba(200,150,50,.08);border:1px solid rgba(200,150,50,.25);color:rgba(220,180,80,.8);font-size:11px;margin-bottom:16px">⚠ @Model.CubeError</div>
            }

            <!-- Header bar -->
            <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap;gap:10px">
                <div>
                    <div class="page-title">Thống kê</div>
                    <div class="page-sub">Doanh thu & phân tích từ cube · Dữ liệu MDX realtime</div>
                </div>
                <button type="button" id="btnExportReport" class="btn-export">
                    <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Xuất báo cáo CSV
                </button>
            </div>

            <!-- KPI Cards -->
            <div class="stats-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px">
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                    </div>
                    <div class="stat-lbl">Doanh thu</div>
                    <div class="stat-val g">@Model.TotalRevenue.ToString("N0")đ</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                    </div>
                    <div class="stat-lbl">Dòng bán hàng</div>
                    <div class="stat-val">@Model.TotalSalesLines</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                    </div>
                    <div class="stat-lbl">Khách hàng</div>
                    <div class="stat-val">@Model.DistinctCustomers</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /></svg>
                    </div>
                    <div class="stat-lbl">Sản phẩm bán</div>
                    <div class="stat-val">@Model.DistinctProductsSold</div>
                </div>
            </div>

            <!-- Charts row -->
            <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:24px">
                <!-- Revenue bar chart -->
                <div style="background:var(--dark2);border:1px solid var(--border);padding:20px">
                    <div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.65);margin-bottom:14px">Doanh thu theo tháng</div>
                    <div style="position:relative;height:260px">
                        <canvas id="revChart"></canvas>
                    </div>
                </div>
                <!-- Category pie chart -->
                <div style="background:var(--dark2);border:1px solid var(--border);padding:20px">
                    <div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.65);margin-bottom:14px">Doanh thu theo danh mục</div>
                    <div style="position:relative;height:260px">
                        <canvas id="catChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Top sellers table -->
            @if (Model.TopSellers.Any())
            {
                <div style="background:var(--dark2);border:1px solid var(--border);margin-bottom:24px">
                    <div style="padding:14px 18px;border-bottom:1px solid var(--border)">
                        <div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.65)">Sản phẩm bán chạy nhất</div>
                    </div>
                    <table style="width:100%;border-collapse:collapse">
                        <thead>
                            <tr>
                                <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.55);padding:10px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.1)">#</th>
                                <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.55);padding:10px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.1)">Sản phẩm</th>
                                <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.55);padding:10px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.1)">Danh mục</th>
                                <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.55);padding:10px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.1)">Đã bán</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rank = 1; }
                            @foreach (var p in Model.TopSellers.Take(8))
                            {
                                <tr style="border-bottom:1px solid rgba(201,168,76,.05)">
                                    <td style="padding:12px 16px;font-size:11px;color:rgba(201,168,76,.5);font-weight:300">@(rank++)</td>
                                    <td style="padding:12px 16px">
                                        <div style="display:flex;align-items:center;gap:10px">
                                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                                            {
                                                <div style="width:32px;height:40px;flex-shrink:0;overflow:hidden">
                                                    <img src="@p.ImageUrl" style="width:100%;height:100%;object-fit:cover;filter:brightness(.8)" onerror="this.style.display='none'">
                                                </div>
                                            }
                                            <div style="font-family:'EB Garamond',serif;font-style:italic;font-size:14px;color:var(--white)">@p.ProductName</div>
                                        </div>
                                    </td>
                                    <td style="padding:12px 16px;font-size:12px;color:rgba(250,248,242,.6)">@p.CategoryName</td>
                                    <td style="padding:12px 16px">
                                        <span style="color:var(--gold);font-size:15px;font-weight:300">@p.QuantitySold.ToString("N0")</span>
                                        <span style="font-size:10px;color:rgba(250,248,242,.4);margin-left:3px">sản phẩm</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- Recent days (cube) -->
            @if (Model.RecentCubeDays.Any())
            {
                <div style="background:var(--dark2);border:1px solid var(--border)">
                    <div style="padding:14px 18px;border-bottom:1px solid var(--border)">
                        <div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(201,168,76,.65)">Doanh thu gần đây (theo ngày)</div>
                    </div>
                    <table style="width:100%;border-collapse:collapse">
                        <thead>
                            <tr>
                                <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.55);padding:10px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.1)">Ngày</th>
                                <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.55);padding:10px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.1)">Doanh thu</th>
                                <th style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.55);padding:10px 16px;border-bottom:1px solid var(--border);text-align:left;font-weight:300;background:rgba(0,0,0,.1)">Số dòng bán</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var day in Model.RecentCubeDays.Take(7))
                            {
                                <tr style="border-bottom:1px solid rgba(201,168,76,.05)">
                                    <td style="padding:11px 16px;font-size:12px;color:rgba(250,248,242,.7)">@day.Date.ToString("dd/MM/yyyy")</td>
                                    <td style="padding:11px 16px;font-size:13px;color:var(--gold);font-weight:300">@day.Revenue.ToString("N0")đ</td>
                                    <td style="padding:11px 16px;font-size:12px;color:rgba(250,248,242,.6)">@day.SalesLines</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </main>
    </div>

    <!-- JSON payload for charts -->
    <script id="statsPayload" type="application/json">@Html.Raw(statsPayload)</script>

    <script src="~/js/neva-base.js" asp-append-version="true"></script>
    <script src="~/js/staff-stats.js" asp-append-version="true"></script>
</body>
</html>
