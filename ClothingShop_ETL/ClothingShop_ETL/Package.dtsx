                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">[ISNULL](#{Package\DimCustomer\Data Conversion.Outputs[Data Conversion Output].Columns[Copy of BirthDay]}) ? NULL(DT_WSTR,50) : ([DATEDIFF]("Year",#{Package\DimCustomer\Data Conversion.Outputs[Data Conversion Output].Columns[Copy of BirthDay]},[GETDATE]()) &lt; 18 ? "Duoi 18" : ([DATEDIFF]("Year",#{Package\DimCustomer\Data Conversion.Outputs[Data Conversion Output].Columns[Copy of BirthDay]},[GETDATE]()) &lt;= 24 ? "18-24" : "Tren 25"))</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">ISNULL([Copy of BirthDay]) ? NULL(DT_WSTR,50) : (DATEDIFF("Year",[Copy of BirthDay],GETDATE()) &lt; 18 ? "Duoi 18" : (DATEDIFF("Year",[Copy of BirthDay],GETDATE()) &lt;= 24 ? "18-24" : "Tren 25"))</property>
